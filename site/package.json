{
  "name": "site",
  "type": "module",
  "version": "0.0.1",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "astro dev",
    "dev:hybrid": "node scripts/generate_runtime_cache_version.mjs && astro dev --config astro.hybrid.config.mjs",
    "prebuild": "node ../scripts/check_editorial_templates.mjs && node ../scripts/check_english_tool_translations.mjs && node scripts/check_tool_public_state.mjs && node ../scripts/generate_tool_added_manifest.mjs && node ../scripts/generate_content_lastmod_manifest.mjs && node ../scripts/generate_guide_backlinks.mjs",
    "build": "astro build",
    "build:frozen-tools": "UTILDESK_BUILD_FROZEN_TOOL_DETAILS=1 npm run build",
    "build:hybrid": "node scripts/generate_runtime_cache_version.mjs && astro build --config astro.hybrid.config.mjs",
    "build:runtime": "node scripts/generate_runtime_sitemap_static.mjs && node scripts/generate_runtime_cache_version.mjs && astro build --config astro.runtime.config.mjs",
    "postbuild": "node scripts/sync_public_images.mjs && node scripts/sync_runtime_ratgeber_fallback_css.mjs && node scripts/generate_published_ratgeber_manifest.mjs && node ../scripts/check_built_tool_routes.mjs && node scripts/generate_sitemap.mjs",
    "preview": "astro preview",
    "export:runtime": "node scripts/export_runtime_content.mjs",
    "publish:runtime": "node scripts/publish_runtime_content.mjs",
    "release:tool-runtime": "node scripts/tool_runtime_release.mjs",
    "astro": "astro",
    "check:tools-sort": "node ../scripts/check_tools_newest_sort.mjs",
    "check:search": "node ../scripts/check_search_query_contract.mjs",
    "check:tool-public-state": "node scripts/check_tool_public_state.mjs",
    "capture:tool-runtime-baseline": "node scripts/capture_tool_runtime_baseline.mjs",
    "check:tool-runtime-parity": "node scripts/check_tool_runtime_parity.mjs",
    "check:tool-shell-runtime-parity": "node scripts/check_tool_shell_runtime_parity.mjs",
    "check:tool-machine-runtime-parity": "node scripts/check_tool_machine_runtime_parity.mjs",
    "audit:tool-runtime-resources": "node scripts/audit_tool_runtime_resources.mjs",
    "gate:tool-runtime-local-full": "node scripts/tool_runtime_gate.mjs local-full",
    "gate:tool-runtime-production-canary": "node scripts/tool_runtime_gate.mjs production-canary",
    "gate:tool-runtime-production-delta": "node scripts/tool_runtime_gate.mjs production-delta",
    "import:runtime-local": "node scripts/import_local_runtime_projection.mjs",
    "test:tool-runtime": "node --test scripts/tests/*.test.mjs",
    "fetch:logos": "node ../scripts/fetch_simpleicons_logos.mjs"
  },
  "dependencies": {
    "astro": "^6.4.8",
    "gray-matter": "^4.0.3",
    "marked": "^18.0.2"
  },
  "devDependencies": {
    "@astrojs/cloudflare": "^13.7.0",
    "wrangler": "^4.110.0"
  }
}
