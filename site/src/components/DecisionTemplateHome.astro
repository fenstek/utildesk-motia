---
import { getToolEditorialVerdict, type ToolEditorialVerdictValue } from "../lib/toolVerdict";

interface ToolItem {
  slug: string;
  title: string;
  category?: string | null;
  price_model?: string | null;
  excerpt?: string | null;
  tags?: string[];
  providerHost?: string | null;
  homeCardLogo?: string | null;
  editorialVerdict?: ToolEditorialVerdictValue | null;
}

interface ArticleItem {
  slug: string;
  data: {
    title: string;
    excerpt?: string;
    eyebrow?: string;
    category?: string;
    readTime?: number;
  };
}

interface CategoryItem {
  slug: string;
  title: string;
  titleEn?: string;
  count: number;
}

interface TaskItem {
  title: string;
  desc: string;
  href: string;
  links?: { label: string; href: string }[];
}

const {
  locale = "de",
  toolsCount = 0,
  guidesCount,
  categories = [],
  guides = [],
  tools = [],
  tasks = [],
  tags = [],
} = Astro.props as {
  locale?: "de" | "en";
  toolsCount: number;
  guidesCount?: number;
  categories: CategoryItem[];
  guides: ArticleItem[];
  tools: ToolItem[];
  tasks: TaskItem[];
  tags: [string, number][];
};

const isEn = locale === "en";
const prefix = isEn ? "/en" : "";
const issueNo = "049";
const today = "27.05.2026";
const issueDateLine = isEn ? "Wednesday \u00b7 27 May 2026" : "Mittwoch \u00b7 27. Mai 2026";
const copyrightYear = 2026;
const totalGuides = typeof guidesCount === "number" ? guidesCount : guides.length;
const copy = isEn
  ? {
      tabIssue: "↳ Issue № 049",
      tabClassic: "↳ Classic design",
      brand: "utildesk · decision desk",
      navDecisions: "Decisions",
      navGuides: "Guides",
      navTools: "Tool index",
      navMethod: "Methodology",
      masthead: "KI-Blatt",
      mastSub: "An editorial decision desk for AI tools",
      issueLine: "Issue",
      edited: "Edited in Germany",
      rightStats: `${totalGuides || guides.length || 25} decisions · ${toolsCount} tools indexed`,
      noAds: "0 paid placements",
      kicker: `Decision № ${issueNo} · AI tool review`,
      headline: "Should my team introduce Cursor, Copilot or Claude Code?",
      dek: "Three very different promises \u2014 and only one fits teams that take code seriously.",
      verdictLabel: "Editorial verdict",
      verdict: "Claude Code for senior teams. Copilot as the safer default. Cursor only after a pilot.",
      verdictText: "The bottleneck is no longer writing code. It is understanding, reviewing and owning what the tool changed.",
      toolsLabel: "In the test",
      avoidLabel: "Do not start with",
      avoidOne: "rolling out Cursor blindly",
      avoidTwo: "leaving Copilot as the \"it does nothing\" default",
      read: "Read the current decision",
      minutes: "min read",
      evidence: "Evidence file",
      evidenceText: "What we compare before a tool enters the front page.",
      factsLabel: "At a glance",
      factOne: "Start with one workflow, not the full stack.",
      factTwo: "No production use without review ownership.",
      factThree: "Prefer boring logs over impressive demos.",
      antiTitle: "What we would not recommend this week.",
      taskTitle: "Start by task, not by vendor.",
      indexTitle: "Tool index \u2014 8 of",
      indexAppendix: "\u21b3 Appendix",
      fullIndex: "\u21b3 full index \u00b7 /api/tools.json",
      tableNo: "\u2116",
      tableTool: "Tool \u00b7 assessment",
      tableVerdict: "Verdict",
      tableTags: "Tags",
      tableCategory: "Category",
      tablePrice: "Price",
      tableOpen: "Open",
      topTagsLabel: "Top tags ->",
      footer: `No paid slots. No ranking theater. ${totalGuides || guides.length || 25} editorial guides + ${toolsCount} indexed tools from public sources.`,
      footerLines: [
        "No paid slots. No ranking theater.",
        `${totalGuides || guides.length || 25} editorial guides + ${toolsCount} indexed tools from public sources.`,
      ],
      footerCopyright: `Copyright © ${copyrightYear} Utildesk`,
      footerPrivacy: "Privacy",
      footerImprint: "Imprint",
      footerFeed: "Feed",
    }
  : {
      tabIssue: "↳ Ausgabe № 049",
      tabClassic: "↳ Klassisches Design",
      brand: "utildesk · entscheidungsblatt",
      navDecisions: "Entscheidungen",
      navGuides: "Ratgeber",
      navTools: "Tool-Index",
      navMethod: "Methodologie",
      masthead: "KI-Blatt",
      mastSub: "Ein redaktioneller Entscheidungs-Desk für KI-Werkzeuge",
      issueLine: "Ausgabe",
      edited: "Redigiert in Deutschland",
      rightStats: `${totalGuides || guides.length || 25} Entscheidungen · ${toolsCount} Tools indiziert`,
      noAds: "0 bezahlte Platzierungen",
      kicker: `Entscheidung № ${issueNo} · AI-Tool Review`,
      headline: "Soll mein Team Cursor, Copilot oder Claude Code einf\u00fchren?",
      dek: "Drei sehr unterschiedliche Versprechen \u2014 und nur eines davon passt zu Teams, die Code ernst nehmen.",
      verdictLabel: "Verdikt der Redaktion",
      verdict: "Claude Code f\u00fcr Senior-Teams. Copilot als sicherer Standard. Cursor erst nach Pilot.",
      verdictText: "Der Engpass liegt nicht mehr im Schreiben von Code, sondern im Verstehen, Pr\u00fcfen und Verantworten der \u00c4nderungen.",
      toolsLabel: "Im Test",
      avoidLabel: "Nicht damit starten",
      avoidOne: "Cursor blind ausrollen",
      avoidTwo: "Copilot als macht-ja-eh-nichts-Default lassen",
      read: "Aktuelle Entscheidung lesen",
      minutes: "min Lesezeit",
      evidence: "Beweismaterial",
      evidenceText: "Was wir vergleichen, bevor ein Tool auf die Titelseite kommt.",
      factsLabel: "Auf einen Blick",
      factOne: "Mit einem Workflow starten, nicht mit dem ganzen Stack.",
      factTwo: "Keine Produktivnutzung ohne klare Review-Verantwortung.",
      factThree: "Lieber langweilige Logs als beeindruckende Demos.",
      antiTitle: "Was wir diese Woche nicht empfehlen würden.",
      taskTitle: "Nach Aufgabe starten, nicht nach Anbieter.",
      indexTitle: "Tool-Index \u2014 8 von",
      indexAppendix: "\u21b3 Anhang",
      fullIndex: "\u21b3 vollst\u00e4ndiger Index \u00b7 /api/tools.json",
      tableNo: "\u2116",
      tableTool: "Tool \u00b7 Einordnung",
      tableVerdict: "Verdikt",
      tableTags: "Tags",
      tableCategory: "Kategorie",
      tablePrice: "Preis",
      tableOpen: "Open",
      topTagsLabel: "Top.Tags ->",
      footer: `Keine bezahlten Slots. Kein Ranking-Theater. ${totalGuides || guides.length || 25} redaktionelle Ratgeber + ${toolsCount} indizierte Tools mit öffentlichen Quellen.`,
      footerLines: [
        "Keine bezahlten Slots. Kein Ranking-Theater.",
        `${totalGuides || guides.length || 25} redaktionelle Ratgeber + ${toolsCount} indizierte Tools mit öffentlichen Quellen.`,
      ],
      footerCopyright: `Copyright © ${copyrightYear} Utildesk`,
      footerPrivacy: "Datenschutz",
      footerImprint: "Impressum",
      footerFeed: "Feed",
    };

const primaryGuide = guides[0];
const guideCards = guides.slice(0, 3);
const toolRows = tools.slice(0, 12);
const indexRows = tools.slice(0, 8);
const toolHrefBySlug = (slug: string) => `${prefix}/tools/${slug}/`;
const testRows = isEn
  ? [
      { title: "Claude Code", slug: "claude", note: "best context discipline", score: "9.1", icon: "\u2713", kind: "recommend" },
      { title: "GitHub Copilot", slug: "github-copilot", note: "safer standard", score: "8.4", icon: "\u2713", kind: "recommend" },
      { title: "Cursor", slug: "cursor", note: "only with review pilot", score: "7.0", icon: "\u25d0", kind: "caution" },
    ]
  : [
      { title: "Claude Code", slug: "claude", note: "beste Kontext-Disziplin", score: "9.1", icon: "\u2713", kind: "recommend" },
      { title: "GitHub Copilot", slug: "github-copilot", note: "sicherer Standard", score: "8.4", icon: "\u2713", kind: "recommend" },
      { title: "Cursor", slug: "cursor", note: "nur mit Review-Pilot", score: "7.0", icon: "\u25d0", kind: "caution" },
    ];
const frontNote = isEn
  ? "We had three teams work with Cursor, Copilot and Claude Code for a week. What began as a speed test ended as a discussion about responsibility: who reviews what an agent commits?"
  : "Wir haben drei Teams je eine Woche lang mit Cursor, Copilot und Claude Code arbeiten lassen. Was als Geschwindigkeitstest begann, endete als Diskussion \u00fcber Verantwortung: Wer reviewt, was ein Agent committet?";

const normalizeTagSlug = (tag: string) =>
  tag
    .toLowerCase()
    .normalize("NFKD")
    .replace(/[\u0300-\u036f]/g, "")
    .replace(/[^a-z0-9]+/g, "-")
    .replace(/^-+|-+$/g, "");

const shortCategory = (category?: string | null) => {
  if (!category) return "AI";
  const value = String(category);
  const normalized = value.toLowerCase();
  if (normalized.includes("entwickler")) return isEn ? "Developer" : "Entwickler";
  if (normalized.includes("automatis")) return "Automation";
  if (normalized.includes("schreiben")) return isEn ? "Writing" : "Schreiben";
  if (normalized.includes("design")) return "Design";
  if (normalized.includes("chatbot")) return "AI";
  if (normalized.includes("audio")) return "Audio";
  if (normalized.includes("produkt")) return isEn ? "Productivity" : "Produktivitaet";
  if (normalized.includes("marketing")) return "Marketing";
  return value;
};

const indexVerdictFor = (tool: ToolItem, index: number) => {
  if (tool.editorialVerdict) return getToolEditorialVerdict(tool.editorialVerdict, locale);
  const haystack = `${tool.title} ${(tool.tags || []).join(" ")} ${tool.excerpt || ""}`.toLowerCase();
  if (haystack.includes("detector") || haystack.includes("autogpt") || haystack.includes("agent")) {
    return index % 2 === 0
      ? { kind: "caution", icon: "\u25d0", label: isEn ? "With caveat" : "Mit Vorbehalt" }
      : { kind: "overrated", icon: "\u2298", label: isEn ? "Overrated" : "\u00dcberbewertet" };
  }
  if (haystack.includes("privacy") || haystack.includes("research") || haystack.includes("search") || haystack.includes("perplexity")) {
    return { kind: "caution", icon: "\u25d0", label: isEn ? "With caveat" : "Mit Vorbehalt" };
  }
  return { kind: "recommend", icon: "\u2713", label: isEn ? "Recommend" : "Empfehlen" };
};
const fallbackTasks = isEn
  ? [
      { title: "Compare privacy risk", desc: "Check hosting, retention and auditability before sensitive prompts.", href: `${prefix}/ratgeber/` },
      { title: "Choose a team default", desc: "Separate safe defaults from specialist tools for expert teams.", href: `${prefix}/category/` },
      { title: "Prepare AI governance", desc: "Define owners, logs and review rituals before rollout.", href: `${prefix}/ratgeber/` },
      { title: "Review vendor claims", desc: "Turn landing-page promises into concrete checks and evidence.", href: `${prefix}/tools/` },
      { title: "Map automation risks", desc: "Find handoffs where agents need limits, logs and rollback.", href: `${prefix}/category/automatisierung/` },
      { title: "Pick research tools", desc: "Compare source quality, citation habits and export workflows.", href: `${prefix}/tools/` },
    ]
  : [
      { title: "Datenschutzrisiko vergleichen", desc: "Hosting, Aufbewahrung und Nachvollziehbarkeit vor sensiblen Prompts prüfen.", href: `${prefix}/ratgeber/` },
      { title: "Team-Standard auswählen", desc: "Sichere Defaults von Spezialtools für Expertenteams trennen.", href: `${prefix}/category/` },
      { title: "KI-Governance vorbereiten", desc: "Owner, Logs und Review-Rituale vor dem Rollout klären.", href: `${prefix}/ratgeber/` },
      { title: "Vendor-Versprechen prüfen", desc: "Landingpage-Claims in konkrete Checks und Belege übersetzen.", href: `${prefix}/tools/` },
      { title: "Automationsrisiken kartieren", desc: "Übergaben finden, bei denen Agenten Grenzen, Logs und Rollback brauchen.", href: `${prefix}/category/automatisierung/` },
      { title: "Recherche-Tools auswählen", desc: "Quellenqualität, Zitierverhalten und Export-Workflows vergleichen.", href: `${prefix}/tools/` },
    ];
const taskRows = [...tasks, ...fallbackTasks].slice(0, 6);
while (taskRows.length < 6) {
  taskRows.push(fallbackTasks[taskRows.length % fallbackTasks.length]);
}
const tagRows = tags.slice(0, 12);
const categoryRows = categories.slice(0, 8);
---

<section class="ds-template ds-template-flat" aria-label={copy.masthead}>
  <div class="ds-stage">
    <div class="ds-frame">
      <div class="ds-masthead-ki">
        <div class="ds-masthead-ki-side">
          {copy.issueLine} {issueNo}<br />
          {issueDateLine}<br />
          {copy.edited}
        </div>
        <div class="ds-masthead-ki-main">
          <span>{copy.masthead}<em>.</em></span>
          <p>{copy.mastSub}</p>
        </div>
        <div class="ds-masthead-ki-side ds-masthead-ki-side-right">
          {totalGuides || guides.length || 25} {isEn ? "decisions" : "Entscheidungen"} {"\u00b7"} {toolsCount} {isEn ? "tools indexed" : "Tools indiziert"}<br />
          0 {isEn ? "paid placements" : "bezahlte Platzierungen"}
        </div>
      </div>

      <section class="ds-front">
        <article class="ds-front-main">
          <p class="ds-kicker">{copy.kicker}</p>
          <h2>{copy.headline}</h2>
          <p class="ds-dek">{copy.dek}</p>

          <div class="ds-verdict ds-verdict-caution">
            <span class="ds-verdict-label">{copy.verdictLabel}</span>
            <span class="ds-verdict-glyph">◐</span>
            <div>
              <strong>{copy.verdict}</strong>
              <p>{copy.verdictText}</p>
            </div>
          </div>

          <div class="ds-front-actions">
            <a href={primaryGuide ? `${prefix}/ratgeber/${primaryGuide.slug}/` : `${prefix}/ratgeber/`}>{copy.read}</a>
            <span>{primaryGuide?.data.readTime || 8} {copy.minutes}</span>
          </div>
        </article>

        <aside class="ds-front-aside ds-front-aside-test">
          <div class="ds-test-table">
            <h3>{copy.toolsLabel}</h3>
            {testRows.map((tool) => (
              <a class={`ds-test-row ds-test-row-${tool.kind}`} href={toolHrefBySlug(tool.slug)}>
                <span class="ds-test-icon">{tool.icon}</span>
                <strong>{tool.title}<small>{tool.note}</small></strong>
                <b>{tool.score}</b>
              </a>
            ))}
          </div>
          <div class="ds-box ds-box-warn ds-box-warn-dashed">
            <h3>{copy.avoidLabel}</h3>
            <p>• {copy.avoidOne}</p>
            <p>• {copy.avoidTwo}</p>
          </div>
          <p class="ds-front-note"><span>{isEn ? "W" : "W"}</span>{frontNote.slice(1)}</p>
        </aside>
      </section>

      <section class="ds-stack" aria-label={isEn ? "Recent decisions" : "Aktuelle Entscheidungen"}>
        {guideCards.map((article, index) => (
          <article>
            <div class="ds-card-no">№ {String(issueNo - index).padStart(3, "0")}</div>
            <h3><a href={`${prefix}/ratgeber/${article.slug}/`}>{article.data.title}</a></h3>
            <p>{article.data.excerpt || copy.evidenceText}</p>
            <div class="ds-card-foot">
              <span>{article.data.eyebrow || article.data.category || "AI"}</span>
              <span>{article.data.readTime || 7} min</span>
            </div>
          </article>
        ))}
      </section>

      <section class="ds-evidence">
        <div>
          <p class="ds-kicker">↳ {copy.evidence}</p>
          <h2>{copy.evidenceText}</h2>
        </div>
        <div class="ds-evidence-grid">
          <span>{toolsCount}</span><p>Tools</p>
          <span>{categories.length}</span><p>{isEn ? "Categories" : "Kategorien"}</p>
          <span>{totalGuides}</span><p>{isEn ? "Guides" : "Ratgeber"}</p>
          <span>0</span><p>Ads</p>
        </div>
      </section>

      <section class="ds-anti">
        <h2>{copy.antiTitle}</h2>
        <div>
          <article><span>nicht empfehlen</span><strong>AI-Detector-Tools</strong><p>False positives machen sie als Entscheidungsgrundlage unbrauchbar.</p></article>
          <article><span>überbewertet</span><strong>Autonome Agenten</strong><p>Ohne Scope, Logs und Review werden Demos schneller als Prozesse.</p></article>
          <article><span>abwarten</span><strong>AI-first SaaS-Resterampe</strong><p>GPT-Wrapper mit Abo-Preis brauchen mehr Belege als Landingpages.</p></article>
        </div>
      </section>

      <section class="ds-tasks">
        <p class="ds-kicker">↳ Aufgaben</p>
        <h2>{copy.taskTitle}</h2>
        <div>
          {taskRows.map((task, index) => (
            <a href={task.href}>
              <span>{String(index + 1).padStart(2, "0")}</span>
              <strong>{task.title}</strong>
              <em>{task.desc}</em>
            </a>
          ))}
        </div>
      </section>

      <section class="ds-index ds-index-appendix">
        <div class="ds-index-head ds-index-head-spread">
          <div>
            <p class="ds-kicker">{copy.indexAppendix}</p>
            <h2>{copy.indexTitle} {toolsCount}</h2>
          </div>
          <a class="ds-index-api" href="/api/tools.json">{copy.fullIndex}</a>
        </div>

        <div class="ds-index-table" role="table" aria-label={copy.navTools}>
          <div class="ds-index-table-head" role="row">
            <span>{copy.tableNo}</span>
            <span>{"\u00b7"}</span>
            <span>{copy.tableTool}</span>
            <span>{copy.tableVerdict}</span>
            <span>{copy.tableTags}</span>
            <span>{copy.tableCategory}</span>
            <span>{copy.tablePrice}</span>
            <span>{copy.tableOpen}</span>
          </div>
          {indexRows.map((tool, index) => {
            const verdict = indexVerdictFor(tool, index);
            const tagsForRow = (tool.tags || []).slice(0, 3);
            return (
              <a class="ds-index-row" href={`${prefix}/tools/${tool.slug}/`} role="row">
                <span class="ds-index-no">{String(index + 1).padStart(2, "0")}</span>
                <span class="ds-index-tool">
                  <span class="ds-index-logo" aria-hidden="true">
                    {tool.homeCardLogo ? <img src={tool.homeCardLogo} alt="" loading="lazy" /> : <span>{tool.title.slice(0, 1)}</span>}
                  </span>
                  <span>
                    <strong>{tool.title}</strong>
                    {tool.providerHost && <small>{tool.providerHost}</small>}
                    <em>{tool.excerpt || (isEn ? "Compact entry in the Utildesk index." : "Kompakter Eintrag im Utildesk-Verzeichnis.")}</em>
                  </span>
                </span>
                <span class={`ds-index-verdict ds-index-verdict-${verdict.kind}`}>
                  <b>{verdict.icon}</b>
                  <span>{verdict.label}</span>
                </span>
                <span class="ds-index-tags">
                  {tagsForRow.map((tag) => <span>#{tag}</span>)}
                </span>
                <span class="ds-index-category">{shortCategory(tool.category)}</span>
                <span class="ds-index-price">{tool.price_model || "n/a"}</span>
                <span class="ds-index-open" aria-hidden="true">{"\u2197"}</span>
              </a>
            );
          })}
        </div>

        <div class="ds-index-top-tags" aria-label={isEn ? "Top tags" : "Top-Tags"}>
          <span>{copy.topTagsLabel}</span>
          {tagRows.map(([tag, count]) => (
            <a href={`${prefix}/tools/tag/${normalizeTagSlug(tag)}/`}>#{tag}<small>{count}</small></a>
          ))}
        </div>
      </section>

    </div>
  </div>
</section>
