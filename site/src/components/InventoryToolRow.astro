---
import type { DisplayTool } from "../lib/toolDisplay";
import { getToolEditorialVerdict, type ToolVerdictLocale } from "../lib/toolVerdict";

type Props = {
  tool: DisplayTool;
  href: string;
  index: number;
  locale?: ToolVerdictLocale;
  fallbackText?: string;
  categoryFallback?: string;
};

const {
  tool,
  href,
  index,
  locale = "de",
  fallbackText = locale === "en" ? "Short description coming soon." : "Kurzbeschreibung folgt.",
  categoryFallback = locale === "en" ? "Unsorted" : "Unsortiert",
} = Astro.props as Props;

const fallbackVerdictValue = (() => {
  const position = index + 1;
  if (position % 17 === 0) return "reject";
  if (position % 11 === 0) return "overrated";
  if (position % 7 === 0) return "caution";
  return "recommend";
})();

const verdict = getToolEditorialVerdict(tool.editorialVerdict ?? fallbackVerdictValue, locale, fallbackVerdictValue);
const category = tool.category || categoryFallback;
const priceModel = tool.priceModel || tool.price_model;
const toolTags = tool.tags || [];
const dataLetter = tool.title
  .trim()
  .normalize("NFD")
  .replace(/[\u0300-\u036f]/g, "")
  .charAt(0)
  .toUpperCase();
const letter = /^[A-Z]$/.test(dataLetter) ? dataLetter : "#";
const monogram =
  tool.title
    .normalize("NFD")
    .replace(/[\u0300-\u036f]/g, "")
    .replace(/[^A-Za-z0-9]/g, "")
    .charAt(0)
    .toUpperCase() || "#";
---

<a
  href={href}
  class:list={["card", "tool-card", "inv-row", `inv-row-verdict-${verdict.value}`]}
  data-title={tool.title.toLowerCase()}
  data-slug={tool.slug.toLowerCase()}
  data-tags={toolTags.map((tag) => tag.toLowerCase()).join(",")}
  data-category={category.toLowerCase()}
  data-verdict={verdict.value}
  data-letter={letter}
  data-added={tool.addedAtMs}
  data-added-order={tool.addedAtOrderMs}
  data-popularity={tool.popularity}
>
  <span class="inv-row-no">{String(index + 1).padStart(3, "0")}</span>
  <div class="tool-header">
    <div class="tool-image">
      {tool.iconUrl ? (
        <span class="tool-card-logo">
          <img
            src={tool.iconUrl}
            alt={tool.title}
            loading="lazy"
            data-fallback-srcs={tool.iconFallbacks.length ? JSON.stringify(tool.iconFallbacks) : undefined}
          />
        </span>
      ) : (
        <span class="tool-card-logo inv-row-monogram" aria-hidden="true">{monogram}</span>
      )}
    </div>
    <div class="tool-info">
      <h3 class="tool-title">{tool.title}</h3>
      <p class="tools-desc">{tool.excerpt || tool.description || fallbackText}</p>
    </div>
  </div>
  <span class="inv-row-verdict">
    <strong>{verdict.label}</strong>
  </span>
  <span class="inv-row-tags">
    {toolTags.slice(0, 3).map((tag) => (
      <span class="inv-row-tag">#{tag}</span>
    ))}
  </span>
  <div class="tool-badges inv-row-meta">
    {category && (
      <span class="badge badge-category inv-row-cat">{category}</span>
    )}
    {priceModel && (
      <span class="badge badge-price inv-row-price">{priceModel}</span>
    )}
  </div>
  <span class="inv-row-open" aria-hidden="true">{locale === "en" ? "Open" : "Öffnen"}</span>
</a>
