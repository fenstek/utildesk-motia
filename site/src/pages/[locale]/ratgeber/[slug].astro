---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import ContentJump from "../../../components/ContentJump.astro";
import { existsSync } from "node:fs";
import { join } from "node:path";
import { marked } from "marked";
import { getRatgeberEntry, listRatgeberEntries } from "../../../lib/ratgeber";
import { getRelatedGuides } from "../../../lib/guideRelations";
import { tagHref } from "../../../lib/tagRoutes";
import { getWordCountFromMarkdown } from "../../../lib/machineReadable";
import {
  buildBreadcrumbSchema,
  buildPublisherOrganization,
  SITE_LANGUAGE_EN,
  SITE_URL,
  toAbsoluteUrl,
} from "../../../lib/siteMeta";
import { buildFaqPageSchema, extractFaqPairsFromMarkdown } from "../../../lib/schema";
import { addContentHeadingIds, wrapFaqSection } from "../../../lib/contentNavigation";

export async function getStaticPaths() {
  const entries = await listRatgeberEntries("en");
  return entries.map((entry) => ({
    params: { locale: "en", slug: entry.slug },
    props: { entry, relatedGuides: getRelatedGuides(entry, entries) },
  }));
}

const { slug } = Astro.params;
const { entry: resolvedEntry, relatedGuides = [] } = Astro.props;
const entry = resolvedEntry ?? (await getRatgeberEntry(slug, "en"));

if (!entry) {
  return Astro.redirect("/404");
}

const { data, content } = entry;
const localAssetExists = (src: string | null | undefined) => {
  if (!src) return false;
  const value = String(src);
  if (!value.startsWith("/")) return true;
  const relativeAsset = value.replace(/^\//, "");
  return [
    join(process.cwd(), "public", relativeAsset),
    join(process.cwd(), "content", relativeAsset),
    join(process.cwd(), "..", "content", relativeAsset),
  ].some((candidate) => existsSync(candidate));
};
const safeCoverImage = data.coverImage && localAssetExists(String(data.coverImage)) ? String(data.coverImage) : null;
const safeSecondaryImage = data.secondaryImage && localAssetExists(String(data.secondaryImage)) ? String(data.secondaryImage) : null;
const rawArticleHtml = String(marked.parse(content));
let articleHtml = rawArticleHtml.replace(
  /<p>\s*(<img\b[^>]*>)\s*<\/p>/g,
  '<figure class="article-inline-image">$1</figure>',
);
articleHtml = articleHtml.replace(
  /<figure class="article-inline-image">\s*<img\b([^>]*?)src="([^"]+)"([^>]*)>\s*<\/figure>/g,
  (match, _before, src) => localAssetExists(src) ? match : "",
);
const headingNavigation = addContentHeadingIds(articleHtml);
articleHtml = wrapFaqSection(headingNavigation.html, "Open frequently asked questions");
const articleHeadings = headingNavigation.headings;
const title = String(data.title ?? slug);
const description = String(data.excerpt ?? title);
const faqSchema = buildFaqPageSchema(extractFaqPairsFromMarkdown(content));
const published = data.date
  ? new Intl.DateTimeFormat("en", { day: "2-digit", month: "long", year: "numeric" }).format(new Date(data.date))
  : "";
const updated = data.updated
  ? new Intl.DateTimeFormat("en", { day: "2-digit", month: "long", year: "numeric" }).format(new Date(data.updated))
  : "";
const decisionNumber = String(Math.abs(slug.length * 7 + 41) % 999 + 1).padStart(3, "0");

const normalizeMetaLabel = (value: string) =>
  String(value || "")
    .toLowerCase()
    .normalize("NFKD")
    .replace(/[\u0300-\u036f]/g, "")
    .replace(/^ai[-\s]+/, "")
    .replace(/^ki[-\s]+/, "")
    .replace(/[^a-z0-9]+/g, " ")
    .trim();

const eyebrowLabel = normalizeMetaLabel(String(data.eyebrow ?? ""));
const categoryLabel = normalizeMetaLabel(String(data.category ?? ""));
const categoryIsRedundant =
  Boolean(categoryLabel) &&
  Boolean(eyebrowLabel) &&
  (eyebrowLabel === categoryLabel ||
    eyebrowLabel.includes(categoryLabel) ||
    categoryLabel.includes(eyebrowLabel));
const renderedPills = new Set<string>();

const addRenderedPill = (label: string) => {
  const normalized = normalizeMetaLabel(label);
  if (!normalized || renderedPills.has(normalized)) {
    return false;
  }
  renderedPills.add(normalized);
  return true;
};

const relatedToolSet = new Set((data.relatedTools ?? []).map((tool: { title: string }) => normalizeMetaLabel(tool.title)));
const imageUrls = [
  safeCoverImage ? toAbsoluteUrl(safeCoverImage) : null,
  safeSecondaryImage ? toAbsoluteUrl(safeSecondaryImage) : null,
].filter(Boolean);
const canonicalUrl = `${SITE_URL}/en/ratgeber/${slug}/`;
const articleSchema = {
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  headline: title,
  description,
  datePublished: data.date,
  dateModified: data.updated ?? data.date,
  image: imageUrls.length ? imageUrls : undefined,
  mainEntityOfPage: canonicalUrl,
  inLanguage: SITE_LANGUAGE_EN,
  articleSection: data.category ? String(data.category) : undefined,
  keywords: Array.isArray(data.tags) ? data.tags.map(String).join(", ") : undefined,
  wordCount: getWordCountFromMarkdown(content) || undefined,
  isAccessibleForFree: true,
  author: buildPublisherOrganization(),
  publisher: buildPublisherOrganization(),
  about: Array.isArray(data.tags) ? data.tags.map((tag: string) => ({ "@type": "Thing", name: tag })) : undefined,
  mentions: Array.isArray(data.relatedTools)
    ? data.relatedTools.map((tool: { title: string; href: string }) => ({
        "@type": "SoftwareApplication",
        name: tool.title,
        url: tool.href.startsWith("http") ? tool.href : `${SITE_URL}${tool.href}`,
      }))
    : undefined,
};
const breadcrumbSchema = buildBreadcrumbSchema([
  { name: "Directory", url: `${SITE_URL}/en/` },
  { name: "Guides", url: `${SITE_URL}/en/ratgeber/` },
  { name: title, url: canonicalUrl },
]);
---

<BaseLayout locale="en" title={`${title} | Utildesk`} description={description}>
  <Fragment slot="head">
    <link rel="canonical" href={canonicalUrl} />
    <link rel="alternate" type="application/json" href={`/en/api/ratgeber/${slug}.json`} title={`${title} (JSON)`} />
    <link rel="alternate" type="text/markdown" href={`/en/markdown/ratgeber/${slug}.md`} title={`${title} (Markdown)`} />
    <script type="application/ld+json" set:html={JSON.stringify(articleSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
    {faqSchema ? <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} /> : null}
  </Fragment>

  <div class="tool-akte sheet-wrap">
    <nav class="akte-crumb" aria-label="Breadcrumb">
      <a href="/en/">&#x2190; Directory</a>
      <span class="akte-crumb-sep">/</span>
      <a href="/en/ratgeber/">Guides</a>
      <span class="akte-crumb-sep">/</span>
      <span class="akte-crumb-current">{title}</span>
    </nav>

    <div class:list={["sheet-lead", safeCoverImage ? "sheet-lead-with-cover" : "sheet-lead-without-cover"]}>
    <header class="sheet-head">
      <div class="sheet-head-kicker">
        &#x21B3; Decision No. {decisionNumber} · {data.eyebrow || data.category || "AI Guide"}
      </div>
      <h1 class="sheet-head-h1">
        {title}<span class="akte-mast-dot">.</span>
      </h1>
      {data.excerpt && (
        <p class="sheet-head-dek">{data.excerpt}</p>
      )}

      <div class="sheet-head-meta">
        <span class="sheet-head-byline">By <strong>Utildesk Editorial</strong></span>
        {published && <span>· {published}</span>}
        {updated && updated !== published && <span>· updated {updated}</span>}
        {data.readTime && <span>· {data.readTime} min read</span>}
        <span>· <a href="/en/methodology/">Methodology</a></span>
      </div>

      {(data.category || data.relatedTools?.length || data.tags?.length) && (
        <div class="akte-chips sheet-chips">
          {data.category && !categoryIsRedundant && addRenderedPill(data.category) ? (
            <span class="akte-chip akte-chip-category">{data.category}</span>
          ) : null}
          {data.relatedTools?.map((tool: { href: string; title: string }) => {
            if (!addRenderedPill(tool.title)) return null;
            return <a href={tool.href} class="akte-chip akte-chip-tag">{tool.title}</a>;
          })}
          {data.tags?.map((tag: string) => {
            const tagKey = normalizeMetaLabel(tag);
            if (!tagKey || relatedToolSet.has(tagKey) || !addRenderedPill(tag)) return null;
            return <a href={tagHref(tag, "en")} class="akte-chip akte-chip-tag">#{tag}</a>;
          })}
        </div>
      )}
    </header>

    {safeCoverImage ? (
      <figure class="sheet-cover">
        <button
          type="button"
          class="article-cover-trigger js-lightbox-image sheet-cover-btn"
          data-lightbox-src={safeCoverImage}
          data-lightbox-alt={data.eyebrow || "Illustration"}
          aria-label={`Open illustration: ${title}`}
        >
          <img src={safeCoverImage} alt={data.eyebrow || "Illustration"} loading="eager" decoding="async" />
        </button>
        <figcaption>
          <span class="sheet-cover-tag">Figure 1</span>
          {data.eyebrow || data.category || "Editorial illustration"} - file note for {title}.
        </figcaption>
      </figure>
    ) : null}
    </div>

    <div class="sheet-body">
      <aside class="sheet-sidecar" aria-label="Article overview">
        {data.sidebarPoints?.length ? (
          <section class="sheet-summary" aria-label={data.sidebarTitle || "Key takeaways"}>
            <div class="sheet-summary-tab">{data.sidebarTitle || "Key takeaways"}</div>
            <ul>
              {data.sidebarPoints.map((point) => <li>{point}</li>)}
            </ul>
          </section>
        ) : null}

        <ContentJump headings={articleHeadings} locale="en" />

        {data.decisionNote ? (
          <section class="sheet-editorial-note" aria-label="Editorial view">
            <span>Editorial view</span>
            <p>{data.decisionNote}</p>
          </section>
        ) : null}

        <section class="sheet-dossier" aria-label="Article details">
          <div class="sheet-dossier-kicker">Dossier</div>
          <dl>
            <div><dt>Issue</dt><dd>No. {decisionNumber}</dd></div>
            {published ? <div><dt>Published</dt><dd>{published}</dd></div> : null}
            {updated && updated !== published ? <div><dt>Updated</dt><dd>{updated}</dd></div> : null}
            {data.readTime ? <div><dt>Read time</dt><dd>{data.readTime} min</dd></div> : null}
            {data.category ? <div><dt>Section</dt><dd>{data.category}</dd></div> : null}
          </dl>
        </section>
      </aside>

      <article class="ratgeber-prose akte-article-body sheet-prose" set:html={articleHtml}></article>
    </div>

    {relatedGuides.length > 0 && (
      <section class="akte-alts related-guides" aria-label="More from this topic cluster">
        <div class="akte-alts-head"><div class="akte-alts-head-left"><div class="akte-alts-kicker">More from this topic cluster</div><h2 class="akte-alts-title">Related decisions<span class="akte-mast-dot">.</span></h2></div><a class="akte-alts-all" href="/en/ratgeber/">All guides</a></div>
        <div class="akte-alts-grid">{relatedGuides.map((guide, index) => <a class="akte-alt-card" href={`/en/ratgeber/${guide.slug}/`}><div class="akte-alt-card-head"><span class="akte-alt-card-kicker">Guide {String(index + 1).padStart(2, "0")}</span></div><div class="akte-alt-card-name">{guide.data.title}<span class="akte-mast-dot">.</span></div><p class="akte-alt-card-tone">{guide.data.excerpt}</p></a>)}</div>
      </section>
    )}

    <footer class="sheet-foot">
      <div class="sheet-foot-left">
        <div class="sheet-foot-kicker">This decision</div>
        <p class="sheet-foot-line">
          We review guides regularly. {updated ? `Last updated ${updated}.` : published ? `Last published ${published}.` : ""}
        </p>
      </div>
      <div class="sheet-foot-actions">
        <a class="akte-action akte-action-primary" href="/en/ratgeber/">&#x21A9; Back to guide archive</a>
        <a class="akte-action akte-action-ghost" href="/en/tools/">&#x21C4; Tool index</a>
      </div>
    </footer>
  </div>

  <dialog id="img-lightbox" class="lightbox">
    <button class="lightbox-close" aria-label="Close">x</button>
    <img id="lightbox-img" src="" alt="" />
  </dialog>
</BaseLayout>

<script>
  const lightbox = document.getElementById('img-lightbox') as HTMLDialogElement | null;
  const lbImg = document.getElementById('lightbox-img') as HTMLImageElement | null;
  if (lightbox && lbImg) {
    const openLightbox = (src: string, alt: string) => {
      if (!src) return;
      lbImg.src = src;
      lbImg.alt = alt;
      lightbox.showModal();
    };

    const bindLightboxTarget = (node: Element) => {
      const target = node as HTMLElement;
      if (target.dataset.lightboxBound === 'true') return;

      let src = '';
      let alt = '';

      if (node instanceof HTMLImageElement) {
        src = node.currentSrc || node.src;
        alt = node.alt;
        node.style.cursor = 'zoom-in';
      } else {
        src = target.dataset.lightboxSrc || '';
        alt = target.dataset.lightboxAlt || '';
      }

      if (!src) return;

      target.dataset.lightboxBound = 'true';
      target.addEventListener('click', () => openLightbox(src, alt));
    };

    document.querySelectorAll('.article-cover-trigger, .ratgeber-prose img').forEach((node) => {
      bindLightboxTarget(node);
    });

    lightbox.addEventListener('click', (e) => {
      if (e.target === lightbox) lightbox.close();
    });
    document.querySelector('.lightbox-close')?.addEventListener('click', () => lightbox.close());
    lbImg.addEventListener('click', () => lightbox.close());
    lightbox.addEventListener('close', () => {
      lbImg.src = '';
      lbImg.alt = '';
    });
  }
</script>

<style>
  :global(.ratgeber-prose .article-inline-image) {
    margin: clamp(2rem, 4vw, 2.8rem) 0 clamp(2.3rem, 4vw, 3.1rem);
  }

  :global(.ratgeber-prose ul + .article-inline-image),
  :global(.ratgeber-prose ol + .article-inline-image) {
    margin-top: clamp(2.8rem, 5vw, 3.6rem);
  }

  :global(.ratgeber-prose h2 + .article-inline-image) {
    margin-top: 1.6rem;
  }

  :global(.ratgeber-prose .article-inline-image + h2) {
    margin-top: clamp(2.8rem, 5vw, 3.4rem);
  }

  :global(.ratgeber-prose .article-inline-image img) {
    display: block;
    margin: 0;
    cursor: zoom-in;
  }

  .lightbox {
    border: none;
    background: transparent;
    padding: 24px;
    width: 100vw;
    max-width: 100vw;
    height: 100vh;
    max-height: 100vh;
    box-sizing: border-box;
    overflow: hidden;
  }

  dialog.lightbox[open] {
    display: grid;
    place-items: center;
  }

  .lightbox::backdrop {
    background: rgba(18, 20, 16, 0.92);
    backdrop-filter: blur(6px);
  }

  .lightbox img {
    max-width: min(95vw, 1500px);
    max-height: 90vh;
    width: auto;
    height: auto;
    object-fit: contain;
    border-radius: 12px;
    box-shadow: 0 0 80px rgba(0, 0, 0, 0.5);
    cursor: zoom-out;
    margin: 0;
    padding: 0;
    border: none;
    background: transparent;
  }

  .lightbox-close {
    position: absolute;
    top: 16px;
    right: 20px;
    width: 44px;
    height: 44px;
    background: rgba(255, 255, 255, 0.12);
    border: 1px solid rgba(255, 255, 255, 0.2);
    color: #fff;
    font-size: 1.1rem;
    border-radius: 50%;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background 0.2s;
  }

  .lightbox-close:hover {
    background: rgba(255, 255, 255, 0.22);
  }
</style>
