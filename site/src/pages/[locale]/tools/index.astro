---
import ToolCard from "../../../components/ToolCard.astro";
import BaseLayout from "../../../layouts/BaseLayout.astro";
import { listRatgeberEntries } from "../../../lib/ratgeber";
import { compareToolsByNewest } from "../../../lib/toolAddedAt";
import { listDisplayTools } from "../../../lib/toolDisplay";
import { tagHref } from "../../../lib/tagRoutes";
import {
  buildBreadcrumbSchema,
  buildCollectionPageSchema,
  SITE_LANGUAGE_EN,
  SITE_URL,
} from "../../../lib/siteMeta";

export function getStaticPaths() {
  return [{ params: { locale: "en" } }];
}

const tools = [...(await listDisplayTools("en"))].sort(compareToolsByNewest("en"));

const tagFrequency = new Map<string, number>();
tools.forEach((tool) => {
  tool.tags.forEach((tag) => {
    const normalized = tag.trim().toLowerCase();
    if (!normalized) return;
    tagFrequency.set(tag, (tagFrequency.get(tag) || 0) + 1);
  });
});
const visibleTags = Array.from(tagFrequency.entries())
  .sort((a, b) => {
    if (b[1] !== a[1]) return b[1] - a[1];
    return a[0].localeCompare(b[0], "en");
  })
  .map(([tag]) => tag)
  .filter((tag) => (tagFrequency.get(tag) || 0) >= 2)
  .slice(0, 24);
const recentRatgeber = (await listRatgeberEntries("en")).slice(0, 3);

const itemListSchema = {
  "@context": "https://schema.org",
  "@type": "ItemList",
  name: "Utildesk AI Tools",
  numberOfItems: tools.length,
  itemListElement: tools.slice(0, 200).map((tool, index) => ({
    "@type": "ListItem",
    position: index + 1,
    name: tool.title,
    url: `${SITE_URL}/en/tools/${tool.slug}/`,
  })),
};
const collectionSchema = buildCollectionPageSchema({
  name: "Utildesk AI Tools",
  description: "Curated directory of AI tools, productivity apps and automation software.",
  url: `${SITE_URL}/en/tools/`,
  about: ["AI tools", "Productivity", "Automation"],
  mainEntity: itemListSchema,
  inLanguage: SITE_LANGUAGE_EN,
});
const breadcrumbSchema = buildBreadcrumbSchema([
  { name: "Directory", url: `${SITE_URL}/en/` },
  { name: "Tools", url: `${SITE_URL}/en/tools/` },
]);
---

<BaseLayout
  locale="en"
  title="AI Tools - Utildesk"
  description="Curated directory of AI tools, productivity apps and automation software."
>
  <Fragment slot="head">
    <link rel="canonical" href="https://tools.utildesk.de/en/tools/" />
    <script type="application/ld+json" set:html={JSON.stringify(collectionSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(itemListSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
  </Fragment>

  <section class="hero" style="padding: 60px 0 40px;">
    <h1 class="hero-title">AI Tools</h1>
    <p class="hero-subtitle">
      Curated directory of useful AI and productivity tools.
      Search all tools or filter by tags.
    </p>
  </section>

  {visibleTags.length > 0 && (
    <div class="tag-filter-row" id="tag-filter-row">
      <label class="tag-filter-label">Popular tags:</label>
      <div class="tag-filter-list" id="tag-filter-list">
        {visibleTags.map((tag) => (
          <a
            href={tagHref(tag, "en")}
            class="tag-filter-item"
            data-tag={tag}
          >
            {tag}
          </a>
        ))}
        <a href="/en/tools/" class="clear-filter-btn" id="clear-filter-btn" style="display: none;">
          Clear filter
        </a>
      </div>
    </div>
  )}

  <div class="search-wrapper">
    <input
      type="search"
      id="search-input"
      class="search-input"
      placeholder="Search tools..."
      autocomplete="off"
    />
    <select id="sort-select" class="search-input" aria-label="Sort order">
      <option value="az">A-Z</option>
      <option value="new" selected>Newly added</option>
      <option value="pop">Popular</option>
    </select>
  </div>

  <div class="tools-grid" id="tools-grid">
    {tools.map((tool) => (
      <ToolCard tool={tool} href={`/en/tools/${tool.slug}/`} fallbackText="Short description coming soon." />
    ))}
  </div>

  <div id="no-results" style="display: none; text-align: center; padding: 60px 0;">
    <p style="color: var(--text-muted); font-size: 1.125rem;">
      No tools found. Try a different search term or another tag.
    </p>
  </div>
  <div style="text-align: center; margin-top: 36px; padding-bottom: 48px;">
    <button type="button" id="load-more-btn" class="hero-cta">Show more</button>
    <div
      id="hidden-count-info"
      style="display: none; margin-top: 10px; text-align: center; font-size: 0.9rem; color: var(--text-muted);"
    >
      0 tools still hidden
    </div>
  </div>

  {recentRatgeber.length > 0 && (
    <section class="tools-guides">
      <div class="tools-guides-head">
        <h2>Related guides</h2>
        <a href="/en/ratgeber/" class="tools-guides-more">Open guides</a>
      </div>
      <div class="tools-guides-list">
        {recentRatgeber.map((article) => (
          <a href={`/en/ratgeber/${article.slug}/`} class="tools-guides-article">
            <strong>{article.data.title}</strong>
            <span>{article.data.excerpt || "Editorial context and tool links from the Utildesk guide section."}</span>
          </a>
        ))}
      </div>
    </section>
  )}

  <script is:inline>
    (function() {
      const sortStorageKey = 'utildesk-tools-sort-en';
      const searchInput = document.getElementById('search-input');
      const sortSelect = document.getElementById('sort-select');
      const toolsGrid = document.getElementById('tools-grid');
      const noResults = document.getElementById('no-results');
      const loadMoreBtn = document.getElementById('load-more-btn');
      const hiddenCountInfo = document.getElementById('hidden-count-info');
      const cards = Array.from(toolsGrid.querySelectorAll('.tool-card'));
      const clearFilterBtn = document.getElementById('clear-filter-btn');
      let pageBlocks = 1;

      const urlParams = new URLSearchParams(window.location.search);
      const initialTag = urlParams.get('tag');
      const initialSort = urlParams.get('sort');

      if (initialTag) {
        const tagSlug = initialTag
          .toLowerCase()
          .replace(/[^a-z0-9]+/g, '-')
          .replace(/^-+|-+$/g, '');
        window.location.replace('/en/tools/tag/' + tagSlug + '/');
        return;
      }

      if (sortSelect) {
        const validSorts = ['az', 'new', 'pop'];
        const defaultSort = 'new';
        let restoredSort = defaultSort;
        if (initialSort && validSorts.indexOf(initialSort) !== -1) {
          restoredSort = initialSort;
        } else {
          try {
            const storedSort = localStorage.getItem(sortStorageKey);
            if (storedSort && validSorts.indexOf(storedSort) !== -1) {
              restoredSort = storedSort;
            }
          } catch (e) {
            // ignore localStorage access errors
          }
        }
        sortSelect.value = restoredSort;
        const normalizedParams = new URLSearchParams(window.location.search);
        if (normalizedParams.get('sort') !== restoredSort) {
          normalizedParams.set('sort', restoredSort);
          const nextUrl = normalizedParams.toString()
            ? '/en/tools/?' + normalizedParams.toString()
            : '/en/tools/';
          history.replaceState(null, '', nextUrl);
        }
      }

      function getCols() {
        const template = window.getComputedStyle(toolsGrid).gridTemplateColumns || '';
        if (!template || template === 'none') return 1;
        const cols = template.split(' ').filter(function(part) { return part.trim().length > 0; }).length;
        return cols > 0 ? cols : 1;
      }

      function getStep() {
        return getCols() * 6;
      }

      function filterTools() {
        const query = searchInput.value.toLowerCase().trim();
        const sortMode = sortSelect ? sortSelect.value : 'az';
        const filtered = cards.filter(function(card) {
          const title = card.getAttribute('data-title') || '';
          const slug = card.getAttribute('data-slug') || '';
          const tags = card.getAttribute('data-tags') || '';

          return !query ||
            title.includes(query) ||
            slug.includes(query) ||
            tags.includes(query);
        });

        filtered.sort(function(a, b) {
          const aTitle = (a.getAttribute('data-title') || '').toLowerCase();
          const bTitle = (b.getAttribute('data-title') || '').toLowerCase();
          if (sortMode === 'new') {
            const aAdded = Number(a.getAttribute('data-added') || '0');
            const bAdded = Number(b.getAttribute('data-added') || '0');
            if (bAdded !== aAdded) return bAdded - aAdded;
            const aOrder = Number(a.getAttribute('data-added-order') || '0');
            const bOrder = Number(b.getAttribute('data-added-order') || '0');
            if (bOrder !== aOrder) return bOrder - aOrder;
            return aTitle.localeCompare(bTitle, 'en');
          }
          if (sortMode === 'pop') {
            const aPopular = Number(a.getAttribute('data-popularity') || '0');
            const bPopular = Number(b.getAttribute('data-popularity') || '0');
            if (bPopular !== aPopular) return bPopular - aPopular;
            return aTitle.localeCompare(bTitle, 'en');
          }
          return aTitle.localeCompare(bTitle, 'en');
        });

        const limit = getStep() * pageBlocks;
        const visibleCards = filtered.slice(0, limit);

        toolsGrid.innerHTML = '';
        visibleCards.forEach(function(card) {
          toolsGrid.appendChild(card);
        });

        const totalFiltered = filtered.length;
        const currentVisible = visibleCards.length;
        const hidden = totalFiltered - currentVisible;

        if (totalFiltered === 0) {
          toolsGrid.style.display = 'none';
          noResults.style.display = 'block';
        } else {
          toolsGrid.style.display = 'grid';
          noResults.style.display = 'none';
        }

        if (loadMoreBtn) {
          loadMoreBtn.style.display = totalFiltered > limit ? 'inline-flex' : 'none';
        }

        if (hiddenCountInfo) {
          if (hidden > 0) {
            hiddenCountInfo.textContent = hidden + ' tools still hidden';
            hiddenCountInfo.style.display = 'block';
          } else {
            hiddenCountInfo.style.display = 'none';
          }
        }
      }

      function resetAndFilter() {
        pageBlocks = 1;
        filterTools();
      }

      searchInput.addEventListener('input', resetAndFilter);

      if (sortSelect) {
        sortSelect.addEventListener('change', function() {
          const sortValue = sortSelect.value;
          try {
            if (sortValue && ['az', 'new', 'pop'].indexOf(sortValue) !== -1) {
              localStorage.setItem(sortStorageKey, sortValue);
            } else {
              localStorage.removeItem(sortStorageKey);
            }
          } catch (e) {
            // ignore localStorage access errors
          }
          const params = new URLSearchParams(window.location.search);
          params.set('sort', sortValue);
          const nextUrl = params.toString() ? '/en/tools/?' + params.toString() : '/en/tools/';
          history.pushState(null, '', nextUrl);
          resetAndFilter();
        });
      }

      if (clearFilterBtn) {
        clearFilterBtn.addEventListener('click', function(e) {
          e.preventDefault();
          window.location.href = '/en/tools/';
        });
      }

      if (loadMoreBtn) {
        loadMoreBtn.addEventListener('click', function() {
          pageBlocks += 1;
          filterTools();
        });
      }

      window.addEventListener('resize', filterTools);
      filterTools();
    })();
  </script>
</BaseLayout>

<style>
  .tools-guides {
    margin: 24px 0 56px;
    padding-top: 20px;
    border-top: 1px solid rgba(23, 98, 89, 0.12);
  }

  .tools-guides-head {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 16px;
    margin-bottom: 16px;
  }

  .tools-guides-head h2 {
    margin: 0;
    font-size: 1.18rem;
    font-weight: 800;
    color: var(--on-surface);
  }

  .tools-guides-more {
    font-size: 0.92rem;
    font-weight: 700;
    text-decoration: none;
    color: var(--primary);
  }

  .tools-guides-list {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 12px;
  }

  .tools-guides-article {
    display: grid;
    gap: 6px;
    padding: 14px 16px;
    text-decoration: none;
    color: inherit;
    border-radius: 18px;
    background: rgba(255, 255, 255, 0.82);
    border: 1px solid rgba(23, 98, 89, 0.10);
    transition: transform var(--transition), border-color var(--transition), box-shadow var(--transition);
  }

  .tools-guides-article:hover {
    transform: translateY(-2px);
    border-color: rgba(23, 98, 89, 0.18);
    box-shadow: 0 12px 28px rgba(18, 28, 24, 0.06);
  }

  .tools-guides-article strong {
    font-size: 0.96rem;
    line-height: 1.35;
    color: var(--primary);
  }

  .tools-guides-article span {
    font-size: 0.9rem;
    line-height: 1.55;
    color: var(--secondary);
  }

  :global([data-theme="dark"]) .tools-guides {
    border-top-color: rgba(142, 216, 201, 0.16);
  }

  :global([data-theme="dark"]) .tools-guides-head h2 {
    color: rgba(246, 252, 249, 0.96);
  }

  :global([data-theme="dark"]) .tools-guides-more {
    color: #8ed8c9;
  }

  :global([data-theme="dark"]) .tools-guides-article {
    background: rgba(22, 41, 36, 0.88);
    border-color: rgba(142, 216, 201, 0.18);
  }

  :global([data-theme="dark"]) .tools-guides-article:hover {
    border-color: rgba(142, 216, 201, 0.34);
    box-shadow: 0 14px 30px rgba(0, 0, 0, 0.22);
  }

  :global([data-theme="dark"]) .tools-guides-article strong {
    color: #b8f3e7;
  }

  :global([data-theme="dark"]) .tools-guides-article span {
    color: rgba(226, 238, 233, 0.72);
  }

  @media (max-width: 920px) {
    .tools-guides-list {
      grid-template-columns: 1fr;
    }
  }
</style>
