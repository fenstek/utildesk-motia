---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import { CATEGORIES } from "../../../lib/categories";
import { getDecisionIssueNumber } from "../../../lib/contentIssue";
import { categoryDescriptionEn, categoryTitleEn } from "../../../lib/englishContent";
import { listDisplayTools } from "../../../lib/toolDisplay";
import {
  buildBreadcrumbSchema,
  buildCollectionPageSchema,
  SITE_LANGUAGE_EN,
  SITE_URL,
} from "../../../lib/siteMeta";

export function getStaticPaths() {
  return [{ params: { locale: "en" } }];
}

const tools = await listDisplayTools("en");
const issueNo = getDecisionIssueNumber();
const categories = CATEGORIES.map((category) => {
  const count = tools.filter((tool) =>
    tool.rawTags.map((tag) => tag.toLowerCase()).some((tag) => category.matchTags.includes(tag))
  ).length;
  return {
    ...category,
    titleEn: categoryTitleEn(category.slug, category.title),
    descriptionEn: categoryDescriptionEn(category.slug, category.description),
    count,
  };
});
const populatedCount = categories.filter((category) => category.count > 0).length;
const largestCategory = [...categories].sort((a, b) => b.count - a.count)[0];

const itemListSchema = {
  "@context": "https://schema.org",
  "@type": "ItemList",
  name: "Utildesk AI Tool Categories",
  numberOfItems: categories.length,
  itemListElement: categories.map((category, index) => ({
    "@type": "ListItem",
    position: index + 1,
    name: category.titleEn,
    url: `${SITE_URL}/en/category/${category.slug}/`,
  })),
};
const collectionSchema = buildCollectionPageSchema({
  name: "AI Tool Categories",
  description: "Explore AI tools by category.",
  url: `${SITE_URL}/en/category/`,
  about: ["AI tools", "Categories", "Productivity"],
  mainEntity: itemListSchema,
  inLanguage: SITE_LANGUAGE_EN,
});
const breadcrumbSchema = buildBreadcrumbSchema([
  { name: "Directory", url: `${SITE_URL}/en/` },
  { name: "Categories", url: `${SITE_URL}/en/category/` },
]);
---

<BaseLayout locale="en" title="AI Tool Categories - Utildesk" description="Explore AI tools by category.">
  <Fragment slot="head">
    <link rel="canonical" href="https://tools.utildesk.de/en/category/" />
    <script type="application/ld+json" set:html={JSON.stringify(collectionSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(itemListSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
  </Fragment>

  <div class="tool-akte inv-wrap category-archive">
    <nav class="akte-crumb" aria-label="Breadcrumb">
      <a href="/en/">Back to directory</a>
      <span class="akte-crumb-sep">/</span>
      <span class="akte-crumb-current">Categories</span>
    </nav>

    <header class="inv-head">
      <div class="inv-head-body">
        <div class="inv-head-kicker">Inventory / Categories / Issue No. {issueNo}</div>
        <h1 class="inv-head-h1">Categories<span class="akte-mast-dot">.</span></h1>
        <p class="inv-head-deck">
          Start with the job to be done, not the vendor pitch:
          writing, automation, development, marketing, media production and support workflows.
        </p>
      </div>
      <div class="inv-head-stats" role="group" aria-label="Category metrics">
        <div class="inv-stat"><strong>{categories.length}</strong><span>Categories</span></div>
        <div class="inv-stat"><strong>{tools.length.toLocaleString("en-US")}</strong><span>Indexed tools</span></div>
        <div class="inv-stat"><strong>{populatedCount}</strong><span>Filled</span></div>
        <div class="inv-stat inv-stat-paid"><strong>{largestCategory?.count ?? 0}</strong><span>Largest category</span></div>
      </div>
    </header>
  </div>

  <section class="tool-akte category-ledger akte-alts" aria-label="Tool categories">
    <div class="akte-alts-head">
      <div class="akte-alts-head-left">
        <div class="akte-alts-kicker">Category files</div>
        <h2 class="akte-alts-title">Sorted by workflow intent<span class="akte-mast-dot">.</span></h2>
      </div>
      <a class="akte-alts-all" href="/en/tools/">All tools</a>
    </div>
    <div class="akte-alts-grid">
      {categories.map((category, index) => (
        <a href={`/en/category/${category.slug}/`} class="akte-alt-card category-akte-card">
          <div class="akte-alt-card-head">
            <span class="akte-alt-card-kicker">Category {String(index + 1).padStart(2, "0")}</span>
            <span class="akte-alt-card-mono" aria-hidden="true">{category.count}</span>
          </div>
          <div class="akte-alt-card-name">{category.titleEn}<span class="akte-mast-dot">.</span></div>
          <p class="akte-alt-card-tone">{category.descriptionEn}</p>
          <div class="akte-alt-card-foot">
            <span class="akte-alt-card-meta">{category.count} {category.count === 1 ? "tool" : "tools"}</span>
            <span class="akte-alt-card-open">Open</span>
          </div>
        </a>
      ))}
    </div>
  </section>
</BaseLayout>
