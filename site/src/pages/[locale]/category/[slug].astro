---
import InventoryToolRow from "../../../components/InventoryToolRow.astro";
import BaseLayout from "../../../layouts/BaseLayout.astro";
import { CATEGORIES } from "../../../lib/categories";
import { categoryDescriptionEn, categoryTitleEn } from "../../../lib/englishContent";
import { listDisplayTools } from "../../../lib/toolDisplay";
import { selectSearchFocusTools } from "../../../lib/searchFocus.mjs";
import {
  buildBreadcrumbSchema,
  buildCollectionPageSchema,
  SITE_LANGUAGE_EN,
  SITE_URL,
} from "../../../lib/siteMeta";

export async function getStaticPaths() {
  return CATEGORIES.map((category) => ({
    params: { locale: "en", slug: category.slug },
    props: { category },
  }));
}

const { slug } = Astro.params;
const category = Astro.props.category ?? CATEGORIES.find((cat) => cat.slug === slug);

if (!category) {
  return Astro.redirect("/404");
}

const title = categoryTitleEn(category.slug, category.title);
const description = categoryDescriptionEn(category.slug, category.description);
const tools = [...(await listDisplayTools("en"))]
  .filter((tool) => tool.rawTags.map((tag) => tag.toLowerCase()).some((tag) => category.matchTags.includes(tag)))
  .sort((a, b) => a.title.localeCompare(b.title, "en"));
const toolCount = tools.length;
const visibleTools = selectSearchFocusTools(tools, 24);
const seoSections = [
  {
    title: `How to compare ${title} tools`,
    text: "Start with the task you need to solve, then compare pricing, data handling, integrations, export options and how quickly the tool fits into your existing workflow.",
  },
  {
    title: "What Utildesk checks",
    text: "Utildesk keeps the catalogue focused on real use cases: what the tool does, who it is useful for, and whether the surrounding metadata is clear enough for people and AI agents.",
  },
];

const itemListSchema = {
  "@context": "https://schema.org",
  "@type": "ItemList",
  name: title,
  url: `${SITE_URL}/en/category/${category.slug}/`,
  numberOfItems: toolCount,
  itemListElement: visibleTools.map((tool, index) => ({
    "@type": "ListItem",
    position: index + 1,
    name: tool.title,
    url: `${SITE_URL}/en/tools/${tool.slug}/`,
  })),
};
const collectionSchema = buildCollectionPageSchema({
  name: `${title} AI tools`,
  description,
  url: `${SITE_URL}/en/category/${category.slug}/`,
  about: [title, "AI tools", "Category"],
  mainEntity: itemListSchema,
  inLanguage: SITE_LANGUAGE_EN,
});
const breadcrumbSchema = buildBreadcrumbSchema([
  { name: "Directory", url: `${SITE_URL}/en/` },
  { name: "Categories", url: `${SITE_URL}/en/category/` },
  { name: title, url: `${SITE_URL}/en/category/${category.slug}/` },
]);
---

<BaseLayout
  locale="en"
  title={`${title} - Utildesk`}
  description={description}
>
  <Fragment slot="head">
    <link rel="canonical" href={`https://tools.utildesk.de/en/category/${category.slug}/`} />
    <script type="application/ld+json" set:html={JSON.stringify(collectionSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(itemListSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
  </Fragment>

  <article class="tool-akte sheet-wrap category-detail">
    <nav class="akte-crumb" aria-label="Breadcrumb">
      <a href="/en/category/">Back to all categories</a>
      <span class="akte-crumb-sep">/</span>
      <span class="akte-crumb-current">{title}</span>
    </nav>

    <header class="sheet-head">
      <div class="sheet-head-kicker">Category file / Tool selection</div>
      <h1 class="sheet-head-h1">{title}<span class="akte-mast-dot">.</span></h1>
      <p class="sheet-head-dek">{description}</p>
      <div class="sheet-head-meta">
        <span><strong>{toolCount}</strong> {toolCount === 1 ? "tool" : "tools"}</span>
        <span>·</span>
        <span>Source: Utildesk inventory</span>
      </div>
    </header>

    <section class="akte-article category-context">
      <div class="akte-article-body">
        <div>
          <p>{description}</p>
          <p>Use this category as a practical starting point when you want to compare tools by workflow fit instead of vendor language.</p>
          {seoSections.map((section) => (
            <>
              <h2>{section.title}</h2>
              <p>{section.text}</p>
            </>
          ))}
        </div>
      </div>
    </section>

    {toolCount < 5 && (
      <div class="akte-colophon category-note">
        <span><span class="akte-colophon-key">Status:</span> This category is still being filled.</span>
      </div>
    )}
  </article>

  <div class="tool-akte inv-list-wrap category-tools-wrap">
    <aside class="inv-filter-rail" aria-label="Category status">
      <div class="inv-filter-kicker">Selection</div>
      <h2>Matching<br />files.</h2>
      <div class="inv-filter-group">
        <h3>Category</h3>
        <p><span class="inv-filter-box inv-filter-box-fill" aria-hidden="true"></span><span>{title}</span><em>{toolCount}</em></p>
        <p><span class="inv-filter-box" aria-hidden="true"></span><span>Paid slots</span><em>0</em></p>
      </div>
      <div class="inv-filter-group">
        <h3>Navigation</h3>
        <p><span class="inv-filter-box" aria-hidden="true"></span><span><a href="/en/tools/">All tools</a></span><em>↗</em></p>
        <p><span class="inv-filter-box" aria-hidden="true"></span><span><a href="/en/category/">All categories</a></span><em>↗</em></p>
      </div>
    </aside>

    <div class="tools-grid inv-register inv-view-register" id="tools-grid">
      {visibleTools.map((tool, index) => (
        <InventoryToolRow tool={tool} href={`/en/tools/${tool.slug}/`} index={index} locale="en" />
      ))}
    </div>
  </div>
  {toolCount > visibleTools.length && (
    <div class="tool-akte inv-loadmore category-loadmore">
      <a class="akte-action akte-action-ghost" href={`/en/tools/?category=${encodeURIComponent(title.toLowerCase())}`}>
        Show all {toolCount} tools in the inventory
      </a>
      <div class="inv-hidden-count">Starting with {visibleTools.length} editorially prioritised files</div>
    </div>
  )}
</BaseLayout>
