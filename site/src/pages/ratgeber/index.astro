---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { listRatgeberEntries } from "../../lib/ratgeber";

const articles = await listRatgeberEntries();
const featuredArticle = articles[0] ?? null;

const itemListSchema = {
  "@context": "https://schema.org",
  "@type": "ItemList",
  "name": "Ratgeber",
  "url": "https://tools.utildesk.de/ratgeber/",
  "numberOfItems": articles.length,
  "itemListElement": articles.map((article, index) => ({
    "@type": "ListItem",
    "position": index + 1,
    "name": article.data.title,
    "url": `https://tools.utildesk.de/ratgeber/${article.slug}/`,
  })),
};
---

<BaseLayout
  title="Ratgeber - Utildesk"
  description="Chronologische Ratgeber, Vergleiche und Leitfaeden zu AI-Tools, Automatisierung und Produktivitaet."
>
  <Fragment slot="head">
    <link rel="canonical" href="https://tools.utildesk.de/ratgeber/" />
    <script type="application/ld+json" set:html={JSON.stringify(itemListSchema)} />
  </Fragment>

  <section class="ratgeber-hero card">
    <div class="ratgeber-hero-copy">
      <p class="ratgeber-eyebrow">Ratgeber</p>
      <h1 class="ratgeber-title">Vergleiche, Leitfaeden und redaktionelle Artikel zu den wichtigsten AI-Tools</h1>
      <p class="ratgeber-intro">
        Hier sammeln wir chronologisch sortierte Artikel mit klarer Einordnung, passenden Tool-Links und einem ruhigen Leselayout.
        Der erste Beitrag vergleicht die drei grossen Assistenten ChatGPT, Claude und Gemini.
      </p>
      <div class="ratgeber-hero-actions">
        <a href="#artikel" class="hero-cta">Zu den Artikeln</a>
        <a href="/tools/" class="hero-secondary">Zum Tool-Katalog</a>
      </div>
    </div>

    <aside class="ratgeber-hero-aside card">
      <p class="aside-label">Aktuell</p>
      <p class="aside-value">{articles.length} Artikel</p>
      <p class="aside-note">Neue Beitraege erscheinen oben in der Liste.</p>
      <div class="aside-divider"></div>
      <ul class="aside-points">
        <li>Vergleiche mit klaren Empfehlungen</li>
        <li>Interne Links zu den passenden Tools</li>
        <li>Illustrationen im Stil des Hauptdesigns</li>
      </ul>
    </aside>
  </section>

  {featuredArticle ? (
    <section class="featured-section card">
      <div class="featured-media">
        {featuredArticle.data.coverImage ? <img src={featuredArticle.data.coverImage} alt={featuredArticle.data.title} loading="eager" /> : null}
      </div>
      <div class="featured-copy">
        <p class="featured-label">Featured Article</p>
        <h2><a href={`/ratgeber/${featuredArticle.slug}/`}>{featuredArticle.data.title}</a></h2>
        <p>{featuredArticle.data.excerpt}</p>
        <div class="featured-meta">
          {featuredArticle.data.date ? <span>{new Intl.DateTimeFormat("de-DE", { day: "2-digit", month: "long", year: "numeric" }).format(new Date(featuredArticle.data.date))}</span> : null}
          {featuredArticle.data.readTime ? <span>Lesedauer ca. {featuredArticle.data.readTime} Min.</span> : null}
          {featuredArticle.data.category ? <span>{featuredArticle.data.category}</span> : null}
        </div>
        <a href={`/ratgeber/${featuredArticle.slug}/`} class="featured-link">Artikel lesen</a>
      </div>
    </section>
  ) : null}

  <section class="ratgeber-list-section" id="artikel">
    <div class="section-heading">
      <h2>Chronologische Vorschau</h2>
      <p>Die Reihenfolge ist nach Veroeffentlichungsdatum sortiert.</p>
    </div>

    {articles.length > 0 ? (
      <div class="ratgeber-list">
        {articles.map((article) => {
          const published = article.data.date ? new Intl.DateTimeFormat("de-DE", {
            day: "2-digit",
            month: "long",
            year: "numeric",
          }).format(new Date(article.data.date)) : "";

          return (
            <a href={`/ratgeber/${article.slug}/`} class="ratgeber-card card">
              <div class="ratgeber-card-content">
                <div class="ratgeber-card-topline">
                  <span class="ratgeber-pill">{article.data.eyebrow || "Ratgeber"}</span>
                  {article.data.category ? <span class="ratgeber-pill ratgeber-pill-secondary">{article.data.category}</span> : null}
                </div>
                <h3>{article.data.title}</h3>
                <p>{article.data.excerpt}</p>
                <div class="ratgeber-card-meta">
                  <span>{published}</span>
                  {article.data.readTime ? <span>Lesedauer ca. {article.data.readTime} Min.</span> : null}
                </div>
                {article.data.tags?.length ? (
                  <div class="ratgeber-card-tags">
                    {article.data.tags.slice(0, 4).map((tag) => <span>{tag}</span>)}
                  </div>
                ) : null}
              </div>
              <div class="ratgeber-card-media">
                {article.data.coverImage ? <img src={article.data.coverImage} alt={article.data.title} loading="lazy" /> : null}
              </div>
            </a>
          );
        })}
      </div>
    ) : (
      <div class="empty-state card">
        <h3>Noch keine Artikel veroeffentlicht</h3>
        <p>Sobald der erste Ratgeber live ist, erscheint er hier in chronologischer Reihenfolge.</p>
      </div>
    )}
  </section>
</BaseLayout>

<style>
  .ratgeber-hero {
    display: grid;
    grid-template-columns: minmax(0, 1fr) 320px;
    gap: var(--space-6);
    padding: var(--space-7);
    margin-top: var(--space-6);
    align-items: start;
  }

  .ratgeber-eyebrow {
    margin: 0 0 12px;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    font-size: 0.75rem;
    color: var(--primary);
    font-weight: 800;
  }

  .ratgeber-title {
    font-size: clamp(2rem, 4vw, 3.2rem);
    line-height: 1.06;
    margin: 0 0 var(--space-4);
    max-width: 15ch;
  }

  .ratgeber-intro {
    margin: 0;
    max-width: 70ch;
    color: var(--secondary);
    font-size: 1.05rem;
  }

  .ratgeber-hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    margin-top: var(--space-5);
  }

  .hero-cta,
  .hero-secondary,
  .featured-link {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 13px 20px;
    border-radius: var(--radius-full);
    font-weight: 700;
    font-family: 'Plus Jakarta Sans', sans-serif;
  }

  .hero-cta {
    background: var(--primary);
    color: var(--on-primary);
  }

  .hero-secondary {
    background: var(--surface-container-low);
    color: var(--on-surface);
  }

  .ratgeber-hero-aside {
    padding: var(--space-5);
    background: var(--surface-container-lowest);
    box-shadow: var(--shadow-card);
  }

  .aside-label,
  .featured-label {
    margin: 0 0 10px;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--secondary);
    font-size: 0.74rem;
    font-weight: 800;
  }

  .aside-value {
    margin: 0 0 10px;
    font-size: 2rem;
    font-weight: 800;
    color: var(--on-surface);
  }

  .aside-note {
    margin: 0;
    color: var(--secondary);
  }

  .aside-divider {
    height: 1px;
    background: var(--outline-variant);
    opacity: 0.42;
    margin: var(--space-5) 0;
  }

  .aside-points {
    margin: 0;
    padding-left: 1.1rem;
    color: var(--secondary);
  }

  .aside-points li + li {
    margin-top: 10px;
  }

  .featured-section {
    display: grid;
    grid-template-columns: minmax(0, 1.05fr) minmax(0, 0.95fr);
    gap: 0;
    margin-top: var(--space-6);
    overflow: hidden;
  }

  .featured-media {
    min-height: 100%;
    background: var(--surface-container-low);
  }

  .featured-media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .featured-copy {
    padding: var(--space-6);
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 14px;
  }

  .featured-copy h2 {
    margin: 0;
    font-size: clamp(1.7rem, 2.8vw, 2.4rem);
    line-height: 1.08;
  }

  .featured-copy p {
    margin: 0;
    color: var(--secondary);
    font-size: 1rem;
  }

  .featured-meta,
  .ratgeber-card-topline,
  .ratgeber-card-meta,
  .ratgeber-card-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }

  .featured-meta span,
  .ratgeber-card-meta span,
  .ratgeber-card-tags span {
    display: inline-flex;
    align-items: center;
    padding: 6px 12px;
    border-radius: var(--radius-full);
    background: var(--surface-container-low);
    color: var(--on-surface-variant);
    font-size: 0.78rem;
    font-weight: 700;
  }

  .featured-link {
    align-self: flex-start;
    background: var(--primary);
    color: var(--on-primary);
  }

  .ratgeber-list-section {
    padding: var(--space-8) 0;
  }

  .section-heading {
    display: flex;
    flex-direction: column;
    gap: 8px;
    margin-bottom: var(--space-6);
  }

  .section-heading h2 {
    margin: 0;
    font-size: clamp(1.6rem, 2.8vw, 2.2rem);
  }

  .section-heading p {
    margin: 0;
    color: var(--secondary);
  }

  .ratgeber-list {
    display: grid;
    gap: var(--space-5);
  }

  .ratgeber-card {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(220px, 300px);
    gap: 0;
    overflow: hidden;
    text-decoration: none;
    color: inherit;
  }

  .ratgeber-card:hover {
    color: inherit;
  }

  .ratgeber-card-content {
    padding: var(--space-6);
    display: flex;
    flex-direction: column;
    gap: 14px;
  }

  .ratgeber-card h3 {
    margin: 0;
    font-size: clamp(1.4rem, 2vw, 1.8rem);
    line-height: 1.12;
  }

  .ratgeber-card p {
    margin: 0;
    color: var(--secondary);
  }

  .ratgeber-pill {
    display: inline-flex;
    align-items: center;
    padding: 6px 12px;
    border-radius: var(--radius-full);
    background: var(--primary);
    color: var(--on-primary);
    font-size: 0.72rem;
    font-weight: 800;
  }

  .ratgeber-pill-secondary {
    background: var(--surface-container-low);
    color: var(--on-surface-variant);
  }

  .ratgeber-card-media {
    min-height: 100%;
    background: var(--surface-container-low);
  }

  .ratgeber-card-media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .empty-state {
    padding: var(--space-6);
  }

  .empty-state h3 {
    margin: 0 0 8px;
  }

  .empty-state p {
    margin: 0;
    color: var(--secondary);
  }

  @media (max-width: 920px) {
    .ratgeber-hero,
    .featured-section,
    .ratgeber-card {
      grid-template-columns: 1fr;
    }

    .ratgeber-card-media {
      aspect-ratio: 16 / 9;
      order: -1;
    }
  }
</style>
