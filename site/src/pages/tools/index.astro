---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { tagHref } from "../../lib/tagRoutes";
import { listRatgeberEntries } from "../../lib/ratgeber";
import { compareToolsByNewest } from "../../lib/toolAddedAt";
import { listDisplayTools } from "../../lib/toolDisplay";
import {
  buildBreadcrumbSchema,
  buildCollectionPageSchema,
  SITE_URL,
} from "../../lib/siteMeta";

const enabledTools = [...(await listDisplayTools("de"))].sort(compareToolsByNewest("de"));

// Build tag frequency map and keep only the most useful tags
const tagFrequency = new Map<string, number>();
enabledTools.forEach((tool) => {
  tool.tags.forEach((tag) => {
    const normalized = tag.trim().toLowerCase();
    if (!normalized) return;
    tagFrequency.set(tag, (tagFrequency.get(tag) || 0) + 1);
  });
});
const sortedTags = Array.from(tagFrequency.entries())
  .sort((a, b) => {
    if (b[1] !== a[1]) return b[1] - a[1];
    return a[0].localeCompare(b[0], "de");
  })
  .map(([tag]) => tag);
const visibleTags = sortedTags.filter((tag) => (tagFrequency.get(tag) || 0) >= 2).slice(0, 24);
const recentRatgeber = (await listRatgeberEntries()).slice(0, 3);
const toolsItemListSchema = {
  "@context": "https://schema.org",
  "@type": "ItemList",
  name: "Utildesk Tools",
  numberOfItems: enabledTools.length,
  itemListElement: enabledTools.slice(0, 200).map((tool, index) => ({
    "@type": "ListItem",
    position: index + 1,
    name: tool.title,
    url: `${SITE_URL}/tools/${tool.slug}/`,
  })),
};
const toolsCollectionSchema = buildCollectionPageSchema({
  name: "Utildesk Tools",
  description: "Indizierter Tool-Katalog aus oeffentlichen Quellen mit redaktionellen Ratgebern als Kontext.",
  url: `${SITE_URL}/tools/`,
  about: ["AI-Tools", "Produktivitaet", "Automatisierung"],
  mainEntity: toolsItemListSchema,
});
const toolsBreadcrumbSchema = buildBreadcrumbSchema([
  { name: "Startseite", url: `${SITE_URL}/` },
  { name: "Tools", url: `${SITE_URL}/tools/` },
]);

const shortCategory = (category: string | null) => {
  if (!category) return "AI";
  const value = String(category);
  const normalized = value.toLowerCase();
  if (normalized.includes("entwickler")) return "Entwickler";
  if (normalized.includes("automatis")) return "Automation";
  if (normalized.includes("schreiben")) return "Schreiben";
  if (normalized.includes("design")) return "Design";
  if (normalized.includes("chatbot")) return "AI";
  if (normalized.includes("audio")) return "Audio";
  if (normalized.includes("produkt")) return "Produktivitaet";
  if (normalized.includes("marketing")) return "Marketing";
  return value;
};
const verdictFor = (tool, index: number) => {
  const haystack = `${tool.title} ${(tool.tags || []).join(" ")} ${tool.excerpt || ""}`.toLowerCase();
  if (haystack.includes("detector") || haystack.includes("autogpt") || haystack.includes("autonomous")) {
    return index % 2 === 0
      ? { kind: "caution", icon: "!", label: "Mit Vorbehalt" }
      : { kind: "overrated", icon: "x", label: "Ueberbewertet" };
  }
  if (haystack.includes("privacy") || haystack.includes("research") || haystack.includes("search") || haystack.includes("perplexity")) {
    return { kind: "caution", icon: "!", label: "Mit Vorbehalt" };
  }
  return { kind: "recommend", icon: "ok", label: "Empfehlen" };
};
const jumpLetters = "ABCDEFGHIJKLMNOPQRSTUVWXYZ#".split("");
const activeLetters = new Set(enabledTools.map((tool) => String(tool.title || "#").trim().charAt(0).toUpperCase()).filter(Boolean));

---

<BaseLayout
  title="Tools - Utildesk"
  description="Indizierter Tool-Katalog aus oeffentlichen Quellen mit redaktionellen Ratgebern als Kontext"
>
  <Fragment slot="head">
    <link rel="canonical" href="https://tools.utildesk.de/tools/" />
    <script type="application/ld+json" set:html={JSON.stringify(toolsCollectionSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(toolsItemListSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(toolsBreadcrumbSchema)} />
  </Fragment>

  <section class="ds-inventory-page" aria-labelledby="tools-inventory-title">
    <nav class="ds-inv-crumb" aria-label="Breadcrumb">
      <a href="/">&lt;- Uebersicht</a>
      <span>/</span>
      <strong>Inventar - alle Akten</strong>
    </nav>

    <header class="ds-inv-head">
      <div>
        <p class="ds-kicker">-&gt; Inventar - Tool-Index - Ausgabe 049</p>
        <h1 id="tools-inventory-title">{enabledTools.length} Akten<span>.</span></h1>
        <p>Jede Akte einzeln gelesen, mit einem Verdikt versehen und in eine Kategorie einsortiert. Keine bezahlten Platzierungen. Sortierung aendert die Reihenfolge - nie die Empfehlung.</p>
      </div>
      <div class="ds-inv-stats" aria-label="Inventar Statistik">
        <div><strong>{enabledTools.length}</strong><span>Akten gesamt</span></div>
        <div><strong>{enabledTools.filter((tool) => verdictFor(tool, 0).kind === "recommend").length}</strong><span>Empfohlen</span></div>
        <div><strong>0</strong><span>Bezahlte Plaetze</span></div>
      </div>
    </header>

    <div class="ds-inv-controls">
      <label class="ds-inv-search">
        <span>Suche</span>
        <input type="search" id="search-input" class="search-input" placeholder="Tool suchen..." autocomplete="off" />
      </label>
      <label class="ds-inv-sort">
        <span>Sortierung</span>
        <select id="sort-select" class="search-input" aria-label="Sortierung">
          <option value="az">A-Z</option>
          <option value="new" selected>Zuletzt geprueft</option>
          <option value="pop">Beliebt</option>
        </select>
      </label>
      <div class="ds-inv-count">Anzeige <span aria-hidden="true">&#8627;</span> <span id="hidden-count-info">erste Auswahl</span></div>
    </div>

    <div class="ds-inv-jump" aria-label="Sprungmarken">
      <span>Sprungmarken</span>
      <div>
        {jumpLetters.map((letter) => (
          <a href={`#letter-${letter}`} class={activeLetters.has(letter) ? "is-active" : undefined}>{letter}</a>
        ))}
      </div>
    </div>

    <div class="ds-inv-layout">
      <aside class="ds-inv-filter" aria-label="Filter">
        <p>-&gt; Filter</p>
        <strong>Auswahl<br />einschraenken.</strong>
        <div>
          <h2>Top Tags</h2>
          {visibleTags.slice(0, 12).map((tag) => (
            <a href={tagHref(tag)}>#{tag}<span>{tagFrequency.get(tag) || 0}</span></a>
          ))}
        </div>
      </aside>

      <div class="ds-index-table ds-inv-register" role="table" aria-label="Utildesk Tool-Inventar">
        <div class="ds-index-table-head" role="row">
          <span>Nr.</span>
          <span>Tool - Einordnung</span>
          <span>Verdikt</span>
          <span>Tags</span>
          <span>Kategorie</span>
          <span>Preis</span>
          <span>Open</span>
        </div>
        <div class="ds-index-table-body" id="tools-grid">
          {enabledTools.map((tool, index) => {
            const verdict = verdictFor(tool, index);
            const tagsForRow = tool.tags.filter((tag) => tag.toLowerCase() !== "ai").slice(0, 3);
            return (
              <a href={`/tools/${tool.slug}/`} class="ds-index-row tool-card" data-title={tool.title.toLowerCase()} data-slug={tool.slug.toLowerCase()} data-tags={tool.tags.map((tag) => tag.toLowerCase()).join(",")} data-added={tool.addedAtMs} data-added-order={tool.addedAtOrderMs} data-popularity={tool.popularity} role="row">
                <span class="ds-index-no">{String(index + 1).padStart(2, "0")}</span>
                <span class="ds-index-tool">
                  <span class="ds-index-logo" aria-hidden="true">
                    {tool.iconUrl ? <img src={tool.iconUrl} alt="" loading="lazy" data-fallback-srcs={tool.iconFallbacks.length ? JSON.stringify(tool.iconFallbacks) : undefined} /> : <span>{tool.title.slice(0, 1)}</span>}
                  </span>
                  <span>
                    <strong>{tool.title}</strong>
                    {tool.providerHost ? <small>{tool.providerHost}</small> : null}
                    <em>{tool.excerpt || "Kompakte Tool-Akte aus oeffentlichen Quellen und redaktioneller Einordnung."}</em>
                  </span>
                </span>
                <span class={`ds-index-verdict ds-index-verdict-${verdict.kind}`}><b>{verdict.icon}</b><span>{verdict.label}</span></span>
                <span class="ds-index-tags">{tagsForRow.map((tag) => <span>#{tag}</span>)}</span>
                <span class="ds-index-category">{shortCategory(tool.category)}</span>
                <span class="ds-index-price">{tool.price_model || "n/a"}</span>
                <span class="ds-index-open" aria-hidden="true">-&gt;</span>
              </a>
            );
          })}
        </div>
      </div>
    </div>

    <div id="no-results" class="ds-inv-empty" style="display: none;">Keine Tools gefunden. Versuche einen anderen Suchbegriff.</div>
    <div class="ds-inv-more"><button type="button" id="load-more-btn" class="hero-cta">Mehr anzeigen</button></div>
  </section>

  <!-- Client-side search + tag filter script (inline, no build tools) -->
  <script is:inline>
    (function() {
      const sortStorageKey = 'utildesk-tools-sort';
      const searchInput = document.getElementById('search-input');
      const sortSelect = document.getElementById('sort-select');
      const toolsGrid = document.getElementById('tools-grid');
      const noResults = document.getElementById('no-results');
      const loadMoreBtn = document.getElementById('load-more-btn');
      const hiddenCountInfo = document.getElementById('hidden-count-info');
      const cards = Array.from(toolsGrid.querySelectorAll('.tool-card'));
      const clearFilterBtn = document.getElementById('clear-filter-btn');
      let pageBlocks = 1;

      // Read URL params tag= and sort=
      const urlParams = new URLSearchParams(window.location.search);
      const initialTag = urlParams.get('tag');
      const initialSort = urlParams.get('sort');

      if (initialTag) {
        const tagSlug = initialTag
          .toLowerCase()
          .replace(/[^a-z0-9]+/g, '-')
          .replace(/^-+|-+$/g, '');
        window.location.replace('/tools/tag/' + tagSlug + '/');
        return;
      }

      // Restore sort preference from URL first, then localStorage.
      if (sortSelect) {
        const validSorts = ['az', 'new', 'pop'];
        const defaultSort = 'new';
        let restoredSort = defaultSort;
        if (initialSort && validSorts.indexOf(initialSort) !== -1) {
          restoredSort = initialSort;
        } else {
          try {
            const storedSort = localStorage.getItem(sortStorageKey);
            if (storedSort && validSorts.indexOf(storedSort) !== -1) {
              restoredSort = storedSort;
            }
          } catch (e) {
            // ignore localStorage access errors
          }
        }
        sortSelect.value = restoredSort;
        const normalizedParams = new URLSearchParams(window.location.search);
        if (normalizedParams.get('sort') !== restoredSort) {
          normalizedParams.set('sort', restoredSort);
          const nextUrl = normalizedParams.toString()
            ? '/tools/?' + normalizedParams.toString()
            : '/tools/';
          history.replaceState(null, '', nextUrl);
        }
      }

      function getCols() {
        const template = window.getComputedStyle(toolsGrid).gridTemplateColumns || '';
        if (!template || template === 'none') return 1;
        const cols = template.split(' ').filter(function(part) { return part.trim().length > 0; }).length;
        return cols > 0 ? cols : 1;
      }

      function getStep() {
        return getCols() * 6;
      }

      // Filter + sort + pagination
      function filterTools() {
        const query = searchInput.value.toLowerCase().trim();
        const sortMode = sortSelect ? sortSelect.value : 'az';
        const filtered = cards.filter(function(card) {
          const title = card.getAttribute('data-title') || '';
          const slug = card.getAttribute('data-slug') || '';
          const tags = card.getAttribute('data-tags') || '';
          const tagList = tags.split(',').map(function(t) { return t.trim().toLowerCase(); });

          // Check search query match
          const searchMatch = !query ||
                             title.includes(query) ||
                             slug.includes(query) ||
                             tags.includes(query);

          return searchMatch;
        });

        filtered.sort(function(a, b) {
          const aTitle = (a.getAttribute('data-title') || '').toLowerCase();
          const bTitle = (b.getAttribute('data-title') || '').toLowerCase();
          if (sortMode === 'new') {
            const aAdded = Number(a.getAttribute('data-added') || '0');
            const bAdded = Number(b.getAttribute('data-added') || '0');
            if (bAdded !== aAdded) return bAdded - aAdded;
            const aOrder = Number(a.getAttribute('data-added-order') || '0');
            const bOrder = Number(b.getAttribute('data-added-order') || '0');
            if (bOrder !== aOrder) return bOrder - aOrder;
            return aTitle.localeCompare(bTitle, 'de');
          }
          if (sortMode === 'pop') {
            const aPopular = Number(a.getAttribute('data-popularity') || '0');
            const bPopular = Number(b.getAttribute('data-popularity') || '0');
            if (bPopular !== aPopular) return bPopular - aPopular;
            return aTitle.localeCompare(bTitle, 'de');
          }
          return aTitle.localeCompare(bTitle, 'de');
        });

        const limit = getStep() * pageBlocks;
        const visibleCards = filtered.slice(0, limit);

        toolsGrid.innerHTML = '';
        visibleCards.forEach(function(card) {
          toolsGrid.appendChild(card);
        });

        const totalFiltered = filtered.length;
        const currentVisible = visibleCards.length;
        const hidden = totalFiltered - currentVisible;

        // Show/hide no results message
        if (totalFiltered === 0) {
          toolsGrid.style.display = 'none';
          noResults.style.display = 'block';
        } else {
          toolsGrid.style.display = 'grid';
          noResults.style.display = 'none';
        }

        if (loadMoreBtn) {
          if (totalFiltered > limit) {
            loadMoreBtn.style.display = 'inline-flex';
          } else {
            loadMoreBtn.style.display = 'none';
          }
        }

        if (hiddenCountInfo) {
          if (hidden > 0) {
            hiddenCountInfo.textContent = 'Noch ' + hidden + ' Tools verborgen';
            hiddenCountInfo.style.display = 'block';
          } else {
            hiddenCountInfo.style.display = 'none';
          }
        }
      }

      function resetAndFilter() {
        pageBlocks = 1;
        filterTools();
      }

      // Search input listener
      searchInput.addEventListener('input', resetAndFilter);

      if (sortSelect) {
        sortSelect.addEventListener('change', function() {
          const sortValue = sortSelect.value;
          try {
            if (sortValue && ['az', 'new', 'pop'].indexOf(sortValue) !== -1) {
              localStorage.setItem(sortStorageKey, sortValue);
            } else {
              localStorage.removeItem(sortStorageKey);
            }
          } catch (e) {
            // ignore localStorage access errors
          }
          const params = new URLSearchParams(window.location.search);
          params.set('sort', sortValue);
          const nextUrl = params.toString() ? '/tools/?' + params.toString() : '/tools/';
          history.pushState(null, '', nextUrl);
          resetAndFilter();
        });
      }

      if (clearFilterBtn) {
        clearFilterBtn.addEventListener('click', function(e) {
          e.preventDefault();
          window.location.href = '/tools/';
        });
      }

      if (loadMoreBtn) {
        loadMoreBtn.addEventListener('click', function() {
          pageBlocks += 1;
          filterTools();
        });
      }

      window.addEventListener('resize', filterTools);

      // Initial filter on page load
      filterTools();
    })();
  </script>
</BaseLayout>

<style>
  .tools-guides {
    margin: 24px 0 56px;
    padding-top: 20px;
    border-top: 1px solid rgba(23, 98, 89, 0.12);
  }

  .tools-guides-head {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 16px;
    margin-bottom: 16px;
  }

  .tools-guides-head h2 {
    margin: 0;
    font-size: 1.18rem;
    font-weight: 800;
    color: var(--on-surface);
  }

  .tools-guides-more {
    font-size: 0.92rem;
    font-weight: 700;
    text-decoration: none;
    color: var(--primary);
  }

  .tools-guides-list {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 12px;
  }

  .tools-guides-article {
    display: grid;
    gap: 6px;
    padding: 14px 16px;
    text-decoration: none;
    color: inherit;
    border-radius: 18px;
    background: rgba(255, 255, 255, 0.82);
    border: 1px solid rgba(23, 98, 89, 0.10);
    transition: transform var(--transition), border-color var(--transition), box-shadow var(--transition);
  }

  .tools-guides-article:hover {
    transform: translateY(-2px);
    border-color: rgba(23, 98, 89, 0.18);
    box-shadow: 0 12px 28px rgba(18, 28, 24, 0.06);
  }

  .tools-guides-article strong {
    font-size: 0.96rem;
    line-height: 1.35;
    color: var(--primary);
  }

  .tools-guides-article span {
    font-size: 0.9rem;
    line-height: 1.55;
    color: var(--secondary);
  }

  :global([data-theme="dark"]) .tools-guides {
    border-top-color: rgba(142, 216, 201, 0.16);
  }

  :global([data-theme="dark"]) .tools-guides-head h2 {
    color: rgba(246, 252, 249, 0.96);
  }

  :global([data-theme="dark"]) .tools-guides-more {
    color: #8ed8c9;
  }

  :global([data-theme="dark"]) .tools-guides-article {
    background: rgba(22, 41, 36, 0.88);
    border-color: rgba(142, 216, 201, 0.18);
  }

  :global([data-theme="dark"]) .tools-guides-article:hover {
    border-color: rgba(142, 216, 201, 0.34);
    box-shadow: 0 14px 30px rgba(0, 0, 0, 0.22);
  }

  :global([data-theme="dark"]) .tools-guides-article strong {
    color: #b8f3e7;
  }

  :global([data-theme="dark"]) .tools-guides-article span {
    color: rgba(226, 238, 233, 0.72);
  }

  @media (max-width: 920px) {
    .tools-guides-list {
      grid-template-columns: 1fr;
    }
  }
</style>
