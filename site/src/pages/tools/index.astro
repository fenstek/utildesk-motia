---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { realpathSync } from "node:fs";
import { readdir, readFile, stat } from "node:fs/promises";
import { join, relative } from "node:path";
import { execFileSync } from "node:child_process";
import matter from "gray-matter";
import { resolveLocalLogo } from "../../lib/resolveLogoPath";
import { getAvatarFallbackDataUrl, getFaviconCandidates } from "../../lib/favicon";
import { fromContent } from "../../lib/contentRoot.mjs";
import { normalizePriceModel } from "../../lib/priceModel";
import { tagHref } from "../../lib/tagRoutes";
import { listRatgeberEntries } from "../../lib/ratgeber";
import toolAddedAtManifest from "../../data/tool-added-at.json";
import {
  buildBreadcrumbSchema,
  buildCollectionPageSchema,
  SITE_URL,
} from "../../lib/siteMeta";

const toolsDir = fromContent("tools");
const toolAddedAtBySlug = toolAddedAtManifest as Record<string, number>;
const files = (await readdir(toolsDir))
  .filter((f) => f.endsWith(".md") && !f.startsWith("_"));

const gitRepoRoot = (() => {
  try {
    return execFileSync("git", ["rev-parse", "--show-toplevel"], {
      cwd: process.cwd(),
      encoding: "utf-8",
    }).trim();
  } catch {
    return process.cwd();
  }
})();

const gitToolsPath = relative(gitRepoRoot, realpathSync(toolsDir)).replace(/\\/g, "/") || "content/tools";

const gitAddedAtByFile = (() => {
  try {
    const output = execFileSync(
      "git",
      ["log", "--diff-filter=A", "--format=%ct", "--name-only", "--", gitToolsPath],
      { cwd: gitRepoRoot, encoding: "utf-8" }
    );
    const map = new Map<string, number>();
    let currentTimestamp = 0;
    output.split(/\r?\n/).forEach((line) => {
      const trimmed = line.trim();
      if (!trimmed) return;
      if (/^\d+$/.test(trimmed)) {
        currentTimestamp = Number(trimmed) * 1000;
        return;
      }
      if (!trimmed.startsWith(`${gitToolsPath}/`)) return;
      if (!map.has(trimmed) && currentTimestamp > 0) {
        map.set(trimmed, currentTimestamp);
      }
    });
    return map;
  } catch {
    return new Map<string, number>();
  }
})();

const stripMarkdown = (text: string) =>
  text
    .replace(/!\[[^\]]*]\([^)]*\)/g, "")
    .replace(/\[[^\]]*]\([^)]*\)/g, "$1")
    .replace(/[`*_>#-]/g, "")
    .replace(/\s+/g, " ")
    .trim();

const getExcerpt = (content: string) => {
  const paragraphs = content.split(/\n\s*\n/);
  for (const paragraph of paragraphs) {
    if (paragraph.trim().startsWith("#")) continue;
    const cleaned = stripMarkdown(paragraph);
    if (cleaned) return cleaned;
  }
  return "";
};



const resolveCategoryIcon = (category: string | null, tags: string[]) => {
  const normalizedCategory = category ? category.toLowerCase() : "";
  const normalizedTags = tags.map((tag) => tag.toLowerCase());
  const combined = [normalizedCategory, ...normalizedTags].join(" ");

  if (combined.includes("design") || combined.includes("ui") || combined.includes("ux")) {
    return "design";
  }
  if (combined.includes("automation") || combined.includes("workflow")) {
    return "automation";
  }
  if (combined.includes("ai") || combined.includes("ml") || combined.includes("machine")) {
    return "ai";
  }
  return "generic";
};



const tools = await Promise.all(
  files.map(async (file) => {
    const full = join(toolsDir, file);
    const stats = await stat(full);
    const raw = await readFile(full, "utf-8");
    const { data, content } = matter(raw);
    const disabled = data.disabled === true || String(data.disabled || "").toLowerCase() === "true";
    if (disabled) return null;
    const slug = String(data.slug ?? file.replace(/\.md$/, ""));
    const title = String(data.title ?? slug);
    const category = data.category ? String(data.category) : null;
    const price_model = normalizePriceModel(data.price_model);
    const affiliate_url = data.affiliate_url ? String(data.affiliate_url) : null;
    const official_url = data.official_url ? String(data.official_url) : null;
    const brandLogo = data.brandLogo ? String(data.brandLogo) : null;
    const providerUrl = affiliate_url || official_url;
    const localLogo = resolveLocalLogo(slug);
    const faviconCandidates = getFaviconCandidates(providerUrl, 128);
    const faviconLogo = faviconCandidates[0] ?? null;
    const iconUrl = brandLogo || localLogo || faviconLogo;
    const iconFallbacks = brandLogo || localLogo || !faviconLogo ? [] : [...faviconCandidates.slice(1), getAvatarFallbackDataUrl(title)];
    const tags = Array.isArray(data.tags) ? data.tags.map(String) : [];
    const description = data.description
      ? String(data.description)
      : data.summary
        ? String(data.summary)
        : data.excerpt
          ? String(data.excerpt)
          : data.tagline
            ? String(data.tagline)
            : "";
    const excerpt = description || getExcerpt(content);

    // Prefer explicit content dates, then the committed manifest because
    // Cloudflare Pages builds do not keep reliable per-file mtimes or git history.
    const createdAt = data.created_at ? String(data.created_at) : "";
    const parsedCreatedAtMs = createdAt ? new Date(createdAt).getTime() : 0;
    const manifestAddedAtMs = Number(toolAddedAtBySlug[slug] || 0);
    const gitAddedAtMs = gitAddedAtByFile.get(`${gitToolsPath}/${file}`) || 0;
    const createdAtMs = (Number.isFinite(parsedCreatedAtMs) && parsedCreatedAtMs > 0 ? parsedCreatedAtMs : 0) ||
      manifestAddedAtMs ||
      gitAddedAtMs ||
      stats.mtimeMs;

    // Read popularity from frontmatter, fallback to 0 if missing
    const popularity = data.popularity ? Number(data.popularity) : 0;

    return {
      slug,
      title,
      category,
      price_model,
      iconUrl,
      iconFallbacks,
      tags,
      excerpt,
      addedAtMs: createdAtMs,
      popularity: popularity,
      fallbackIcon: resolveCategoryIcon(category, tags),
    };
  })
);

const enabledTools = tools.filter(Boolean);
enabledTools.sort((a, b) => a.title.localeCompare(b.title, "de"));

// Build tag frequency map and keep only the most useful tags
const tagFrequency = new Map<string, number>();
enabledTools.forEach((tool) => {
  tool.tags.forEach((tag) => {
    const normalized = tag.trim().toLowerCase();
    if (!normalized) return;
    tagFrequency.set(tag, (tagFrequency.get(tag) || 0) + 1);
  });
});
const sortedTags = Array.from(tagFrequency.entries())
  .sort((a, b) => {
    if (b[1] !== a[1]) return b[1] - a[1];
    return a[0].localeCompare(b[0], "de");
  })
  .map(([tag]) => tag);
const visibleTags = sortedTags.filter((tag) => (tagFrequency.get(tag) || 0) >= 2).slice(0, 24);
const recentRatgeber = (await listRatgeberEntries()).slice(0, 3);
const toolsItemListSchema = {
  "@context": "https://schema.org",
  "@type": "ItemList",
  name: "Utildesk Tools",
  numberOfItems: enabledTools.length,
  itemListElement: enabledTools.slice(0, 200).map((tool, index) => ({
    "@type": "ListItem",
    position: index + 1,
    name: tool.title,
    url: `${SITE_URL}/tools/${tool.slug}/`,
  })),
};
const toolsCollectionSchema = buildCollectionPageSchema({
  name: "Utildesk Tools",
  description: "Kuratiertes Verzeichnis nützlicher AI- und Produktivitätstools.",
  url: `${SITE_URL}/tools/`,
  about: ["AI-Tools", "Produktivität", "Automatisierung"],
  mainEntity: toolsItemListSchema,
});
const toolsBreadcrumbSchema = buildBreadcrumbSchema([
  { name: "Startseite", url: `${SITE_URL}/` },
  { name: "Tools", url: `${SITE_URL}/tools/` },
]);
---

<BaseLayout
  title="Tools — Utildesk"
  description="Kuratiertes Verzeichnis nützlicher AI- und Produktivitätstools"
>
  <Fragment slot="head">
    <link rel="canonical" href="https://tools.utildesk.de/tools/" />
    <script type="application/ld+json" set:html={JSON.stringify(toolsCollectionSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(toolsItemListSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(toolsBreadcrumbSchema)} />
  </Fragment>

  <!-- Hero -->
  <section class="hero" style="padding: 60px 0 40px;">
    <h1 class="hero-title">Tools</h1>
    <p class="hero-subtitle">
      Kuratiertes Verzeichnis nützlicher AI- und Produktivitätstools.
      Durchsuche alle Tools oder filtere nach Tags.
    </p>
  </section>

  <!-- Tag Filter Row -->
  {visibleTags.length > 0 && (
    <div class="tag-filter-row" id="tag-filter-row">
      <label class="tag-filter-label">Beliebte Tags:</label>
      <div class="tag-filter-list" id="tag-filter-list">
        {visibleTags.map((tag) => (
          <a
            href={tagHref(tag)}
            class="tag-filter-item"
            data-tag={tag}
          >
            {tag}
          </a>
        ))}
        <a href="/tools/" class="clear-filter-btn" id="clear-filter-btn" style="display: none;">
          Filter löschen
        </a>
      </div>
    </div>
  )}

  <!-- Search -->
  <div class="search-wrapper">
    <input
      type="search"
      id="search-input"
      class="search-input"
      placeholder="Tools suchen…"
      autocomplete="off"
    />
    <select id="sort-select" class="search-input" aria-label="Sortierung">
      <option value="az">A–Z</option>
      <option value="new">Neu hinzugefügt</option>
      <option value="pop">Beliebt</option>
    </select>
  </div>

  <!-- Tools Grid -->
  <div class="tools-grid" id="tools-grid">
    {enabledTools.map((tool) => (
      <a
        href={`/tools/${tool.slug}/`}
        class="card tool-card"
        data-title={tool.title.toLowerCase()}
        data-slug={tool.slug.toLowerCase()}
        data-tags={tool.tags.map((tag) => tag.toLowerCase()).join(",")}
        data-added={tool.addedAtMs}
        data-popularity={tool.popularity}
      >
        <div class="tool-header">
          <div class="tool-image">
            {tool.iconUrl ? (
              <span class="tool-card-logo">
                <img src={tool.iconUrl} alt={tool.title} loading="lazy" data-fallback-srcs={tool.iconFallbacks.length ? JSON.stringify(tool.iconFallbacks) : undefined} />
              </span>
            ) : tool.fallbackIcon === "ai" ? (
              <span class="tool-card-logo" aria-hidden="true">
                <svg viewBox="0 0 24 24" role="img" aria-hidden="true">
                  <path
                    d="M9 3a1 1 0 0 1 1 1v1.1a6.002 6.002 0 0 1 4 0V4a1 1 0 1 1 2 0v2.1a6.002 6.002 0 0 1 3 5.2V13a1 1 0 0 1-1 1h-1.1a6.002 6.002 0 0 1-5.2 3V19a1 1 0 1 1-2 0v-2.1a6.002 6.002 0 0 1-5.2-3H4a1 1 0 0 1-1-1v-1.7a6.002 6.002 0 0 1 3-5.2V4a1 1 0 0 1 2 0v1.1a6.01 6.01 0 0 1 1-.1Zm3 4a4 4 0 1 0 0 8 4 4 0 0 0 0-8Z"
                    fill="currentColor"
                  />
                </svg>
              </span>
            ) : tool.fallbackIcon === "automation" ? (
              <span class="tool-card-logo" aria-hidden="true">
                <svg viewBox="0 0 24 24" role="img" aria-hidden="true">
                  <path
                    d="M7 4a3 3 0 0 1 3 3v1h4V7a3 3 0 1 1 6 0v3a3 3 0 0 1-3 3h-1v2h1a3 3 0 1 1-3 3v-1h-4v1a3 3 0 1 1-6 0v-3a3 3 0 0 1 3-3h1v-2H7a3 3 0 0 1-3-3V7a3 3 0 0 1 3-3Zm0 2a1 1 0 0 0-1 1v3a1 1 0 0 0 1 1h3v4H7a1 1 0 0 0-1 1v3a1 1 0 1 0 2 0v-1h8v1a1 1 0 1 0 2 0v-3a1 1 0 0 0-1-1h-3v-4h3a1 1 0 0 0 1-1V7a1 1 0 1 0-2 0v1H8V7a1 1 0 0 0-1-1Z"
                    fill="currentColor"
                  />
                </svg>
              </span>
            ) : tool.fallbackIcon === "design" ? (
              <span class="tool-card-logo" aria-hidden="true">
                <svg viewBox="0 0 24 24" role="img" aria-hidden="true">
                  <path
                    d="M6 3a3 3 0 0 0-3 3v9a6 6 0 0 0 12 0V6a3 3 0 0 0-3-3H6Zm0 2h6a1 1 0 0 1 1 1v9a4 4 0 1 1-8 0V6a1 1 0 0 1 1-1Zm12 2a3 3 0 0 1 3 3v5a6 6 0 0 1-6 6h-1.5a7.97 7.97 0 0 0 2.5-6V7h2Z"
                    fill="currentColor"
                  />
                </svg>
              </span>
            ) : (
              <span class="tool-card-logo" aria-hidden="true">
                <svg viewBox="0 0 24 24" role="img" aria-hidden="true">
                  <path
                    d="M5 5h14a2 2 0 0 1 2 2v3H3V7a2 2 0 0 1 2-2Zm-2 7h18v5a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-5Zm4 2v3h2v-3H7Zm4 0v3h6v-3h-6Z"
                    fill="currentColor"
                  />
                </svg>
              </span>
            )}
          </div>
          <div class="tool-info">
            <h3 class="tool-title">{tool.title}</h3>
            <p class="tools-desc">{tool.excerpt || "Kurzbeschreibung folgt."}</p>
          </div>
        </div>
        <div class="tool-badges">
          {tool.category && (
            <span class="badge badge-category">{tool.category}</span>
          )}
          {tool.price_model && (
            <span class="badge badge-price">{tool.price_model}</span>
          )}
        </div>
      </a>
    ))}
  </div>

  <!-- No results message (hidden by default) -->
  <div id="no-results" style="display: none; text-align: center; padding: 60px 0;">
    <p style="color: var(--text-muted); font-size: 1.125rem;">
      Keine Tools gefunden. Versuche einen anderen Suchbegriff oder filtere nach einem anderen Tag.
    </p>
  </div>
  <div style="text-align: center; margin-top: 36px; padding-bottom: 48px;">
    <button type="button" id="load-more-btn" class="hero-cta">Mehr anzeigen</button>
    <div
      id="hidden-count-info"
      style="display: none; margin-top: 10px; text-align: center; font-size: 0.9rem; color: var(--text-muted);"
    >
      Noch 0 Tools verborgen
    </div>
  </div>

  {recentRatgeber.length > 0 && (
    <section class="tools-guides">
      <div class="tools-guides-head">
        <h2>Passende Guides</h2>
        <a href="/ratgeber/" class="tools-guides-more">Zum Ratgeber</a>
      </div>
      <div class="tools-guides-list">
        {recentRatgeber.map((article) => (
          <a href={`/ratgeber/${article.slug}/`} class="tools-guides-article">
            <strong>{article.data.title}</strong>
            <span>{article.data.excerpt || "Redaktionelle Einordnung und Tool-Bezüge aus dem Utildesk-Ratgeber."}</span>
          </a>
        ))}
      </div>
    </section>
  )}

  <!-- Client-side search + tag filter script (inline, no build tools) -->
  <script is:inline>
    (function() {
      const sortStorageKey = 'utildesk-tools-sort';
      const searchInput = document.getElementById('search-input');
      const sortSelect = document.getElementById('sort-select');
      const toolsGrid = document.getElementById('tools-grid');
      const noResults = document.getElementById('no-results');
      const loadMoreBtn = document.getElementById('load-more-btn');
      const hiddenCountInfo = document.getElementById('hidden-count-info');
      const cards = Array.from(toolsGrid.querySelectorAll('.tool-card'));
      const clearFilterBtn = document.getElementById('clear-filter-btn');
      let pageBlocks = 1;

      // Read URL params ?tag= and ?sort=
      const urlParams = new URLSearchParams(window.location.search);
      const initialTag = urlParams.get('tag');
      const initialSort = urlParams.get('sort');

      if (initialTag) {
        const tagSlug = initialTag
          .toLowerCase()
          .replace(/[^a-z0-9]+/g, '-')
          .replace(/^-+|-+$/g, '');
        window.location.replace('/tools/tag/' + tagSlug + '/');
        return;
      }

      // Restore sort preference from URL first, then localStorage.
      if (sortSelect) {
        const validSorts = ['az', 'new', 'pop'];
        let restoredSort = '';
        if (initialSort && validSorts.indexOf(initialSort) !== -1) {
          restoredSort = initialSort;
        } else {
          try {
            const storedSort = localStorage.getItem(sortStorageKey);
            if (storedSort && validSorts.indexOf(storedSort) !== -1) {
              restoredSort = storedSort;
            }
          } catch (e) {
            // ignore localStorage access errors
          }
        }
        if (restoredSort) {
          sortSelect.value = restoredSort;
        }
        if (window.location.search) {
          history.replaceState(null, '', '/tools/');
        }
      }

      function getCols() {
        const template = window.getComputedStyle(toolsGrid).gridTemplateColumns || '';
        if (!template || template === 'none') return 1;
        const cols = template.split(' ').filter(function(part) { return part.trim().length > 0; }).length;
        return cols > 0 ? cols : 1;
      }

      function getStep() {
        return getCols() * 6;
      }

      // Filter + sort + pagination
      function filterTools() {
        const query = searchInput.value.toLowerCase().trim();
        const sortMode = sortSelect ? sortSelect.value : 'az';
        const filtered = cards.filter(function(card) {
          const title = card.getAttribute('data-title') || '';
          const slug = card.getAttribute('data-slug') || '';
          const tags = card.getAttribute('data-tags') || '';
          const tagList = tags.split(',').map(function(t) { return t.trim().toLowerCase(); });

          // Check search query match
          const searchMatch = !query ||
                             title.includes(query) ||
                             slug.includes(query) ||
                             tags.includes(query);

          return searchMatch;
        });

        filtered.sort(function(a, b) {
          const aTitle = (a.getAttribute('data-title') || '').toLowerCase();
          const bTitle = (b.getAttribute('data-title') || '').toLowerCase();
          if (sortMode === 'new') {
            const aAdded = Number(a.getAttribute('data-added') || '0');
            const bAdded = Number(b.getAttribute('data-added') || '0');
            if (bAdded !== aAdded) return bAdded - aAdded;
            return aTitle.localeCompare(bTitle, 'de');
          }
          if (sortMode === 'pop') {
            const aPopular = Number(a.getAttribute('data-popularity') || '0');
            const bPopular = Number(b.getAttribute('data-popularity') || '0');
            if (bPopular !== aPopular) return bPopular - aPopular;
            return aTitle.localeCompare(bTitle, 'de');
          }
          return aTitle.localeCompare(bTitle, 'de');
        });

        const limit = getStep() * pageBlocks;
        const visibleCards = filtered.slice(0, limit);

        toolsGrid.innerHTML = '';
        visibleCards.forEach(function(card) {
          toolsGrid.appendChild(card);
        });

        const totalFiltered = filtered.length;
        const currentVisible = visibleCards.length;
        const hidden = totalFiltered - currentVisible;

        // Show/hide no results message
        if (totalFiltered === 0) {
          toolsGrid.style.display = 'none';
          noResults.style.display = 'block';
        } else {
          toolsGrid.style.display = 'grid';
          noResults.style.display = 'none';
        }

        if (loadMoreBtn) {
          if (totalFiltered > limit) {
            loadMoreBtn.style.display = 'inline-flex';
          } else {
            loadMoreBtn.style.display = 'none';
          }
        }

        if (hiddenCountInfo) {
          if (hidden > 0) {
            hiddenCountInfo.textContent = 'Noch ' + hidden + ' Tools verborgen';
            hiddenCountInfo.style.display = 'block';
          } else {
            hiddenCountInfo.style.display = 'none';
          }
        }
      }

      function resetAndFilter() {
        pageBlocks = 1;
        filterTools();
      }

      // Search input listener
      searchInput.addEventListener('input', resetAndFilter);

      if (sortSelect) {
        sortSelect.addEventListener('change', function() {
          const sortValue = sortSelect.value;
          try {
            if (sortValue && sortValue !== 'az') {
              localStorage.setItem(sortStorageKey, sortValue);
            } else {
              localStorage.removeItem(sortStorageKey);
            }
          } catch (e) {
            // ignore localStorage access errors
          }
          history.replaceState(null, '', '/tools/');
          resetAndFilter();
        });
      }

      if (clearFilterBtn) {
        clearFilterBtn.addEventListener('click', function(e) {
          e.preventDefault();
          window.location.href = '/tools/';
        });
      }

      if (loadMoreBtn) {
        loadMoreBtn.addEventListener('click', function() {
          pageBlocks += 1;
          filterTools();
        });
      }

      window.addEventListener('resize', filterTools);

      // Initial filter on page load
      filterTools();
    })();
  </script>
</BaseLayout>

<style>
  .tools-guides {
    margin: 24px 0 56px;
    padding-top: 20px;
    border-top: 1px solid rgba(23, 98, 89, 0.12);
  }

  .tools-guides-head {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 16px;
    margin-bottom: 16px;
  }

  .tools-guides-head h2 {
    margin: 0;
    font-size: 1.18rem;
    font-weight: 800;
    color: var(--on-surface);
  }

  .tools-guides-more {
    font-size: 0.92rem;
    font-weight: 700;
    text-decoration: none;
    color: var(--primary);
  }

  .tools-guides-list {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 12px;
  }

  .tools-guides-article {
    display: grid;
    gap: 6px;
    padding: 14px 16px;
    text-decoration: none;
    color: inherit;
    border-radius: 18px;
    background: rgba(255, 255, 255, 0.82);
    border: 1px solid rgba(23, 98, 89, 0.10);
    transition: transform var(--transition), border-color var(--transition), box-shadow var(--transition);
  }

  .tools-guides-article:hover {
    transform: translateY(-2px);
    border-color: rgba(23, 98, 89, 0.18);
    box-shadow: 0 12px 28px rgba(18, 28, 24, 0.06);
  }

  .tools-guides-article strong {
    font-size: 0.96rem;
    line-height: 1.35;
    color: var(--primary);
  }

  .tools-guides-article span {
    font-size: 0.9rem;
    line-height: 1.55;
    color: var(--secondary);
  }

  :global([data-theme="dark"]) .tools-guides {
    border-top-color: rgba(142, 216, 201, 0.16);
  }

  :global([data-theme="dark"]) .tools-guides-head h2 {
    color: rgba(246, 252, 249, 0.96);
  }

  :global([data-theme="dark"]) .tools-guides-more {
    color: #8ed8c9;
  }

  :global([data-theme="dark"]) .tools-guides-article {
    background: rgba(22, 41, 36, 0.88);
    border-color: rgba(142, 216, 201, 0.18);
  }

  :global([data-theme="dark"]) .tools-guides-article:hover {
    border-color: rgba(142, 216, 201, 0.34);
    box-shadow: 0 14px 30px rgba(0, 0, 0, 0.22);
  }

  :global([data-theme="dark"]) .tools-guides-article strong {
    color: #b8f3e7;
  }

  :global([data-theme="dark"]) .tools-guides-article span {
    color: rgba(226, 238, 233, 0.72);
  }

  @media (max-width: 920px) {
    .tools-guides-list {
      grid-template-columns: 1fr;
    }
  }
</style>
