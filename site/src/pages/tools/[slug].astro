---
// editorial tool-akte rendering
import BaseLayout from "../../layouts/BaseLayout.astro";
import { marked } from "marked";
import { resolveLocalLogo } from "../../lib/resolveLogoPath";
import { getAvatarFallbackDataUrl, getFaviconCandidates } from "../../lib/favicon";
import { CATEGORIES } from "../../lib/categories";
import { listActiveToolEntries } from "../../lib/toolEntries.mjs";
import toolAddedAtManifest from "../../data/tool-added-at.json";
import contentLastmodManifest from "../../data/content-lastmod.json";
import {
  createToolAddedAtRankMap,
  getToolSearchIndexDecision,
} from "../../lib/searchIndexPolicy.mjs";
import {
  classifyToolEntry,
  isCuratedTier,
  stripTemplateBoilerplate,
} from "../../lib/toolQuality.mjs";
import { normalizePriceModel } from "../../lib/priceModel";
import { tagHref } from "../../lib/tagRoutes";
import {
  buildBreadcrumbSchema,
  buildPublisherOrganization,
  SITE_LANGUAGE,
  SITE_URL,
  toAbsoluteUrl,
} from "../../lib/siteMeta";
import {
  buildOfferFromPriceModel,
  extractFeatureList,
  mapToolCategoryToSchemaCategory,
} from "../../lib/machineReadable";
import { buildFaqPageSchema, extractFaqPairsFromMarkdown } from "../../lib/schema";

export async function getStaticPaths() {
  const entries = await listActiveToolEntries();
  return entries.map((entry) => ({
    params: { slug: entry.slug },
    props: { entry },
  }));
}

const { slug } = Astro.params;
const { entry } = Astro.props;
const { data, content } = entry;
const contentLastmod = contentLastmodManifest as Record<string, string>;
const toolAddedAtRankMap = createToolAddedAtRankMap(toolAddedAtManifest);
const searchIndexDecision = getToolSearchIndexDecision(entry, {
  addedAtRank: toolAddedAtRankMap.get(entry.slug) ?? 0,
});
const toolQuality = classifyToolEntry(entry);
const isCuratedTool = isCuratedTier(toolQuality.tier);
const renderedContent = isCuratedTool ? content : stripTemplateBoilerplate(content);

const official_url = data.official_url ? String(data.official_url) : "";
const affiliate_url = data.affiliate_url ? String(data.affiliate_url) : "";
const brandLogo = data.brandLogo ? String(data.brandLogo) : null;
const provider_url = affiliate_url || official_url || "";
const visible_provider_url = official_url || provider_url || "";
const target_provider_url = affiliate_url || official_url || "";
const escapeRegExp = (value: string) => value.replace(/[.*+?^$|()\[\]{}]/g, "\\$&");
const escapeHtml = (value: string) =>
  String(value)
    .replace(/&/g, "&amp;")
    .replace(/"/g, "&quot;")
    .replace(/</g, "&lt;")
    .replace(/>/g, "&gt;");
const linkFirstParagraphMention = (input: string, term: string, url: string) => {
  if (!url || term.trim().length < 4) return input;
  const termRegex = new RegExp("(?<![\\w/>\"])" + escapeRegExp(term) + "(?![\\w/<\"])", "gi");
  let firstDone = false;
  return input.replace(/(<(?:p|li|h[2-6])\b[^>]*>)([\s\S]*?)(<\/(?:p|li|h[2-6])>)/gi, (_, open, inner, close) => {
    if (/<a\b/i.test(inner) || /<code\b/i.test(inner) || /<pre\b/i.test(inner)) return _ ;
    if (!termRegex.test(inner)) { termRegex.lastIndex = 0; return _; }
    termRegex.lastIndex = 0;
    const linked = inner.replace(termRegex, (match) => {
      if (firstDone) return `<a href="${url}" rel="noopener noreferrer">${match}</a>`;
      firstDone = true;
      return `<a href="${url}" target="_blank" rel="noopener noreferrer">${match}</a>`;
    });
    return open + linked + close;
  });
};
const buildInlineProviderLinkHtml = (visibleUrl: string, targetUrl: string) => {
  if (!visibleUrl || !targetUrl) return "";
  const safeVisibleUrl = escapeHtml(visibleUrl);
  const safeTargetUrl = escapeHtml(targetUrl);

  return [
    `<div class="inline-provider-link">`,
    `<p><span class="inline-provider-link-emoji">👉</span> <strong>Zum Anbieter:</strong> <a href="${safeTargetUrl}" target="_blank" rel="noopener noreferrer">${safeVisibleUrl}</a></p>`,
    `</div>`,
  ].join("");
};
const ensureInlineProviderLink = (input: string, visibleUrl: string, targetUrl: string) => {
  if (!visibleUrl || !targetUrl) return input;

  const providerLinkHtml = buildInlineProviderLinkHtml(visibleUrl, targetUrl);
  if (!providerLinkHtml) return input;

  const cleanedInput = input
    .replace(/<div[^>]*class="inline-provider-link"[^>]*>[\s\S]*?<\/div>/gi, "")
    .replace(/<p[^>]*>(?:(?!<\/p>).)*?Zum Anbieter:(?:(?!<\/p>).)*?<\/p>/gis, "")
    .replace(/<p[^>]*>(?:(?!<\/p>).)*?(?:Affiliate-Link:|Linkziel:)(?:(?!<\/p>).)*?<\/p>/gis, "")
    .replace(/\n{3,}/g, "\n\n")
    .trim();

  if (/<h2[^>]*>\s*FAQ\s*<\/h2>/i.test(cleanedInput)) {
    return cleanedInput.replace(/<h2[^>]*>\s*FAQ\s*<\/h2>/i, `${providerLinkHtml}\n<h2>FAQ</h2>`);
  }

  return `${cleanedInput}\n${providerLinkHtml}`;
};

const localLogo = resolveLocalLogo(slug);
const faviconCandidates = getFaviconCandidates(provider_url, 128);
const faviconLogo = faviconCandidates[0] ?? null;
const faviconFallbacks = faviconCandidates.slice(1);
const fallbackAvatarUrl = getAvatarFallbackDataUrl(String(data.title ?? slug));

const logoUrl = brandLogo || localLogo || faviconLogo;
const logoFallbacks = logoUrl === faviconLogo ? [...faviconFallbacks, fallbackAvatarUrl] : [];


const title = String(data.title ?? slug);
const category = data.category ? String(data.category) : null;
const price_model = normalizePriceModel(data.price_model);
const tags = Array.isArray(data.tags) ? data.tags.map(String) : [];
const description = data.description ? String(data.description) : "";
const oneliner = description || (data.summary ? String(data.summary) : "");
const vendorName = data.vendor ? String(data.vendor) : title;
const extractDomain = (url: string) => {
  if (!url) return "";
  try { return new URL(url).hostname.replace(/^www\./, ""); }
  catch { return url.replace(/^https?:\/\//, "").replace(/^www\./, "").replace(/\/.*$/, ""); }
};
const providerDomain = extractDomain(visible_provider_url || target_provider_url);
const monogramLetter = (vendorName || title || slug || "·")
  .replace(/[^A-Za-zÄÖÜäöü]/g, "")
  .charAt(0)
  .toUpperCase() || "·";
const mentionedInCount = Array.isArray(data.mentionedIn) ? data.mentionedIn.length : 0;
const formatGermanDate = (value: unknown) => {
  if (!value) return "";
  try {
    return new Intl.DateTimeFormat("de-DE", { day: "2-digit", month: "2-digit", year: "numeric" }).format(new Date(String(value)));
  } catch { return ""; }
};
const lastCheckedShort = formatGermanDate(data.lastReviewed || data.last_reviewed || data.lastReviewedAt || data.last_reviewed_at);
const inIndexSinceShort = formatGermanDate(data.created_at || data.createdAt || data.date);
const norm = (s) => String(s ?? "").trim().toLowerCase();
const categoryNorm = norm(category);
const seen = new Set();
const displayTags = (tags ?? [])
  .map(String)
  .filter((t) => {
    const n = norm(t);
    if (!n) return false;
    if (n === "ai") return false; // Hide generic ai tag from UI
    if (categoryNorm && n === categoryNorm) return false;
    if (seen.has(n)) return false;
    seen.add(n);
    return true;
  });

// Find primary category by highest tag match count
// On tie, prefer category whose first matching tag appears earlier in tags
const normalizedTags = tags.map(t => String(t).toLowerCase());
const providerCtaLabel = visible_provider_url || (affiliate_url ? "Zum Anbieter" : "Zur Website");

const categoryResults = CATEGORIES.map(cat => {
  const matches = normalizedTags.filter(tag => cat.matchTags.includes(tag));
  const matchCount = matches.length;
  const firstMatchPos = matchCount > 0
    ? normalizedTags.findIndex(tag => cat.matchTags.includes(tag))
    : Infinity;

  return { category: cat, matchCount, firstMatchPos };
}).filter(r => r.matchCount > 0);

// Sort by: 1) highest match count, 2) earliest first match position
categoryResults.sort((a, b) => {
  if (b.matchCount !== a.matchCount) {
    return b.matchCount - a.matchCount;
  }
  return a.firstMatchPos - b.firstMatchPos;
});

const primaryCategory = categoryResults.length > 0 ? categoryResults[0].category : undefined;

// Render Markdown to HTML

// Remove the Alternativen/Alternatives section from the main markdown content so it won't appear in the article text
const contentWithoutAlternatives = renderedContent.replace(
  /(?:^|\n)#{1,3}\s+(Alternativen|Alternatives?)\b[^\n]*\n[\s\S]*?(?=\n#{1,3}\s|\s*$)/i,
  ""
).trim();
let html = marked.parse(contentWithoutAlternatives);

// Remove first H1 from markdown to avoid duplicate title
html = String(html).replace(/<h1[^>]*>[\s\S]*?<\/h1>\s*/i, "");
const articleHtml = ensureInlineProviderLink(
  linkFirstParagraphMention(String(html), title, target_provider_url),
  visible_provider_url,
  target_provider_url
);

// ── Alternatives helpers ───────────────────────────────────────────────────
const stripMd = (text: string) =>
  text
    .replace(/!\[[^\]]*]\([^)]*\)/g, "")
    .replace(/\[[^\]]*]\([^)]*\)/g, "$1")
    .replace(/[`*_>#]/g, "")
    .replace(/(^|\s)-\s+/g, "$1")
    .replace(/\s+/g, " ")
    .trim();

const getExcerpt = (md: string) => {
  for (const p of md.split(/\n\s*\n/)) {
    if (p.trim().startsWith("#")) continue;
    const cleaned = stripMd(p);
    if (cleaned) return cleaned;
  }
  return "";
};

const iconType = (cat: string | null, tgs: string[]) => {
  const c = [cat?.toLowerCase() ?? "", ...tgs.map((t) => t.toLowerCase())].join(" ");
  if (c.includes("design") || c.includes("ui") || c.includes("ux")) return "design";
  if (c.includes("automation") || c.includes("workflow")) return "automation";
  if (c.includes("ai") || c.includes("ml") || c.includes("machine")) return "ai";
  return "generic";
};

const normalizeAltName = (value: string) =>
  String(value ?? "")
    .replace(/\[([^\]]+)\]\(([^)]+)\)/g, "$1")
    .replace(/[`*_]/g, "")
    .replace(/\s+/g, " ")
    .trim()
    .toLowerCase();

const normalizeAltNameFuzzy = (value: string) =>
  normalizeAltName(value)
    .replace(/\([^)]*\)/g, " ")
    .replace(/\b(ai|tool|app|platform)\b/g, " ")
    .replace(/\s+/g, " ")
    .trim();

const parseAltItem = (item: string) => {
  const internalLink = item.match(/^\[([^\]]+)\]\(\/tools\/([^/)\s]+)\/?\)\s*(?::\s*(.*))?$/);
  if (internalLink) {
    return { kind: "internal_link" as const, name: internalLink[1], slug: internalLink[2] };
  }

  const linked = item.match(/^\[([^\]]+)\]\(([^)]+)\)\s*(?::\s*(.*))?$/);
  if (linked) {
    return { kind: "linked" as const, name: linked[1] };
  }

  const boldColonInside = item.match(/^\*\*([^*]+?)\s*:\s*\*\*\s*(.+)$/);
  if (boldColonInside) {
    return { kind: "bold" as const, name: boldColonInside[1] };
  }

  const boldWithSeparator = item.match(/^\s*\*\*([^*]+)\*\*\s*(?::|–|—|-)\s*(.+)?$/i);
  if (boldWithSeparator) {
    return { kind: "bold" as const, name: boldWithSeparator[1] };
  }

  const bold = item.match(/^\*\*([^*]+?)\*\*\s*:\s*(.+)$/);
  if (bold) {
    return { kind: "bold" as const, name: bold[1] };
  }

  const plainWithSeparator = item.match(/^\s*([^:–—-][^:–—-]{1,80})\s*(?::|–|—|-)\s*(.+)?$/);
  if (plainWithSeparator) {
    return { kind: "plain" as const, name: plainWithSeparator[1] };
  }

  const plain = item.match(/^([^:]+?)\s*:\s*(.+)$/);
  if (plain) {
    return { kind: "plain" as const, name: plain[1] };
  }

  return null;
};

// ── Extract raw list items from the "Alternatives" section ─────────────────
const altSection = renderedContent.match(/(?:^|\r?\n)#{1,3}\s+(Alternativen|Alternatives?)\b[^\r\n]*\r?\n([\s\S]*?)(?=\r?\n#{1,3}\s|\s*$)/i);
const rawAltItems: string[] = altSection
  ? (altSection[2].match(/^[-*]\s+(.+)$/gm) ?? []).map((l) => l.replace(/^[-*]\s+/, "").trim())
  : [];

// ── Load all tool metadata (for matching + rendering) ──────────────────────
const allTools = (await listActiveToolEntries()).map(({ slug: s, data: d, content: c }) => {
  const t = String(d.title ?? s);
  const cat = d.category ? String(d.category) : null;
  const pm = normalizePriceModel(d.price_model);
  const bLogo = d.brandLogo ? String(d.brandLogo) : null;
  const pUrl = d.affiliate_url ? String(d.affiliate_url) : d.official_url ? String(d.official_url) : null;
  const tgs = Array.isArray(d.tags) ? d.tags.map(String) : [];
  const disabled = d.disabled === true || String(d.disabled || "").toLowerCase() === "true";
  const desc = d.description ? String(d.description)
    : d.summary ? String(d.summary)
    : d.excerpt ? String(d.excerpt)
    : d.tagline ? String(d.tagline)
    : "";
  const localAltLogo = resolveLocalLogo(s);
  const faviconAltCandidates = getFaviconCandidates(pUrl, 128);
  const faviconAltLogo = faviconAltCandidates[0] ?? null;
  return {
    slug: s, title: t, category: cat, price_model: pm,
    iconUrl: bLogo || localAltLogo || faviconAltLogo,
    iconFallbacks: bLogo || localAltLogo || !faviconAltLogo ? [] : [...faviconAltCandidates.slice(1), getAvatarFallbackDataUrl(t)],
    tags: tgs,
    excerpt: desc || getExcerpt(c),
    fallbackIcon: iconType(cat, tgs),
    disabled,
  };
});

const enabledTools = allTools.filter((t) => !t.disabled);
const enabledBySlug = new Map(enabledTools.map((t) => [t.slug, t]));
const enabledByNormTitle = new Map(enabledTools.map((t) => [normalizeAltName(t.title), t]));
const enabledByNormTitleFuzzy = new Map(enabledTools.map((t) => [normalizeAltNameFuzzy(t.title), t]));

// ── Match alternatives from multiple markdown formats, preserve input order ─
const alternatives = rawAltItems.reduce<typeof enabledTools>((acc, item) => {
  const parsed = parseAltItem(item);
  if (!parsed) return acc;

  let tool = null;
  if (parsed.kind === "internal_link") {
    tool = enabledBySlug.get(parsed.slug) ?? null;
  } else {
    tool = enabledByNormTitle.get(normalizeAltName(parsed.name)) ?? null;
    if (!tool) {
      tool = enabledByNormTitleFuzzy.get(normalizeAltNameFuzzy(parsed.name)) ?? null;
    }
  }

  if (!tool) return acc;
  if (tool.slug === slug) return acc;
  if (acc.some((x) => x.slug === tool.slug)) return acc;

  acc.push(tool);
  return acc;
}, []);
const alternativesTop = alternatives.slice(0, 3);

// ── Editorial dossier: parse the German markdown body into Akte sections ────
const mdToHtml = (md: string) => String(marked.parse(String(md ?? "").trim()));
const stripInlineMd = (t: unknown) =>
  String(t ?? "")
    .replace(/\[([^\]]+)\]\([^)]*\)/g, "$1")
    .replace(/\*\*([^*]+)\*\*/g, "$1")
    .replace(/\*([^*]+)\*/g, "$1")
    .replace(/`([^`]+)`/g, "$1")
    .replace(/\s+/g, " ")
    .trim();

// Pull out an editorial illustration (rendered as Schlussbild), then drop figures.
const figMatch =
  contentWithoutAlternatives.match(
    /<figure[^>]*tool-editorial-figure[^>]*>[\s\S]*?<img[^>]*src="([^"]+)"[^>]*?(?:alt="([^"]*)")?[^>]*>[\s\S]*?<\/figure>/i,
  ) || [];
const schlussbildSrc = figMatch[1] || "";
const schlussbildAlt = figMatch[2] || `Editorial-Illustration zu ${title}`;

const mdBase = contentWithoutAlternatives
  .replace(/<figure[\s\S]*?<\/figure>/gi, "")
  .replace(/^#\s+.+$/m, "")
  .trim();

const firstH2Idx = mdBase.search(/(^|\n)##\s+/);
const introMd = (firstH2Idx === -1 ? mdBase : mdBase.slice(0, firstH2Idx)).trim();
const afterIntro = firstH2Idx === -1 ? "" : mdBase.slice(firstH2Idx).replace(/^\n+/, "");
const rawSecs = (afterIntro ? afterIntro.split(/\n(?=##\s+)/) : [])
  .map((ch) => {
    const m = ch.match(/^##\s+([^\n]+)\n?([\s\S]*)$/);
    return m ? { title: m[1].trim(), body: m[2].trim() } : null;
  })
  .filter((x): x is { title: string; body: string } => Boolean(x));

const splitBullets = (body: string) =>
  (body.match(/^[ \t]*[-*]\s+.+(?:\n(?![ \t]*[-*]\s|#).+)*/gm) ?? [])
    .map((b) => b.replace(/^[ \t]*[-*]\s+/, "").replace(/\s*\n\s*/g, " ").trim())
    .filter(Boolean);

const leadOf = (body: string) =>
  stripInlineMd(body.split(/\n[ \t]*[-*]\s+/)[0]?.split(/\n\s*\n/)[0] ?? "");

const parsePair = (item: string): [string, string] => {
  let m = item.match(/^\*\*\s*(.+?)\s*\*\*\s*[:–—-]*\s*([\s\S]*)$/);
  if (m) return [stripInlineMd(m[1]).replace(/[:–—-]\s*$/, "").trim(), stripInlineMd(m[2])];
  m = item.match(/^(.{2,60}?)\s*[:–—]\s+([\s\S]+)$/);
  if (m) return [stripInlineMd(m[1]), stripInlineMd(m[2])];
  return [stripInlineMd(item), ""];
};

const classifySection = (titleRaw: string) => {
  const t = titleRaw.toLowerCase();
  if (/(vorteile?[\s\S]*nachteile?|nachteile?[\s\S]*vorteile?|pro[\s\S]*kontra|soll[\s\S]*haben)/.test(t)) return "proscons";
  if (/(für wen|geeignet|zielgruppe|passt zu)/.test(t)) return "fit";
  if (/(einsatz|szenarien|anwendung|use ?case|praxis|beispiele|workflow)/.test(t)) return "cases";
  if (/(funktion|features|leistung)/.test(t)) return "features";
  if (/(faq|häufige fragen|^fragen)/.test(t)) return "faq";
  if (/(einschätzung|fazit|verdikt|bewertung|empfehlung|urteil)/.test(t)) return "closing";
  if (/(datenschutz|privacy|sicherheit|daten)/.test(t)) return "privacy";
  if (/(preis|kosten|pricing|tarif)/.test(t)) return "pricing";
  return "body";
};

const KICKERS: Record<string, string> = {
  intro: "Position im Markt",
  body: "Hintergrund",
  fit: "Zielprofile · Eignung",
  cases: "Aus der Redaktionspraxis",
  features: "Funktionsumfang",
  proscons: "Bilanz · Soll & Haben",
  privacy: "Datenschutz · Regeln",
  pricing: "Preise · Kosten",
  closing: "Redaktionelle Einschätzung",
  faq: "Häufige Fragen",
};

type AkteSection = Record<string, any> & { type: string; num: string; title: string; kicker: string };
const sections: AkteSection[] = [];
let secCounter = 0;
const nextNum = () => `§ ${String(++secCounter).padStart(2, "0")}`;
const pushBody = (title: string, kicker: string, body: string) =>
  sections.push({ type: "body", num: nextNum(), title, kicker, html: mdToHtml(body) });

if (introMd) {
  sections.push({
    type: "intro",
    num: nextNum(),
    title: "Was es ist",
    kicker: KICKERS.intro,
    html: mdToHtml(introMd),
  });
}

for (const sec of rawSecs) {
  const type = classifySection(sec.title);
  if (type === "proscons") {
    const prosBlock = (sec.body.match(/###\s*Vorteile[\s\S]*?(?=\n###|$)/i) || [""])[0];
    const consBlock = (sec.body.match(/###\s*Nachteile[\s\S]*?(?=\n###|$)/i) || [""])[0];
    const pros = splitBullets(prosBlock).map(stripInlineMd);
    const cons = splitBullets(consBlock).map(stripInlineMd);
    if (!pros.length && !cons.length) { pushBody(sec.title, KICKERS.body, sec.body); continue; }
    sections.push({ type: "proscons", num: nextNum(), title: sec.title, kicker: KICKERS.proscons, pros, cons });
  } else if (type === "fit") {
    const bullets = splitBullets(sec.body);
    const lead = leadOf(sec.body);
    const items = bullets.map((b) => {
      const m = b.match(/^(.{2,52}?)[,–—:]\s+([\s\S]+)$/);
      return m ? { who: stripInlineMd(m[1]), note: stripInlineMd(m[2]), ok: true } : { who: stripInlineMd(b), note: "", ok: true };
    });
    const neg = sec.body.match(/(weniger\s+(?:passend|geeignet|gut)[\s\S]*?)(?:\n\s*\n|$)/i);
    if (neg) {
      const note = stripInlineMd(neg[1].replace(/^weniger\s+(?:passend|geeignet|gut)\s*(?:ist[^,.:]*)?[,.:]?\s*/i, ""));
      if (note) items.push({ who: "Weniger geeignet", note, ok: false });
    }
    if (!items.length) { pushBody(sec.title, KICKERS.body, sec.body); continue; }
    sections.push({ type: "fit", num: nextNum(), title: sec.title, kicker: KICKERS.fit, lead, items });
  } else if (type === "cases" || type === "features") {
    const pairs = splitBullets(sec.body).map(parsePair).filter((p) => p[0]);
    const lead = leadOf(sec.body);
    if (pairs.length < 2) { pushBody(sec.title, KICKERS[type] ?? KICKERS.body, sec.body); continue; }
    sections.push({ type, num: nextNum(), title: sec.title, kicker: KICKERS[type], lead, pairs });
  } else if (type === "faq") {
    const items: { q: string; a: string }[] = [];
    const re = /\*\*\s*(.+?)\s*\*\*\s*\n+([\s\S]*?)(?=\n\s*\*\*|\n##|$)/g;
    let m: RegExpExecArray | null;
    while ((m = re.exec(sec.body))) {
      const q = stripInlineMd(m[1]);
      const a = stripInlineMd(m[2]);
      if (q && a) items.push({ q, a });
    }
    if (!items.length) { pushBody(sec.title, KICKERS.body, sec.body); continue; }
    sections.push({ type: "faq", num: nextNum(), title: sec.title, kicker: KICKERS.faq, items });
  } else if (type === "closing") {
    const quote = stripInlineMd(sec.body.split(/\n\s*\n/)[0] || sec.body);
    if (!quote) continue;
    sections.push({ type: "closing", num: nextNum(), title: sec.title, kicker: KICKERS.closing, quote });
  } else {
    pushBody(sec.title, KICKERS[type] ?? KICKERS.body, sec.body);
  }
}

const closingIdx = sections.findIndex((s) => s.type === "closing");
const prosForTldr: string[] = (sections.find((s) => s.type === "proscons")?.pros ?? []).slice(0, 3);
const useEditorial = isCuratedTool && introMd.length > 40 && sections.length >= 3;

// Verdict stamp (only rendered when the frontmatter carries an explicit verdict).
const VERDICTS: Record<string, { glyph: string; color: string; label: string }> = {
  EMPFEHLEN: { glyph: "✔", color: "var(--akte-green)", label: "Empfehlen" },
  BEDINGT: { glyph: "◐", color: "var(--akte-amber)", label: "Bedingt" },
  NICHT: { glyph: "✕", color: "var(--akte-vermillion)", label: "Nicht empfohlen" },
  UEBERBEWERTET: { glyph: "⊘", color: "var(--akte-purple)", label: "Überbewertet" },
  ABWARTEN: { glyph: "◷", color: "#5a6068", label: "Abwarten" },
};
const verdictKey = String(data.verdict ?? "").toUpperCase().replace(/[ÜÜ]/g, "UE").trim();
const verdict = VERDICTS[verdictKey] ?? null;
const verdictHead = data.verdict_head ? String(data.verdict_head) : "";
const verdictNuance = data.verdict_nuance ? String(data.verdict_nuance) : "";
const trustVal = Number(data.trust);
const trust = Number.isFinite(trustVal) ? Math.max(0, Math.min(5, Math.round(trustVal))) : null;

// ── Schema.org JSON-LD ─────────────────────────────────────────────────────
const schemaDescription = data.description
  ? String(data.description)
  : data.summary
    ? String(data.summary)
    : data.excerpt
      ? String(data.excerpt)
      : getExcerpt(renderedContent) || `${title} - Informationen, Features und Anwendungsfälle`;

const metaDescription = schemaDescription.length > 160
  ? `${schemaDescription.slice(0, 157).trimEnd()}...`
  : schemaDescription;
const featureList = extractFeatureList(renderedContent);
const faqSchema = isCuratedTool
  ? buildFaqPageSchema(extractFaqPairsFromMarkdown(renderedContent))
  : null;
const schemaCategory = mapToolCategoryToSchemaCategory(category, tags);
const schemaOffer = buildOfferFromPriceModel(price_model);
const canonicalUrl = `${SITE_URL}/tools/${slug}/`;
const lastmodKey = `content/tools/${slug}.md`;
const checkedDateSource =
  data.lastReviewed ||
  data.last_reviewed ||
  data.lastReviewedAt ||
  data.last_reviewed_at ||
  (toolQuality.tier === "A" ? contentLastmod[lastmodKey] : "");
const checkedDate = checkedDateSource
  ? new Intl.DateTimeFormat("de-DE", {
      day: "2-digit",
      month: "long",
      year: "numeric",
    }).format(new Date(String(checkedDateSource)))
  : "";
const generatedAtSource =
  contentLastmod[lastmodKey] ||
  data.generatedAt ||
  data.generated_at ||
  data.created_at ||
  data.createdAt ||
  data.date;
const generatedAt = generatedAtSource
  ? new Intl.DateTimeFormat("de-DE", {
      day: "2-digit",
      month: "long",
      year: "numeric",
    }).format(new Date(String(generatedAtSource)))
  : "";
const breadcrumbSchema = buildBreadcrumbSchema([
  { name: "Startseite", url: `${SITE_URL}/` },
  { name: "Tools", url: `${SITE_URL}/tools/` },
  { name: title, url: canonicalUrl },
]);

const softwareApplicationSchema = {
  "@context": "https://schema.org",
  "@type": ["SoftwareApplication", "WebApplication"],
  "name": title,
  "description": schemaDescription.slice(0, 500),
  "url": canonicalUrl,
  "mainEntityOfPage": canonicalUrl,
  "operatingSystem": "Web",
  "applicationCategory": schemaCategory,
  "applicationSubCategory": category || undefined,
  "inLanguage": SITE_LANGUAGE,
  "keywords": tags.length ? tags.join(", ") : undefined,
  "featureList": featureList.length ? featureList : undefined,
  "isAccessibleForFree": ["Kostenlos", "Freemium", "Open Source"].includes(String(price_model ?? "")),
  "publisher": buildPublisherOrganization(),
  "image": logoUrl ? toAbsoluteUrl(logoUrl) : undefined,
  "offers": schemaOffer,
  "about": tags.length ? tags.map((tag) => ({ "@type": "Thing", "name": tag })) : undefined,
  ...(official_url && official_url.startsWith("http") && { "sameAs": official_url })
};
---

<BaseLayout
  title={`${title} — Utildesk`}
  description={metaDescription}
  robots={searchIndexDecision.robots}
  googlebotRobots={searchIndexDecision.googlebotRobots}
>
  <Fragment slot="head">
    <link rel="canonical" href={canonicalUrl} />
    <link rel="alternate" type="application/json" href={`/api/tools/${slug}.json`} title={`${title} (JSON)`} />
    <link rel="alternate" type="text/markdown" href={`/markdown/tools/${slug}.md`} title={`${title} (Markdown)`} />
    {isCuratedTool ? <script type="application/ld+json" set:html={JSON.stringify(softwareApplicationSchema)} /> : null}
    <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
    {faqSchema ? <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} /> : null}
  </Fragment>

  <div class="tool-akte">
    <!-- Breadcrumb -->
    <nav class="akte-crumb" aria-label="Breadcrumb">
      <a href="/tools/">← Tool-Index</a>
      {primaryCategory && (
        <Fragment>
          <span class="akte-crumb-sep">/</span>
          <a href={`/category/${primaryCategory.slug}/`}>{primaryCategory.title}</a>
        </Fragment>
      )}
      <span class="akte-crumb-sep">/</span>
      <span class="akte-crumb-current">{title}</span>
    </nav>

    <!-- Editorial Masthead -->
    <header class="akte-mast">
      <div class="akte-mast-body">
        <div class="akte-mast-kicker">
          ↳ Tool-Akte{category ? ` · ${category}` : ""}
        </div>

        <h1 class="akte-mast-h1">{title}<span class="akte-mast-dot">.</span></h1>

        {oneliner && (
          <p class="akte-mast-oneliner">{oneliner}</p>
        )}

        {(category || price_model || displayTags.length > 0) && (
          <div class="akte-chips">
            {category && primaryCategory ? (
              <a class="akte-chip akte-chip-category" href={`/category/${primaryCategory.slug}/`}>{category}</a>
            ) : category ? (
              <span class="akte-chip akte-chip-category">{category}</span>
            ) : null}
            {price_model && (
              <span class="akte-chip akte-chip-price">{price_model}</span>
            )}
            {displayTags.map((tag) => (
              <a class="akte-chip akte-chip-tag" href={tagHref(tag)}>#{tag}</a>
            ))}
          </div>
        )}

        {(target_provider_url || providerDomain) && (
          <div class="akte-actions">
            {target_provider_url && (
              <a
                class="akte-action akte-action-primary"
                href={target_provider_url}
                target="_blank"
                rel="noopener noreferrer"
              >
                ↗ Zum Anbieter{providerDomain ? ` · ${providerDomain}` : ""}
              </a>
            )}
            <a class="akte-action akte-action-ghost" href="/tools/">
              ⇄ Zurück zum Index
            </a>
          </div>
        )}
      </div>

      <!-- Faktenblatt sidebar -->
      <aside class="akte-faktenblatt" aria-label="Faktenblatt">
        <div class="akte-faktenblatt-tab">Faktenblatt</div>

        <div class="akte-faktenblatt-head">
          <span class="akte-monogram" aria-hidden="true">
            {logoUrl ? (
              <img
                src={logoUrl}
                alt=""
                loading="lazy"
                data-fallback-srcs={logoFallbacks.length ? JSON.stringify(logoFallbacks) : undefined}
              />
            ) : (
              monogramLetter
            )}
          </span>
          <div class="akte-faktenblatt-vendor">
            <div class="akte-faktenblatt-vendor-name">{vendorName}</div>
            {providerDomain && (
              <div class="akte-faktenblatt-vendor-domain">{providerDomain}</div>
            )}
          </div>
        </div>

        {(category || price_model) && (
          <Fragment>
            {category && (
              <div class="akte-faktenblatt-row">
                <span class="akte-faktenblatt-key">Kategorie</span>
                <span class="akte-faktenblatt-val">{category}</span>
              </div>
            )}
            {price_model && (
              <div class="akte-faktenblatt-row">
                <span class="akte-faktenblatt-key">Preismodell</span>
                <span class="akte-faktenblatt-val">{price_model}</span>
              </div>
            )}
            <div class="akte-faktenblatt-row is-paid">
              <span class="akte-faktenblatt-key">Bezahlte Platzierung</span>
              <span class="akte-faktenblatt-val">nein</span>
            </div>
          </Fragment>
        )}

        {(lastCheckedShort || inIndexSinceShort || mentionedInCount > 0) && (
          <Fragment>
            <hr class="akte-faktenblatt-divider" />
            <div class="akte-faktenblatt-foot">
              {lastCheckedShort && (
                <div>
                  <span class="akte-faktenblatt-key">Zuletzt geprüft</span>
                  <span>{lastCheckedShort}</span>
                </div>
              )}
              {inIndexSinceShort && (
                <div>
                  <span class="akte-faktenblatt-key">Im Index seit</span>
                  <span>{inIndexSinceShort}</span>
                </div>
              )}
              {mentionedInCount > 0 && (
                <div>
                  <span class="akte-faktenblatt-key">Verwendet in</span>
                  <span>{mentionedInCount} Ratgebern</span>
                </div>
              )}
            </div>
          </Fragment>
        )}
      </aside>
    </header>

    {isCuratedTool ? (
      <p class="editorial-note">
        Kuratiert von <strong>Utildesk Redaktion</strong>
        {checkedDate ? <span> · zuletzt geprüft: {checkedDate}</span> : null}
        <span> · <a href="/methodologie/">Methodologie</a></span>
      </p>
    ) : (
      <p class="editorial-note">
        Eintrag automatisch erstellt aus öffentlichen Quellen{generatedAt ? <span> · Stand: {generatedAt}</span> : null}
        <span> · <a href="/methodologie/">Methodologie</a></span>
      </p>
    )}

    {verdict && (
      <section class="akte-verdict-wrap" aria-labelledby="verdict-h">
        <div class="akte-verdict">
          <div class="akte-verdict-tab">Verdikt der Redaktion</div>
          <div class="akte-verdict-glyph" style={`color:${verdict.color}`} aria-hidden="true">{verdict.glyph}</div>
          <div class="akte-verdict-mid">
            <div class="akte-verdict-label" style={`color:${verdict.color}`}>{verdict.label}</div>
            <h2 id="verdict-h" class="akte-verdict-head">{verdictHead || verdict.label}</h2>
            {verdictNuance && <p class="akte-verdict-nuance">{verdictNuance}</p>}
          </div>
          {trust !== null && (
            <div class="akte-verdict-trust" role="img" aria-label={`Vertrauen: ${trust} von 5`}>
              <div class="akte-verdict-trust-title">VERTRAUEN</div>
              <div class="akte-trust-bars" aria-hidden="true">
                {[1, 2, 3, 4, 5].map((i) => (
                  <span class={`akte-trust-bar ${i <= trust ? "is-on" : ""}`}></span>
                ))}
              </div>
              <div>{trust} / 5 · {trust >= 4 ? "hoch" : trust >= 2 ? "mittel" : "niedrig"}</div>
            </div>
          )}
        </div>
      </section>
    )}

    {oneliner && (
      <section class="akte-tldr" aria-label="TL;DR">
        <div class="akte-tldr-aside">
          <span class="akte-tldr-kicker">In 60 Sek.</span>
          <span class="akte-tldr-title">TL;DR<span class="akte-mast-dot">.</span></span>
        </div>
        <div class="akte-tldr-body">
          <p>{oneliner}</p>
          {prosForTldr.length > 0 && (
            <ul class="akte-tldr-list">
              {prosForTldr.map((item) => <li>{item}</li>)}
            </ul>
          )}
          {category && (
            <p class="akte-tldr-meta">
              Kategorie: <strong>{category}</strong>
              {price_model ? <span> · Preis: <strong>{price_model}</strong></span> : null}
              {providerDomain ? <span> · {providerDomain}</span> : null}
            </p>
          )}
        </div>
      </section>
    )}
  </div>

  <!-- Article Content -->
  {useEditorial ? (
    <article class="tool-akte akte-doc" aria-label={`Tool-Akte ${title}`}>
      {sections.map((sec, i) => (
        <Fragment>
          {i === closingIdx && schlussbildSrc && (
            <figure class="akte-schlussbild">
              <div class="akte-schlussbild-head">
                <div>
                  <div class="akte-schlussbild-kicker">↳ Schlussbild</div>
                  <div class="akte-schlussbild-title">Eine Pause, bevor die Redaktion spricht.</div>
                </div>
                <div class="akte-schlussbild-meta">Bild · Redaktion · 2026</div>
              </div>
              <div class="akte-schlussbild-slot">
                <img src={schlussbildSrc} alt={schlussbildAlt} loading="lazy" decoding="async" />
              </div>
              <figcaption class="akte-schlussbild-cap">
                <span class="akte-schlussbild-cap-text">
                  <span class="akte-schlussbild-cap-fig">Abbildung 1</span>{schlussbildAlt}
                </span>
                <span class="akte-schlussbild-cap-meta">{title} · Editorial</span>
              </figcaption>
            </figure>
          )}

          <section class={`akte-sec akte-sec-${sec.type}`}>
            <div class="akte-sec-marg">
              <div class="akte-sec-num" aria-hidden="true">{sec.num}</div>
              <div class="akte-sec-kicker">{sec.kicker}</div>
            </div>
            <div class="akte-sec-body">
              <h2 class="akte-sec-title">{sec.title}</h2>

              {(sec.type === "intro" || sec.type === "body") && (
                <div
                  class={`akte-prose ${sec.type === "intro" ? "akte-prose-drop" : ""}`}
                  set:html={sec.html}
                ></div>
              )}

              {sec.type === "fit" && (
                <Fragment>
                  {sec.lead && <p class="akte-sec-lead">{sec.lead}</p>}
                  <div class="akte-fit">
                    {sec.items.map((it: any) => (
                      <div class="akte-fit-row">
                        <span class={`akte-fit-mark ${it.ok ? "is-ok" : "is-no"}`} aria-hidden="true">{it.ok ? "✔" : "✕"}</span>
                        <span class="akte-fit-who">{it.who}</span>
                        <span class="akte-fit-note">{it.note}</span>
                      </div>
                    ))}
                  </div>
                </Fragment>
              )}

              {sec.type === "cases" && (
                <Fragment>
                  {sec.lead && <p class="akte-sec-lead">{sec.lead}</p>}
                  <div class="akte-cases">
                    {sec.pairs.map((p: [string, string], idx: number) => (
                      <div class="akte-case">
                        <div class="akte-case-head">
                          <span class="akte-case-num">{String(idx + 1).padStart(2, "0")}</span>
                          <span class="akte-case-title">{p[0]}</span>
                        </div>
                        {p[1] && <p class="akte-case-blurb">{p[1]}</p>}
                      </div>
                    ))}
                  </div>
                </Fragment>
              )}

              {sec.type === "features" && (
                <Fragment>
                  {sec.lead && <p class="akte-sec-lead">{sec.lead}</p>}
                  <div class="akte-feat">
                    <div class="akte-feat-head"><span>Funktion</span><span>Was es bedeutet</span></div>
                    {sec.pairs.map((p: [string, string]) => (
                      <div class="akte-feat-row">
                        <span class="akte-feat-name">{p[0]}</span>
                        <span class="akte-feat-mean">{p[1]}</span>
                      </div>
                    ))}
                  </div>
                </Fragment>
              )}

              {sec.type === "proscons" && (
                <div class="akte-bilanz">
                  <div class="akte-bilanz-col akte-bilanz-pro">
                    <div class="akte-bilanz-head">✔ Haben — was funktioniert</div>
                    <ul aria-label="Was funktioniert">{sec.pros.map((x: string) => <li>{x}</li>)}</ul>
                  </div>
                  <div class="akte-bilanz-col akte-bilanz-con">
                    <div class="akte-bilanz-head">✕ Soll — was Sie wissen müssen</div>
                    <ul aria-label="Was Sie wissen müssen">{sec.cons.map((x: string) => <li>{x}</li>)}</ul>
                  </div>
                </div>
              )}

              {sec.type === "closing" && (
                <blockquote class="akte-closing">
                  <p>„{sec.quote}“</p>
                  <div class="akte-closing-attr">— Die Redaktion{lastCheckedShort ? ` · letzte Prüfung ${lastCheckedShort}` : ""}</div>
                </blockquote>
              )}

              {sec.type === "faq" && (
                <div class="akte-faq">
                  {sec.items.map((it: any, idx: number) => (
                    <div class="akte-faq-row">
                      <span class="akte-faq-num">F.{String(idx + 1).padStart(2, "0")}</span>
                      <div class="akte-faq-qa">
                        <h3 class="akte-faq-q">{it.q}</h3>
                        <p class="akte-faq-a">{it.a}</p>
                      </div>
                    </div>
                  ))}
                </div>
              )}
            </div>
          </section>
        </Fragment>
      ))}

      {closingIdx === -1 && schlussbildSrc && (
        <figure class="akte-schlussbild">
          <div class="akte-schlussbild-head">
            <div>
              <div class="akte-schlussbild-kicker">↳ Schlussbild</div>
              <div class="akte-schlussbild-title">Eine Pause, bevor die Redaktion spricht.</div>
            </div>
            <div class="akte-schlussbild-meta">Bild · Redaktion · 2026</div>
          </div>
          <div class="akte-schlussbild-slot">
            <img src={schlussbildSrc} alt={schlussbildAlt} loading="lazy" decoding="async" />
          </div>
        </figure>
      )}
    </article>
  ) : (
    <article class="card article akte-article">
      <div class="article-body akte-article-body">
        {!isCuratedTool ? (
          <blockquote class="tool-disclosure">
            Dieser Eintrag wurde automatisch aus öffentlichen Anbieterinformationen erstellt und nicht redaktionell geprüft.
            Für eine kuratierte Einordnung siehe unsere <a href="/ratgeber/">Ratgeber</a>.
          </blockquote>
        ) : null}
        <div set:html={articleHtml}></div>
      </div>
    </article>
  )}

  <!-- Verwandte Akten / Alternatives — editorial dossier card grid -->
  {alternativesTop.length > 0 && (
    <section class="akte-alts tool-akte" aria-label="Verwandte Akten">
      <div class="akte-alts-head">
        <div class="akte-alts-head-left">
          <div class="akte-alts-kicker">↳ Verwandte Akten</div>
          <h2 class="akte-alts-title">
            Vergleichbare Werkzeuge<span class="akte-mast-dot">.</span>
          </h2>
        </div>
        <a class="akte-alts-all" href="/tools/">↳ alle Akten</a>
      </div>
      <div class="akte-alts-grid">
        {alternativesTop.map((tool, i) => {
          const altMonogram = (tool.title || "·")
            .replace(/[^A-Za-zÄÖÜäöü]/g, "")
            .charAt(0)
            .toUpperCase() || "·";
          return (
            <a
              href={`/tools/${tool.slug}/`}
              class="akte-alt-card"
            >
              <div class="akte-alt-card-head">
                <span class="akte-alt-card-kicker">
                  Alternative {String(i + 1).padStart(2, "0")}
                </span>
                <span class="akte-alt-card-mono" aria-hidden="true">
                  {tool.iconUrl ? (
                    <img
                      src={tool.iconUrl}
                      alt=""
                      loading="lazy"
                      data-fallback-srcs={tool.iconFallbacks.length ? JSON.stringify(tool.iconFallbacks) : undefined}
                    />
                  ) : (
                    altMonogram
                  )}
                </span>
              </div>
              <div class="akte-alt-card-name">
                {tool.title}<span class="akte-mast-dot">.</span>
              </div>
              <p class="akte-alt-card-tone">
                {tool.excerpt || "Kurzbeschreibung folgt."}
              </p>
              <div class="akte-alt-card-foot">
                <span class="akte-alt-card-meta">
                  {[tool.category, tool.price_model].filter(Boolean).join(" · ")}
                </span>
                <span class="akte-alt-card-open">Akte öffnen ↗</span>
              </div>
            </a>
          );
        })}
      </div>
    </section>
  )}

  <div class="tool-akte">
    <aside class="akte-colophon" aria-label="Colophon">
      <span><span class="akte-colophon-key">Akte</span>{vendorName ? ` ${vendorName}` : ` ${title}`}</span>
      <span><span class="akte-colophon-key">Status</span> {isCuratedTool ? "kuratiert" : "automatisch"}</span>
      {lastCheckedShort && (
        <span><span class="akte-colophon-key">Letzte Prüfung</span> {lastCheckedShort}</span>
      )}
      <span><span class="akte-colophon-key">Daten</span> <a href={`/api/tools/${slug}.json`}>/api/tools/{slug}.json</a></span>
      <span><span class="akte-colophon-key">Lizenz</span> CC BY-NC 4.0</span>
      <span class="akte-colophon-paid">0 bezahlte Platzierungen</span>
    </aside>
  </div>
</BaseLayout>

<style>
  /* editorial-note used under the masthead — kept here so it inherits
     the Astro-scoped data attribute and does not need a global rule. */
  .editorial-note {
    margin: 14px 0 0;
    font-family: var(--mono);
    color: var(--fg-3);
    font-size: 0.78rem;
    line-height: 1.6;
    letter-spacing: 0.04em;
  }

  .editorial-note a {
    color: var(--accent);
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  /* .akte-alts-* live in global.css under the .tool-akte scope. */
</style>
