---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { CATEGORIES } from "../../lib/categories";
import { readdir, readFile } from "node:fs/promises";
import { join } from "node:path";
import matter from "gray-matter";
import { fromContent } from "../../lib/contentRoot.mjs";
import {
  buildBreadcrumbSchema,
  buildCollectionPageSchema,
  SITE_URL,
} from "../../lib/siteMeta";

// Count tools per category
const toolsDir = fromContent("tools");
const files = (await readdir(toolsDir)).filter((f) => f.endsWith(".md") && !f.startsWith("_"));

const toolsData = await Promise.all(
  files.map(async (file) => {
    const raw = await readFile(join(toolsDir, file), "utf-8");
    const { data } = matter(raw);
    const disabled = data.disabled === true || String(data.disabled || "").toLowerCase() === "true";
    if (disabled) return null;
    const tags = Array.isArray(data.tags) ? data.tags.map(String).map((t) => t.toLowerCase()) : [];
    return { tags };
  })
);

const enabledTools = toolsData.filter(Boolean);

const categoriesWithCount = CATEGORIES.map((cat) => {
  const count = enabledTools.filter((tool) =>
    tool.tags.some((tag) => cat.matchTags.includes(tag))
  ).length;
  return { ...cat, count };
});
const categoryItemListSchema = {
  "@context": "https://schema.org",
  "@type": "ItemList",
  name: "Utildesk Kategorien",
  numberOfItems: categoriesWithCount.length,
  itemListElement: categoriesWithCount.map((category, index) => ({
    "@type": "ListItem",
    position: index + 1,
    name: category.title,
    url: `${SITE_URL}/category/${category.slug}/`,
  })),
};
const categoryCollectionSchema = buildCollectionPageSchema({
  name: "Tool-Kategorien",
  description: "Entdecke AI-Tools nach Kategorien organisiert.",
  url: `${SITE_URL}/category/`,
  about: ["AI-Tools", "Kategorien", "Produktivität"],
  mainEntity: categoryItemListSchema,
});
const categoryBreadcrumbSchema = buildBreadcrumbSchema([
  { name: "Startseite", url: `${SITE_URL}/` },
  { name: "Kategorien", url: `${SITE_URL}/category/` },
]);
---

<BaseLayout
  title="Kategorien — Utildesk"
  description="Entdecke AI-Tools nach Kategorien organisiert."
>
  <Fragment slot="head">
    <link rel="canonical" href="https://tools.utildesk.de/category/" />
    <script type="application/ld+json" set:html={JSON.stringify(categoryCollectionSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(categoryItemListSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(categoryBreadcrumbSchema)} />
  </Fragment>

  <section class="category-index">
    <div class="category-shell">
      <h1 class="page-title">Tool-Kategorien</h1>
      <p class="page-intro">
        Finde AI-Tools nach Kategorien sortiert. Jede Kategorie gruppiert Tools mit ähnlichen Funktionen.
      </p>

      <div class="category-grid">
        {categoriesWithCount.map((cat) => (
          <a href={`/category/${cat.slug}/`} class="card tool-card category-card">
            <div class="category-card-top">
              <span class="badge badge-category category-chip">Kategorie</span>
              <span class="category-count">{cat.count} {cat.count === 1 ? "Tool" : "Tools"}</span>
            </div>
            <div class="category-card-body">
              <h2 class="category-title">{cat.title}</h2>
              <p class="category-description">{cat.description}</p>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .category-index {
    padding: 32px 0 64px;
  }

  .category-shell {
    background: var(--surface-container-low);
    border: 1px solid rgba(190, 201, 197, 0.2);
    border-radius: var(--radius-lg);
    padding: 28px;
    box-shadow: var(--shadow-card);
  }

  .page-title {
    font-size: clamp(1.9rem, 4vw, 2.8rem);
    font-weight: 800;
    letter-spacing: -0.03em;
    margin: 0 0 14px;
    color: var(--on-surface);
  }

  .page-intro {
    font-size: 1.02rem;
    line-height: 1.7;
    color: var(--text-muted);
    margin: 0 0 32px;
    max-width: 680px;
  }

  .category-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: var(--space-5);
  }

  .category-card {
    min-height: 200px;
    gap: var(--space-4);
    justify-content: space-between;
  }

  .category-card-top {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-3);
    flex-wrap: wrap;
  }

  .category-chip {
    background: var(--surface-container-high);
  }

  .category-count {
    display: inline-flex;
    align-items: center;
    padding: 4px 11px;
    border-radius: var(--radius-full);
    font-size: 0.77rem;
    font-weight: 700;
    letter-spacing: 0.03em;
    text-transform: uppercase;
    color: var(--primary);
    background: rgba(23, 98, 89, 0.08);
    border: 1px solid rgba(23, 98, 89, 0.14);
  }

  .category-card-body {
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .category-title {
    font-size: 1.2rem;
    font-weight: 700;
    color: var(--on-surface);
    margin: 0;
    letter-spacing: -0.02em;
  }

  .category-description {
    font-size: 0.94rem;
    line-height: 1.6;
    color: var(--text-muted);
    margin: 0;
  }

  :root[data-theme="dark"] .category-shell {
    background: var(--surface-container);
    border-color: rgba(139, 152, 145, 0.18);
  }

  @media (max-width: 720px) {
    .category-index {
      padding: 16px 0 48px;
    }

    .category-shell {
      padding: 20px;
    }

    .category-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
