---
import BaseLayout from "../layouts/BaseLayout.astro";
import { readdir, readFile } from "node:fs/promises";
import { join } from "node:path";
import matter from "gray-matter";
import { resolveLocalLogo } from "../lib/resolveLogoPath";
import { getAvatarFallbackDataUrl, getFaviconCandidates } from "../lib/favicon";

const toolsDir = join(process.cwd(), "content", "tools");
const files = (await readdir(toolsDir))
  .filter((f) => f.endsWith(".md") && !f.startsWith("_"));

const stripMarkdown = (text: string) =>
  text
    .replace(/!\[[^\]]*\]\([^)]*\)/g, "")
    .replace(/\[[^\]]*\]\([^)]*\)/g, "$1")
    .replace(/[`*_>#-]/g, "")
    .replace(/\s+/g, " ")
    .trim();

const getExcerpt = (content: string) => {
  const paragraphs = content.split(/\n\s*\n/);
  for (const paragraph of paragraphs) {
    if (paragraph.trim().startsWith("#")) continue;
    const cleaned = stripMarkdown(paragraph);
    if (cleaned) return cleaned;
  }
  return "";
};

const getImageFromContent = (content: string) => {
  const match = content.match(/!\[[^\]]*\]\(([^)]+)\)/);
  if (!match?.[1]) return null;
  return match[1].trim();
};

const normalizeImagePath = (path: string | null) => {
  if (!path) return null;
  if (path.startsWith("http://") || path.startsWith("https://")) return path;
  if (path.startsWith("/")) return path;
  return `/${path}`;
};

const resolveCategoryIcon = (category: string | null, tags: string[]) => {
  const normalizedCategory = category ? category.toLowerCase() : "";
  const normalizedTags = tags.map((tag) => tag.toLowerCase());
  const combined = [normalizedCategory, ...normalizedTags].join(" ");

  if (combined.includes("design") || combined.includes("ui") || combined.includes("ux")) return "design";
  if (combined.includes("automation") || combined.includes("workflow")) return "automation";
  if (combined.includes("ai") || combined.includes("ml") || combined.includes("machine")) return "ai";
  return "generic";
};

const tools = await Promise.all(
  files.map(async (file) => {
    const full = join(toolsDir, file);
    const raw = await readFile(full, "utf-8");
    const { data, content } = matter(raw);
    const disabled = data.disabled === true || String(data.disabled || "").toLowerCase() === "true";
    if (disabled) return null;

    const slug = String(data.slug ?? file.replace(/\.md$/, ""));
    const title = String(data.title ?? slug);
    const category = data.category ? String(data.category) : null;
    const affiliateUrl = data.affiliate_url ? String(data.affiliate_url) : null;
    const officialUrl = data.official_url ? String(data.official_url) : null;
    const image = data.image ? String(data.image) : null;
    const homeImage = data.homeImage ? String(data.homeImage) : null;
    const brandLogo = data.brandLogo ? String(data.brandLogo) : null;
    const icon = data.icon ? String(data.icon) : null;
    const priceModel = data.price_model ? String(data.price_model) : null;
    const tags = Array.isArray(data.tags) ? data.tags.map(String) : [];
    const description = data.description
      ? String(data.description)
      : data.summary
        ? String(data.summary)
        : data.excerpt
          ? String(data.excerpt)
          : "";
    const excerpt = description || getExcerpt(content);
    const contentImage = getImageFromContent(content);
    const localLogoPath = resolveLocalLogo(slug);
    const providerUrl = affiliateUrl || officialUrl;
    const faviconCandidates = getFaviconCandidates(providerUrl, 128);
    const faviconLogo = faviconCandidates[0] ?? null;
    const homeCardLogo = normalizeImagePath(brandLogo) ?? localLogoPath ?? faviconLogo;
    const homeCardLogoFallbacks = normalizeImagePath(brandLogo) || localLogoPath || !faviconLogo
      ? []
      : [...faviconCandidates.slice(1), getAvatarFallbackDataUrl(title)];
    const homeCardImage = normalizeImagePath(homeImage ?? image ?? icon ?? contentImage);

    return {
      slug,
      title,
      category,
      priceModel,
      tags,
      excerpt,
      homeCardImage,
      homeCardLogo,
      homeCardLogoFallbacks,
      fallbackIcon: resolveCategoryIcon(category, tags),
      popularity: data.popularity ? Number(data.popularity) : 0,
    };
  })
);

const enabledTools = tools.filter(Boolean);
enabledTools.sort((a, b) => a.title.localeCompare(b.title, "de"));

const tagFrequency = new Map<string, number>();
enabledTools.forEach((tool) => {
  tool.tags.forEach((tag) => {
    tagFrequency.set(tag, (tagFrequency.get(tag) || 0) + 1);
  });
});

const sortedTags = Array.from(tagFrequency.entries())
  .sort((a, b) => {
    if (b[1] !== a[1]) return b[1] - a[1];
    return a[0].localeCompare(b[0], "de");
  });

const visibleTags = sortedTags.filter(([, count]) => count >= 3).slice(0, 7);

const pinnedSlugs = ["chatgpt", "claude", "midjourney", "perplexity", "zapier", "notion-ai", "vercel-ai"];
const enabledBySlug = new Map(enabledTools.map((tool) => [tool.slug, tool]));
const pinnedTools = pinnedSlugs.map((slug) => enabledBySlug.get(slug)).filter(Boolean);
const pinnedSlugSet = new Set(pinnedSlugs);
const restTools = enabledTools.filter((tool) => !pinnedSlugSet.has(tool.slug));

restTools.sort(
  (a, b) =>
    (b.popularity ?? 0) - (a.popularity ?? 0) ||
    a.title.localeCompare(b.title, "de")
);

const latestTools = [...pinnedTools, ...restTools].slice(0, 6);
const heroTitleMain = "Tools & Guides f\u00fcr AI,";
const heroTitleAccent = "Automatisierung";
const heroTitleTail = "und Produktivit\u00e4t.";
---

<BaseLayout
  title={"Utildesk - Tools & Guides f\u00fcr AI und Produktivit\u00e4t"}
  description={"Kuratiertes Verzeichnis n\u00fctzlicher AI- und Produktivit\u00e4tstools."}
>
  <Fragment slot="head">
    <link rel="canonical" href="https://tools.utildesk.de/" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=Plus+Jakarta+Sans:wght@500;700;800&display=swap" rel="stylesheet" />
  </Fragment>

  <style>
    .stitch-home {
      --surface: #fafaf1;
      --surface-alt: #f4f4e9;
      --surface-card: #ffffff;
      --text: #1a1c17;
      --muted: #5f5e5e;
      --primary: #176259;
      --primary-soft: #367b71;
      --outline: rgba(190, 201, 197, 0.4);
      --shadow: 0 20px 40px rgba(26, 28, 23, 0.04);
      color: var(--text);
      font-family: "Inter", var(--font-sans);
      padding: 24px 0 72px;
    }

    .stitch-home .hero-shell {
      padding: 58px 24px 42px;
      text-align: center;
      background: radial-gradient(circle at top center, rgba(170, 240, 227, 0.14), rgba(170, 240, 227, 0) 42%);
    }

    .stitch-home .hero-title {
      margin: 0 auto 20px;
      max-width: 12ch;
      font-family: "Plus Jakarta Sans", var(--font-sans);
      font-size: clamp(3.4rem, 7.2vw, 5.8rem);
      line-height: 1.02;
      letter-spacing: -0.06em;
      font-weight: 800;
    }

    .stitch-home .hero-accent {
      color: var(--primary);
      font-style: italic;
    }

    .stitch-home .hero-subtitle {
      margin: 0 auto 34px;
      max-width: 40rem;
      font-size: 1.23rem;
      line-height: 1.65;
      color: var(--muted);
    }

    .stitch-home .hero-search {
      display: grid;
      grid-template-columns: 1fr auto;
      gap: 16px;
      align-items: center;
      max-width: 680px;
      margin: 0 auto;
      padding: 10px 12px 10px 18px;
      background: rgba(255, 255, 255, 0.58);
      border-radius: 999px;
      box-shadow: 0 10px 32px rgba(26, 28, 23, 0.04);
      backdrop-filter: blur(12px);
    }

    .stitch-home .hero-search-copy {
      display: flex;
      align-items: center;
      gap: 14px;
      min-width: 0;
      color: #8a8a7f;
      font-size: 1rem;
      text-align: left;
    }

    .stitch-home .hero-search-copy svg {
      flex-shrink: 0;
      width: 20px;
      height: 20px;
      color: #8f938a;
    }

    .stitch-home .hero-search-button,
    .stitch-home .tools-button {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      border-radius: 999px;
      background: var(--primary);
      color: #fff;
      font-weight: 700;
      box-shadow: inset 0 0 0 1px rgba(0,0,0,0.08);
    }

    .stitch-home .hero-search-button {
      min-height: 52px;
      padding: 0 26px;
    }

    .stitch-home .chip-band {
      margin: 24px calc(50% - 50vw) 0;
      padding: 28px 24px;
      background: var(--surface-alt);
    }

    .stitch-home .chip-row {
      max-width: 1100px;
      margin: 0 auto;
      display: flex;
      flex-wrap: wrap;
      justify-content: center;
      gap: 12px;
    }

    .stitch-home .chip {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      padding: 11px 18px;
      border-radius: 999px;
      background: var(--surface-card);
      color: var(--text);
      box-shadow: inset 0 0 0 1px rgba(190, 201, 197, 0.55);
      font-size: 0.96rem;
      font-weight: 500;
    }

    .stitch-home .chip:hover {
      opacity: 1;
      transform: translateY(-1px);
    }

    .stitch-home .chip--active {
      background: var(--primary-soft);
      color: #fff;
      box-shadow: none;
    }

    .stitch-home .chip-dot {
      width: 9px;
      height: 9px;
      border-radius: 999px;
      background: currentColor;
      opacity: 0.9;
    }

    .stitch-home .section-shell {
      padding: 58px 0 0;
    }

    .stitch-home .section-head {
      display: flex;
      align-items: end;
      justify-content: space-between;
      gap: 18px;
      margin-bottom: 28px;
      flex-wrap: wrap;
    }

    .stitch-home .section-title {
      margin: 0;
      font-family: "Plus Jakarta Sans", var(--font-sans);
      font-size: clamp(2rem, 4vw, 3rem);
      line-height: 1.05;
      letter-spacing: -0.05em;
      font-weight: 800;
    }

    .stitch-home .section-subtitle {
      margin: 8px 0 0;
      color: var(--muted);
      font-size: 1rem;
    }

    .stitch-home .section-link {
      display: inline-flex;
      align-items: center;
      gap: 10px;
      color: var(--primary);
      font-weight: 700;
      white-space: nowrap;
    }

    .stitch-home .tools-grid {
      display: grid;
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: 26px;
    }

    .stitch-home .tool-card {
      display: flex;
      flex-direction: column;
      min-height: 232px;
      padding: 20px 20px 22px;
      border-radius: 28px;
      background: rgba(255,255,255,0.92);
      box-shadow: var(--shadow);
      color: inherit;
    }

    .stitch-home .tool-card:hover {
      opacity: 1;
      transform: translateY(-3px);
    }

    .stitch-home .tool-logo,
    .stitch-home .tool-fallback {
      width: 56px;
      height: 56px;
      border-radius: 16px;
      display: grid;
      place-items: center;
      background: #f7f7ef;
      box-shadow: inset 0 0 0 1px rgba(190, 201, 197, 0.28);
      overflow: hidden;
      margin-bottom: 22px;
    }

    .stitch-home .tool-logo img {
      width: 32px;
      height: 32px;
      object-fit: contain;
    }

    .stitch-home .tool-fallback svg {
      width: 26px;
      height: 26px;
      color: var(--primary);
    }

    .stitch-home .tool-head {
      display: flex;
      align-items: center;
      gap: 10px;
      flex-wrap: wrap;
      margin-bottom: 10px;
    }

    .stitch-home .tool-title {
      margin: 0;
      font-family: "Plus Jakarta Sans", var(--font-sans);
      font-size: 1.65rem;
      line-height: 1.05;
      letter-spacing: -0.05em;
      font-weight: 700;
    }

    .stitch-home .tool-badge {
      display: inline-flex;
      align-items: center;
      padding: 4px 10px;
      border-radius: 999px;
      background: #ecebe1;
      color: #65655e;
      font-size: 0.68rem;
      font-weight: 700;
      letter-spacing: 0.08em;
      text-transform: uppercase;
    }

    .stitch-home .tool-text {
      margin: 0;
      color: var(--muted);
      line-height: 1.65;
      font-size: 1rem;
      flex-grow: 1;
    }

    .stitch-home .tools-button {
      margin-top: 18px;
      min-height: 52px;
      padding: 0 22px;
      background: #f1eee4;
      color: var(--text);
      box-shadow: none;
    }

    .stitch-home .tool-card:hover .tools-button {
      background: var(--primary);
      color: #fff;
    }

    @media (max-width: 1000px) {
      .stitch-home .tools-grid {
        grid-template-columns: repeat(2, minmax(0, 1fr));
      }
    }

    @media (max-width: 720px) {
      .stitch-home {
        padding-top: 8px;
      }

      .stitch-home .hero-shell {
        padding-left: 0;
        padding-right: 0;
      }

      .stitch-home .hero-search {
        grid-template-columns: 1fr;
        border-radius: 28px;
        padding: 14px;
      }

      .stitch-home .hero-search-button {
        width: 100%;
      }

      .stitch-home .tools-grid {
        grid-template-columns: 1fr;
      }
    }
  </style>

  <div class="stitch-home">
    <section class="hero-shell">
      <h1 class="hero-title">
        {heroTitleMain}<br />
        <span class="hero-accent">{heroTitleAccent}</span><br />
        {heroTitleTail}
      </h1>
      <p class="hero-subtitle">
        Kuratiertes Verzeichnis mit allem, was du f&uuml;r effizientes Arbeiten brauchst.
      </p>
      <div class="hero-search">
        <div class="hero-search-copy">
          <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M10 4a6 6 0 1 0 3.874 10.582l4.272 4.272 1.414-1.414-4.272-4.272A6 6 0 0 0 10 4Zm0 2a4 4 0 1 1 0 8 4 4 0 0 1 0-8Z" fill="currentColor" /></svg>
          <span>Kuratiertes Verzeichnis n&uuml;tzlicher AI- und Produktivit&auml;tstools.</span>
        </div>
        <a href="/tools/" class="hero-search-button">Alle Tools durchsuchen</a>
      </div>
    </section>

    <section class="chip-band">
      <div class="chip-row">
        {visibleTags.map(([tag], index) => (
          <a href={`/tools/?tag=${encodeURIComponent(tag)}`} class={`chip ${index === 0 ? "chip--active" : ""}`}>
            <span class="chip-dot"></span>
            {tag}
          </a>
        ))}
      </div>
    </section>

    <section class="section-shell">
      <div class="section-head">
        <div>
          <h2 class="section-title">Featured Tools</h2>
          <p class="section-subtitle">Eine Auswahl aus unserem Verzeichnis</p>
        </div>
        <a href="/tools/" class="section-link">Alle Tools anzeigen <span aria-hidden="true">&rarr;</span></a>
      </div>

      <div class="tools-grid">
        {latestTools.map((tool) => (
          <a href={`/tools/${tool.slug}/`} class="tool-card">
            {tool.homeCardLogo ? (
              <span class="tool-logo">
                <img src={tool.homeCardLogo} alt={tool.title} loading="lazy" data-fallback-srcs={tool.homeCardLogoFallbacks.length ? JSON.stringify(tool.homeCardLogoFallbacks) : undefined} />
              </span>
            ) : tool.homeCardImage ? (
              <span class="tool-logo">
                <img src={tool.homeCardImage} alt={tool.title} loading="lazy" />
              </span>
            ) : tool.fallbackIcon === "ai" ? (
              <span class="tool-fallback" aria-hidden="true">
                <svg viewBox="0 0 24 24"><path d="M9 3a1 1 0 0 1 1 1v1.1a6.002 6.002 0 0 1 4 0V4a1 1 0 1 1 2 0v2.1a6.002 6.002 0 0 1 3 5.2V13a1 1 0 0 1-1 1h-1.1a6.002 6.002 0 0 1-5.2 3V19a1 1 0 1 1-2 0v-2.1a6.002 6.002 0 0 1-5.2-3H4a1 1 0 0 1-1-1v-1.7a6.002 6.002 0 0 1 3-5.2V4a1 1 0 0 1 2 0v1.1a6.01 6.01 0 0 1 1-.1Zm3 4a4 4 0 1 0 0 8 4 4 0 0 0 0-8Z" fill="currentColor" /></svg>
              </span>
            ) : tool.fallbackIcon === "automation" ? (
              <span class="tool-fallback" aria-hidden="true">
                <svg viewBox="0 0 24 24"><path d="M7 4a3 3 0 0 1 3 3v1h4V7a3 3 0 1 1 6 0v3a3 3 0 0 1-3 3h-1v2h1a3 3 0 1 1-3 3v-1h-4v1a3 3 0 1 1-6 0v-3a3 3 0 0 1 3-3h1v-2H7a3 3 0 0 1-3-3V7a3 3 0 0 1 3-3Zm0 2a1 1 0 0 0-1 1v3a1 1 0 0 0 1 1h3v4H7a1 1 0 0 0-1 1v3a1 1 0 1 0 2 0v-1h8v1a1 1 0 1 0 2 0v-3a1 1 0 0 0-1-1h-3v-4h3a1 1 0 0 0 1-1V7a1 1 0 1 0-2 0v1H8V7a1 1 0 0 0-1-1Z" fill="currentColor" /></svg>
              </span>
            ) : tool.fallbackIcon === "design" ? (
              <span class="tool-fallback" aria-hidden="true">
                <svg viewBox="0 0 24 24"><path d="M6 3a3 3 0 0 0-3 3v9a6 6 0 0 0 12 0V6a3 3 0 0 0-3-3H6Zm0 2h6a1 1 0 0 1 1 1v9a4 4 0 1 1-8 0V6a1 1 0 0 1 1-1Zm12 2a3 3 0 0 1 3 3v5a6 6 0 0 1-6 6h-1.5a7.97 7.97 0 0 0 2.5-6V7h2Z" fill="currentColor" /></svg>
              </span>
            ) : (
              <span class="tool-fallback" aria-hidden="true">
                <svg viewBox="0 0 24 24"><path d="M5 5h14a2 2 0 0 1 2 2v3H3V7a2 2 0 0 1 2-2Zm-2 7h18v5a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-5Zm4 2v3h2v-3H7Zm4 0v3h6v-3h-6Z" fill="currentColor" /></svg>
              </span>
            )}

            <div class="tool-head">
              <h3 class="tool-title">{tool.title}</h3>
              {tool.category && <span class="tool-badge">{tool.category}</span>}
            </div>

            <p class="tool-text">{tool.excerpt || "Kurzbeschreibung folgt."}</p>
            <span class="tools-button">Zum Tool</span>
          </a>
        ))}
      </div>
    </section>
  </div>
</BaseLayout>
