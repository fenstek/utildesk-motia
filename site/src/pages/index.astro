---
import BaseLayout from "../layouts/BaseLayout.astro";
import { readdir, readFile } from "node:fs/promises";
import { join } from "node:path";
import matter from "gray-matter";
import { resolveLocalLogo } from "../lib/resolveLogoPath";
import { getAvatarFallbackDataUrl, getFaviconCandidates } from "../lib/favicon";

const toolsDir = join(process.cwd(), "content", "tools");
const files = (await readdir(toolsDir))
  .filter((f) => f.endsWith(".md") && !f.startsWith("_"));

const stripMarkdown = (text: string) =>
  text
    .replace(/!\[[^\]]*\]\([^)]*\)/g, "")
    .replace(/\[[^\]]*\]\([^)]*\)/g, "$1")
    .replace(/[`*_>#-]/g, "")
    .replace(/\s+/g, " ")
    .trim();

const getExcerpt = (content: string) => {
  const paragraphs = content.split(/\n\s*\n/);
  for (const paragraph of paragraphs) {
    if (paragraph.trim().startsWith("#")) continue;
    const cleaned = stripMarkdown(paragraph);
    if (cleaned) return cleaned;
  }
  return "";
};

const getImageFromContent = (content: string) => {
  const match = content.match(/!\[[^\]]*\]\(([^)]+)\)/);
  if (!match?.[1]) return null;
  return match[1].trim();
};

const normalizeImagePath = (path: string | null) => {
  if (!path) return null;
  if (path.startsWith("http://") || path.startsWith("https://")) return path;
  if (path.startsWith("/")) return path;
  return `/${path}`;
};

const resolveCategoryIcon = (category: string | null, tags: string[]) => {
  const normalizedCategory = category ? category.toLowerCase() : "";
  const normalizedTags = tags.map((tag) => tag.toLowerCase());
  const combined = [normalizedCategory, ...normalizedTags].join(" ");

  if (combined.includes("design") || combined.includes("ui") || combined.includes("ux")) return "design";
  if (combined.includes("automation") || combined.includes("workflow")) return "automation";
  if (combined.includes("ai") || combined.includes("ml") || combined.includes("machine")) return "ai";
  return "generic";
};

const tools = await Promise.all(
  files.map(async (file) => {
    const full = join(toolsDir, file);
    const raw = await readFile(full, "utf-8");
    const { data, content } = matter(raw);
    const disabled = data.disabled === true || String(data.disabled || "").toLowerCase() === "true";
    if (disabled) return null;

    const slug = String(data.slug ?? file.replace(/\.md$/, ""));
    const title = String(data.title ?? slug);
    const category = data.category ? String(data.category) : null;
    const affiliateUrl = data.affiliate_url ? String(data.affiliate_url) : null;
    const officialUrl = data.official_url ? String(data.official_url) : null;
    const image = data.image ? String(data.image) : null;
    const homeImage = data.homeImage ? String(data.homeImage) : null;
    const brandLogo = data.brandLogo ? String(data.brandLogo) : null;
    const icon = data.icon ? String(data.icon) : null;
    const tags = Array.isArray(data.tags) ? data.tags.map(String) : [];
    const description = data.description
      ? String(data.description)
      : data.summary
        ? String(data.summary)
        : data.excerpt
          ? String(data.excerpt)
          : "";
    const excerpt = description || getExcerpt(content);
    const contentImage = getImageFromContent(content);
    const localLogoPath = resolveLocalLogo(slug);
    const providerUrl = affiliateUrl || officialUrl;
    const faviconCandidates = getFaviconCandidates(providerUrl, 128);
    const faviconLogo = faviconCandidates[0] ?? null;
    const homeCardLogo = normalizeImagePath(brandLogo) ?? localLogoPath ?? faviconLogo;
    const homeCardLogoFallbacks = normalizeImagePath(brandLogo) || localLogoPath || !faviconLogo
      ? []
      : [...faviconCandidates.slice(1), getAvatarFallbackDataUrl(title)];
    const homeCardImage = normalizeImagePath(homeImage ?? image ?? icon ?? contentImage);

    return {
      slug,
      title,
      category,
      tags,
      excerpt,
      homeCardImage,
      homeCardLogo,
      homeCardLogoFallbacks,
      fallbackIcon: resolveCategoryIcon(category, tags),
      popularity: data.popularity ? Number(data.popularity) : 0,
    };
  })
);

const enabledTools = tools.filter(Boolean);
enabledTools.sort((a, b) => a.title.localeCompare(b.title, "de"));

const tagFrequency = new Map<string, number>();
enabledTools.forEach((tool) => {
  tool.tags.forEach((tag) => {
    tagFrequency.set(tag, (tagFrequency.get(tag) || 0) + 1);
  });
});

const sortedTags = Array.from(tagFrequency.entries())
  .sort((a, b) => {
    if (b[1] !== a[1]) return b[1] - a[1];
    return a[0].localeCompare(b[0], "de");
  });

const getFrequencyClass = (count: number, max: number) => {
  const ratio = count / max;
  if (ratio >= 0.6) return "tag-freq-high";
  if (ratio >= 0.3) return "tag-freq-medium";
  return "tag-freq-low";
};

const visibleTags = sortedTags.filter(([, count]) => count >= 3).slice(0, 24);
const maxFrequency = sortedTags.length > 0 ? sortedTags[0][1] : 1;

const pinnedSlugs = ["chatgpt", "claude", "midjourney", "perplexity", "zapier"];
const enabledBySlug = new Map(enabledTools.map((tool) => [tool.slug, tool]));
const pinnedTools = pinnedSlugs.map((slug) => enabledBySlug.get(slug)).filter(Boolean);
const pinnedSlugSet = new Set(pinnedSlugs);
const restTools = enabledTools.filter((tool) => !pinnedSlugSet.has(tool.slug));

restTools.sort(
  (a, b) =>
    (b.popularity ?? 0) - (a.popularity ?? 0) ||
    a.title.localeCompare(b.title, "de")
);

const latestTools = [...pinnedTools, ...restTools].slice(0, 12);
const heroTools = latestTools.slice(0, 3);
---

<BaseLayout
  title={"Utildesk - Tools & Guides f\u00fcr AI und Produktivit\u00e4t"}
  description={"Kuratiertes Verzeichnis n\u00fctzlicher AI- und Produktivit\u00e4tstools."}
>
  <Fragment slot="head">
    <link rel="canonical" href="https://tools.utildesk.de/" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Plus+Jakarta+Sans:wght@500;700;800&display=swap" rel="stylesheet" />
  </Fragment>

  <style>
    .homepage-revamp {
      --paper: #fafaf1;
      --panel: rgba(255, 255, 255, 0.82);
      --panel-strong: #ffffff;
      --ink: #1a1c17;
      --muted: #5f5e5e;
      --teal: #176259;
      --teal-soft: #367b71;
      --outline: rgba(190, 201, 197, 0.24);
      --shadow: 0 20px 40px rgba(26, 28, 23, 0.05);
      color: var(--ink);
      font-family: "Inter", var(--font-sans);
      padding: 24px 0 84px;
      position: relative;
      overflow: hidden;
    }

    .homepage-revamp::before,
    .homepage-revamp::after {
      content: "";
      position: absolute;
      border-radius: 999px;
      pointer-events: none;
      filter: blur(14px);
      opacity: 0.85;
    }

    .homepage-revamp::before {
      width: 360px;
      height: 360px;
      top: 8px;
      right: -120px;
      background: radial-gradient(circle, rgba(143, 211, 199, 0.32) 0%, rgba(143, 211, 199, 0) 72%);
    }

    .homepage-revamp::after {
      width: 300px;
      height: 300px;
      bottom: 24px;
      left: -130px;
      background: radial-gradient(circle, rgba(54, 123, 113, 0.16) 0%, rgba(54, 123, 113, 0) 72%);
    }

    .homepage-shell {
      display: grid;
      gap: 30px;
      position: relative;
      z-index: 1;
    }

    .hero-stage {
      display: grid;
      grid-template-columns: minmax(0, 1.35fr) minmax(290px, 0.85fr);
      gap: 26px;
      align-items: stretch;
    }

    .hero-copy,
    .hero-gallery,
    .tag-stage,
    .featured-stage {
      background: var(--panel);
      backdrop-filter: blur(24px);
      border-radius: 32px;
      box-shadow: var(--shadow);
    }

    .hero-copy {
      position: relative;
      overflow: hidden;
      padding: 54px 54px 46px;
      background:
        radial-gradient(circle at top left, rgba(170, 240, 227, 0.34), rgba(170, 240, 227, 0) 38%),
        linear-gradient(180deg, rgba(255,255,255,0.88), rgba(255,255,255,0.68));
    }

    .hero-copy::after {
      content: "";
      position: absolute;
      width: 180px;
      height: 180px;
      right: -24px;
      bottom: -38px;
      border-radius: 999px;
      background: radial-gradient(circle, rgba(54, 123, 113, 0.14), rgba(54, 123, 113, 0));
    }

    .hero-mark {
      display: inline-flex;
      align-items: center;
      gap: 10px;
      padding: 10px 16px;
      border-radius: 999px;
      background: rgba(255,255,255,0.78);
      color: var(--teal);
      margin-bottom: 18px;
      font-size: 0.82rem;
      font-weight: 700;
      letter-spacing: 0.08em;
      text-transform: uppercase;
    }

    .hero-mark::before {
      content: "";
      width: 10px;
      height: 10px;
      border-radius: 999px;
      background: linear-gradient(135deg, var(--teal), var(--teal-soft));
      box-shadow: 0 0 0 6px rgba(23, 98, 89, 0.08);
    }

    .hero-title {
      margin: 0 0 20px;
      font-family: "Plus Jakarta Sans", var(--font-sans);
      font-size: clamp(3.2rem, 7vw, 5.4rem);
      line-height: 0.98;
      letter-spacing: -0.055em;
      max-width: 10ch;
    }

    .hero-subtitle {
      max-width: 60ch;
      margin: 0 0 28px;
      color: var(--muted);
      font-size: clamp(1.05rem, 1.8vw, 1.22rem);
      line-height: 1.72;
    }

    .hero-cta {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      padding: 14px 24px;
      border-radius: 999px;
      background: linear-gradient(135deg, var(--teal), var(--teal-soft));
      color: #fff;
      font-weight: 700;
      box-shadow: 0 16px 32px rgba(23, 98, 89, 0.18);
      border: 0;
    }

    .hero-cta:hover {
      opacity: 1;
      transform: translateY(-2px);
    }

    .hero-gallery {
      padding: 24px;
      display: grid;
      gap: 16px;
      align-self: end;
      transform: translateY(24px);
      background: linear-gradient(180deg, rgba(255,255,255,0.92), rgba(244,244,235,0.96));
    }

    .hero-gallery-card {
      display: grid;
      grid-template-columns: 64px minmax(0, 1fr);
      gap: 14px;
      align-items: center;
      padding: 16px;
      border-radius: 24px;
      background: rgba(255,255,255,0.94);
      box-shadow: inset 0 0 0 1px var(--outline);
      color: inherit;
    }

    .hero-gallery-card:hover {
      opacity: 1;
      transform: translateY(-2px);
    }

    .hero-gallery-card:nth-child(2) {
      transform: translateX(14px);
    }

    .hero-gallery-card:nth-child(3) {
      transform: translateX(-10px);
    }

    .hero-gallery-card:nth-child(2):hover {
      transform: translateX(14px) translateY(-2px);
    }

    .hero-gallery-card:nth-child(3):hover {
      transform: translateX(-10px) translateY(-2px);
    }

    .hero-gallery-logo,
    .featured-card-logo,
    .featured-card-fallback {
      width: 64px;
      height: 64px;
      border-radius: 20px;
      display: grid;
      place-items: center;
      background: #f5f5ed;
      box-shadow: inset 0 0 0 1px rgba(190, 201, 197, 0.18);
      overflow: hidden;
      flex-shrink: 0;
    }

    .hero-gallery-logo img,
    .featured-card-logo img {
      width: 38px;
      height: 38px;
      object-fit: contain;
    }

    .hero-gallery-name,
    .featured-card-title,
    .section-title {
      font-family: "Plus Jakarta Sans", var(--font-sans);
      letter-spacing: -0.04em;
    }

    .hero-gallery-name {
      font-size: 1.18rem;
      margin: 0;
    }

    .hero-gallery-type {
      display: inline-flex;
      margin-top: 6px;
      padding: 6px 10px;
      border-radius: 999px;
      background: rgba(23, 98, 89, 0.08);
      color: var(--teal);
      font-size: 0.76rem;
      font-weight: 700;
      letter-spacing: 0.08em;
      text-transform: uppercase;
    }

    .tag-stage {
      padding: 28px 28px 30px;
      background: linear-gradient(180deg, rgba(244,244,235,0.86), rgba(255,255,255,0.92));
    }

    .tag-cloud {
      display: flex;
      flex-wrap: wrap;
      gap: 12px;
      align-items: center;
      justify-content: center;
    }

    .tag-cloud-item {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      border-radius: 999px;
      padding: 10px 16px;
      background: rgba(255,255,255,0.96);
      color: var(--ink);
      box-shadow: inset 0 0 0 1px var(--outline);
      font-weight: 600;
      line-height: 1;
    }

    .tag-cloud-item:hover {
      opacity: 1;
      transform: translateY(-2px);
    }

    .tag-freq-high { font-size: 1rem; padding-inline: 18px; }
    .tag-freq-medium { font-size: 0.95rem; }
    .tag-freq-low { font-size: 0.9rem; color: #3f4946; }

    .featured-stage {
      padding: 32px 28px 30px;
      background: linear-gradient(180deg, rgba(255,255,255,0.94), rgba(244,244,235,0.9));
    }

    .featured-stage-head {
      display: flex;
      justify-content: space-between;
      align-items: end;
      gap: 18px;
      margin-bottom: 24px;
      flex-wrap: wrap;
    }

    .section-title {
      font-size: clamp(2rem, 3vw, 2.9rem);
      margin: 0;
    }

    .section-subtitle {
      margin: 8px 0 0;
      color: var(--muted);
      max-width: 56ch;
    }

    .featured-link {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      padding: 10px 14px;
      border-radius: 999px;
      background: rgba(255,255,255,0.82);
      color: var(--teal);
      box-shadow: inset 0 0 0 1px var(--outline);
      font-weight: 700;
    }

    .featured-grid {
      display: grid;
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: 24px;
    }

    .featured-card {
      display: flex;
      flex-direction: column;
      gap: 18px;
      min-height: 212px;
      padding: 24px;
      border-radius: 30px;
      background: var(--panel-strong);
      color: inherit;
      box-shadow: 0 20px 40px rgba(26, 28, 23, 0.04);
      position: relative;
      overflow: hidden;
    }

    .featured-card::after {
      content: "";
      position: absolute;
      width: 130px;
      height: 130px;
      right: -26px;
      bottom: -42px;
      border-radius: 999px;
      background: radial-gradient(circle, rgba(143, 211, 199, 0.22), rgba(143, 211, 199, 0));
    }

    .featured-card:hover {
      opacity: 1;
      transform: translateY(-4px);
    }

    .featured-card:nth-child(3n + 2) {
      transform: translateY(18px);
    }

    .featured-card:nth-child(3n + 3) {
      transform: translateY(-8px);
    }

    .featured-card:nth-child(3n + 2):hover {
      transform: translateY(14px);
    }

    .featured-card:nth-child(3n + 3):hover {
      transform: translateY(-12px);
    }

    .featured-card-top {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 12px;
      position: relative;
      z-index: 1;
    }

    .featured-card-fallback svg {
      width: 30px;
      height: 30px;
      color: var(--teal);
    }

    .featured-card-title {
      font-size: 1.4rem;
      line-height: 1.08;
      margin: 0;
      position: relative;
      z-index: 1;
    }

    .featured-card-marker {
      width: 42px;
      height: 42px;
      border-radius: 999px;
      display: grid;
      place-items: center;
      background: #f4f4eb;
      box-shadow: inset 0 0 0 1px var(--outline);
      color: var(--teal);
      font-weight: 700;
      position: relative;
      z-index: 1;
    }

    .featured-stage-foot {
      margin-top: 34px;
      text-align: center;
    }

    .featured-stage-foot .hero-cta {
      min-width: 240px;
    }

    @media (max-width: 1080px) {
      .hero-stage {
        grid-template-columns: 1fr;
      }

      .hero-gallery {
        transform: none;
      }

      .featured-grid {
        grid-template-columns: repeat(2, minmax(0, 1fr));
      }

      .featured-card:nth-child(3n + 2),
      .featured-card:nth-child(3n + 3),
      .featured-card:nth-child(3n + 2):hover,
      .featured-card:nth-child(3n + 3):hover {
        transform: none;
      }
    }

    @media (max-width: 760px) {
      .homepage-revamp {
        padding-top: 14px;
      }

      .hero-copy,
      .hero-gallery,
      .tag-stage,
      .featured-stage {
        border-radius: 24px;
      }

      .hero-copy,
      .hero-gallery,
      .tag-stage,
      .featured-stage {
        padding-left: 20px;
        padding-right: 20px;
      }

      .hero-copy {
        padding-top: 38px;
        padding-bottom: 32px;
      }

      .hero-title {
        max-width: none;
      }

      .hero-gallery-card:nth-child(2),
      .hero-gallery-card:nth-child(3),
      .hero-gallery-card:nth-child(2):hover,
      .hero-gallery-card:nth-child(3):hover {
        transform: none;
      }

      .featured-grid {
        grid-template-columns: 1fr;
      }
    }
  </style>

  <div class="homepage-revamp">
    <div class="homepage-shell">
      <section class="hero-stage">
        <div class="hero-copy">
          <span class="hero-mark">Kuratiertes Verzeichnis</span>
          <h1 class="hero-title">Utildesk</h1>
          <p class="hero-subtitle">
            Tools &amp; Guides f&uuml;r AI, Automatisierung und Produktivit&auml;t.
            Kuratiertes Verzeichnis mit allem, was du f&uuml;r effizientes Arbeiten brauchst.
          </p>
          <a href="/tools/" class="hero-cta">Alle Tools durchsuchen &rarr;</a>
        </div>

        <aside class="hero-gallery" aria-label="Featured tools preview">
          {heroTools.map((tool) => (
            <a href={`/tools/${tool.slug}/`} class="hero-gallery-card">
              <div class="hero-gallery-logo">
                {tool.homeCardLogo ? (
                  <img src={tool.homeCardLogo} alt={tool.title} loading="lazy" data-fallback-srcs={tool.homeCardLogoFallbacks.length ? JSON.stringify(tool.homeCardLogoFallbacks) : undefined} />
                ) : tool.homeCardImage ? (
                  <img src={tool.homeCardImage} alt={tool.title} loading="lazy" />
                ) : null}
              </div>
              <div>
                <h2 class="hero-gallery-name">{tool.title}</h2>
                {tool.category && <span class="hero-gallery-type">{tool.category}</span>}
              </div>
            </a>
          ))}
        </aside>
      </section>

      <section class="tag-stage">
        {visibleTags.length > 0 ? (
          <div class="tag-cloud">
            {visibleTags.map(([tag, count]) => (
              <a
                href={`/tools/?tag=${encodeURIComponent(tag)}`}
                class={`tag-cloud-item ${getFrequencyClass(count, maxFrequency)}`}
              >
                {tag}
              </a>
            ))}
          </div>
        ) : (
          <p style="text-align: center; color: var(--muted);">Keine Tags gefunden.</p>
        )}
      </section>

      <section class="featured-stage">
        <div class="featured-stage-head">
          <div>
            <h2 class="section-title">Featured Tools</h2>
            <p class="section-subtitle">Eine Auswahl aus unserem Verzeichnis</p>
          </div>
          <a href="/tools/" class="featured-link">Alle Tools anzeigen &rarr;</a>
        </div>

        <div class="featured-grid">
          {latestTools.map((tool) => (
            <a href={`/tools/${tool.slug}/`} class="featured-card">
              <div class="featured-card-top">
                {tool.homeCardLogo ? (
                  <span class="featured-card-logo">
                    <img src={tool.homeCardLogo} alt={tool.title} loading="lazy" data-fallback-srcs={tool.homeCardLogoFallbacks.length ? JSON.stringify(tool.homeCardLogoFallbacks) : undefined} />
                  </span>
                ) : tool.homeCardImage ? (
                  <span class="featured-card-logo">
                    <img src={tool.homeCardImage} alt={tool.title} loading="lazy" />
                  </span>
                ) : tool.fallbackIcon === "ai" ? (
                  <span class="featured-card-fallback" aria-hidden="true">
                    <svg viewBox="0 0 24 24" role="img" aria-hidden="true"><path d="M9 3a1 1 0 0 1 1 1v1.1a6.002 6.002 0 0 1 4 0V4a1 1 0 1 1 2 0v2.1a6.002 6.002 0 0 1 3 5.2V13a1 1 0 0 1-1 1h-1.1a6.002 6.002 0 0 1-5.2 3V19a1 1 0 1 1-2 0v-2.1a6.002 6.002 0 0 1-5.2-3H4a1 1 0 0 1-1-1v-1.7a6.002 6.002 0 0 1 3-5.2V4a1 1 0 0 1 2 0v1.1a6.01 6.01 0 0 1 1-.1Zm3 4a4 4 0 1 0 0 8 4 4 0 0 0 0-8Z" fill="currentColor" /></svg>
                  </span>
                ) : tool.fallbackIcon === "automation" ? (
                  <span class="featured-card-fallback" aria-hidden="true">
                    <svg viewBox="0 0 24 24" role="img" aria-hidden="true"><path d="M7 4a3 3 0 0 1 3 3v1h4V7a3 3 0 1 1 6 0v3a3 3 0 0 1-3 3h-1v2h1a3 3 0 1 1-3 3v-1h-4v1a3 3 0 1 1-6 0v-3a3 3 0 0 1 3-3h1v-2H7a3 3 0 0 1-3-3V7a3 3 0 0 1 3-3Zm0 2a1 1 0 0 0-1 1v3a1 1 0 0 0 1 1h3v4H7a1 1 0 0 0-1 1v3a1 1 0 1 0 2 0v-1h8v1a1 1 0 1 0 2 0v-3a1 1 0 0 0-1-1h-3v-4h3a1 1 0 0 0 1-1V7a1 1 0 1 0-2 0v1H8V7a1 1 0 0 0-1-1Z" fill="currentColor" /></svg>
                  </span>
                ) : tool.fallbackIcon === "design" ? (
                  <span class="featured-card-fallback" aria-hidden="true">
                    <svg viewBox="0 0 24 24" role="img" aria-hidden="true"><path d="M6 3a3 3 0 0 0-3 3v9a6 6 0 0 0 12 0V6a3 3 0 0 0-3-3H6Zm0 2h6a1 1 0 0 1 1 1v9a4 4 0 1 1-8 0V6a1 1 0 0 1 1-1Zm12 2a3 3 0 0 1 3 3v5a6 6 0 0 1-6 6h-1.5a7.97 7.97 0 0 0 2.5-6V7h2Z" fill="currentColor" /></svg>
                  </span>
                ) : (
                  <span class="featured-card-fallback" aria-hidden="true">
                    <svg viewBox="0 0 24 24" role="img" aria-hidden="true"><path d="M5 5h14a2 2 0 0 1 2 2v3H3V7a2 2 0 0 1 2-2Zm-2 7h18v5a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-5Zm4 2v3h2v-3H7Zm4 0v3h6v-3h-6Z" fill="currentColor" /></svg>
                  </span>
                )}
                <span class="featured-card-marker">+</span>
              </div>
              <h3 class="featured-card-title">{tool.title}</h3>
            </a>
          ))}
        </div>

        <div class="featured-stage-foot">
          <a href="/tools/" class="hero-cta">Alle {enabledTools.length} Tools durchsuchen &rarr;</a>
        </div>
      </section>
    </div>
  </div>
</BaseLayout>
