---

import {
  DEFAULT_ROBOTS_CONTENT,
  SITE_DESCRIPTION,
  SITE_NAME,
} from "../lib/siteMeta";
import {
  buildCollectionMetaTitle,
  buildToolMetaTitle,
  enrichMetaDescription,
  humanizeTagLabel,
  normalizeSeoText,
} from "../lib/seoText";
import "../styles/global.css";

interface Props {

  title?: string;

  description?: string;

}



const {
  title = SITE_NAME,
  description = SITE_DESCRIPTION,
} = Astro.props;

const pathname = Astro.url.pathname;
const normalizedTitle = normalizeSeoText(title);
const normalizedDescription = normalizeSeoText(description);
const siteSuffixPattern = /\s+(?:—|–|-|\|)\s+Utildesk$/;
const baseTitle = normalizeSeoText(normalizedTitle.replace(siteSuffixPattern, ""));
const pathSegments = pathname.split("/").filter(Boolean);

let resolvedTitle = normalizedTitle;
let resolvedDescription = normalizedDescription;

if (/^\/tools\/[^/]+\/$/.test(pathname) && !pathname.startsWith("/tools/tag/")) {
  const toolName = baseTitle || humanizeTagLabel(pathSegments[1] ?? "Tool");
  resolvedTitle = buildToolMetaTitle(toolName);
  resolvedDescription = enrichMetaDescription(resolvedDescription, [
    `Auf Utildesk findest du ${toolName} mit Funktionen, Preis-Modell und typischen Einsatzbereichen im kompakten Überblick.`,
  ]);
} else if (pathname === "/tools/") {
  resolvedTitle = buildCollectionMetaTitle("AI-Tools", "Apps und Produktivitätstools entdecken");
  resolvedDescription = enrichMetaDescription(resolvedDescription, [
    "Durchsuche das Utildesk-Verzeichnis nach Funktionen, Kategorien und Einsatzbereichen für produktive KI-Workflows.",
  ]);
} else if (/^\/tools\/tag\/[^/]+\/$/.test(pathname)) {
  const tagLabel = humanizeTagLabel(pathSegments[2] ?? baseTitle);
  resolvedTitle = buildCollectionMetaTitle(tagLabel || "Tag", "AI-Tools mit diesem Tag entdecken");
  resolvedDescription = enrichMetaDescription(
    resolvedDescription || `Tools mit dem Tag ${tagLabel} im Utildesk-Verzeichnis.`,
    ["Vergleiche passende Tools, Kategorien und typische Einsatzbereiche auf einen Blick."],
  );
} else if (pathname === "/category/") {
  resolvedTitle = buildCollectionMetaTitle("AI-Tools", "nach Kategorien entdecken");
  resolvedDescription = enrichMetaDescription(resolvedDescription, [
    "Finde schneller passende Tools für Automatisierung, Produktivität, Schreiben, Design und Entwickler-Workflows.",
  ]);
} else if (/^\/category\/[^/]+\/$/.test(pathname)) {
  const categoryName = baseTitle || humanizeTagLabel(pathSegments[1] ?? "Kategorie");
  resolvedTitle = buildCollectionMetaTitle(categoryName, "passende AI-Tools entdecken");
  resolvedDescription = enrichMetaDescription(resolvedDescription, [
    `Vergleiche Tools, Einsatzbereiche und typische Workflows für die Kategorie ${categoryName}.`,
  ]);
} else if (pathname === "/ratgeber/") {
  resolvedTitle = "KI-Ratgeber, Vergleiche und Workflow-Guides | Utildesk";
  resolvedDescription = enrichMetaDescription(resolvedDescription, [
    "Lies redaktionelle Einordnungen, Tool-Vergleiche und Praxis-Guides für Teams, die KI produktiv einsetzen wollen.",
  ]);
} else if (/^\/ratgeber\/[^/]+\/$/.test(pathname)) {
  resolvedDescription = enrichMetaDescription(resolvedDescription, [
    "Lies die Einordnung, Praxisbeispiele und Tool-Bezüge im Utildesk-Ratgeber.",
  ]);
} else if (pathname === "/datenschutz" || pathname === "/datenschutz/") {
  resolvedTitle = "Datenschutzerklärung und Datenverarbeitung | Utildesk";
  resolvedDescription = enrichMetaDescription(resolvedDescription, [
    "Hier findest du die Hinweise zur Datenverarbeitung, Hosting-Infrastruktur und Kontaktaufnahme auf Utildesk.",
  ]);
} else if (pathname === "/impressum" || pathname === "/impressum/") {
  resolvedTitle = "Impressum und Anbieterkennzeichnung | Utildesk";
  resolvedDescription = enrichMetaDescription(resolvedDescription, [
    "Hier findest du die gesetzlichen Anbieterangaben und Kontaktinformationen für Utildesk.",
  ]);
} else if (pathname === "/") {
  resolvedTitle = "Utildesk: AI-Tools, Automatisierung und KI-Ratgeber";
  resolvedDescription = enrichMetaDescription(resolvedDescription, [
    "Entdecke kuratierte Tools, Workflows und redaktionelle Guides für produktive KI-Einsätze an einem Ort.",
  ]);
} else {
  resolvedDescription = enrichMetaDescription(resolvedDescription, [
    "Mehr Kontext, Einsatzbereiche und weiterführende Orientierung findest du auf Utildesk.",
  ]);
}

const UMAMI_SRC = import.meta.env.PUBLIC_UMAMI_SRC || "https://stats.utildesk.de/script.js";

const UMAMI_WEBSITE_ID = import.meta.env.PUBLIC_UMAMI_WEBSITE_ID;

const shouldLoadUmami = import.meta.env.PROD && UMAMI_WEBSITE_ID;

---



<!DOCTYPE html>

<html lang="de" data-accent="lime">

  <head>

    <meta charset="utf-8" />

    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <meta name="description" content={resolvedDescription} />
    <meta name="robots" content={DEFAULT_ROBOTS_CONTENT} />
    <meta property="og:site_name" content={SITE_NAME} />
    <meta property="og:title" content={resolvedTitle} />
    <meta property="og:description" content={resolvedDescription} />
    <meta property="og:locale" content="de_DE" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={resolvedTitle} />
    <meta name="twitter:description" content={resolvedDescription} />
    <meta name="application-name" content={SITE_NAME} />
    <meta name="apple-mobile-web-app-title" content={SITE_NAME} />

    <meta name="generator" content={Astro.generator} />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <link rel="icon" href="/favicon.ico" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />

    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="alternate" type="application/rss+xml" title="Utildesk Ratgeber Feed" href="/feed.xml" />
    <link rel="alternate" type="application/feed+json" title="Utildesk Ratgeber JSON Feed" href="/feed.json" />
    <link rel="alternate" type="application/json" title="Utildesk Tools Catalog" href="/api/tools.json" />
    <link rel="alternate" type="application/json" title="Utildesk Ratgeber Catalog" href="/api/ratgeber.json" />
    <link rel="alternate" type="text/plain" title="Utildesk AI manifest" href="/llms.txt" />
    <link rel="alternate" type="text/plain" title="Utildesk AI full manifest" href="/llms-full.txt" />

    <script is:inline>

      (() => {

        const storageKey = "utildesk-theme";

        try {

          const storedTheme = localStorage.getItem(storageKey);

          const theme = storedTheme === "dark" || storedTheme === "light" ? storedTheme : "dark";

          document.documentElement.dataset.theme = theme;

          document.documentElement.style.colorScheme = theme;

        } catch {

          document.documentElement.dataset.theme = "dark";

          document.documentElement.style.colorScheme = "dark";

        }

      })();

    </script>

    <title>{resolvedTitle}</title>

    <slot name="head" />

    {shouldLoadUmami && (

      <script defer src={UMAMI_SRC} data-website-id={UMAMI_WEBSITE_ID}></script>

    )}

  </head>

  <body>
    <a href="#main-content" class="skip-link">Zum Inhalt springen</a>

    <header class="site-header">

      <div class="container">

        <div class="hdr-row hdr-top">

          <a href="/" class="brand">

            <span class="brand-mark-text">[ utildesk ]</span>

            <span class="brand-sub">// ki-werkzeugverzeichnis</span>

          </a>

          <div class="hdr-meta" aria-label="Systemstatus">

            <span>v4.2.0-catalog</span>

            <span class="dot">/</span>

            <span><span class="live-dot"></span>live</span>

            <span class="dot">/</span>

            <span>curated-no-ads</span>

          </div>

        </div>

        <nav class="nav hdr-row hdr-bottom" aria-label="Hauptnavigation">

          <div class="nav-links">

            <a href="/">Verzeichnis</a>

            <a href="/tools/">Tools</a>

            <a href="/ratgeber/">Ratgeber</a>

            <a href="/category/">Kategorien</a>

          </div>

          <div class="nav-actions">

            <a class="btn-ghost" href="/llms.txt">llms.txt</a>

            <button type="button" class="theme-toggle btn-ghost" id="theme-toggle" aria-label="Design umschalten" aria-pressed="false" title="Design umschalten">

              <span data-theme-label>Hell</span>

            </button>

          </div>

        </nav>

        <div class="hdr-status">

          <span>db: tools + ratgeber</span>

          <span class="dot">/</span>

          <span>indexnow: aktiv</span>

          <span class="dot">/</span>

          <span>ai-readable manifests: online</span>

        </div>

      </div>

    </header>



    <main id="main-content" class="container">

      <slot />

    </main>



    <footer class="site-footer">

      <div class="container">

        <div class="footer-content">

          <a href="/" class="footer-brand">

            <img src="/logo-grid.svg" alt="Utildesk" height="16" />

            Utildesk

          </a>

          <div class="footer-links">

            <a href='/ratgeber/'>Ratgeber</a>

            <a href="/tools/">Tools</a>

            <a href="/category/">Kategorien</a>

            <a href="/datenschutz" rel="nofollow">Datenschutzerklärung</a>

            <a href="/impressum" rel="nofollow">Impressum</a>

          </div>

        </div>

        <p class="footer-copy">&copy; {new Date().getFullYear()} Utildesk. Disclaimer: Utildesk is an independent tools directory. All trademarks, logos, and brand names are the property of their respective owners.</p>

      </div>

    </footer>



    <script is:inline>

      (() => {

        const storageKey = "utildesk-theme";

        const root = document.documentElement;

        const button = document.getElementById("theme-toggle");

        const label = button?.querySelector("[data-theme-label]");

        const media = window.matchMedia ? window.matchMedia("(prefers-color-scheme: dark)") : null;



        const getStoredTheme = () => {

          try {

            const value = localStorage.getItem(storageKey);

            return value === "dark" || value === "light" ? value : null;

          } catch {

            return null;

          }

        };



        const applyTheme = (theme, persist = false) => {

          root.dataset.theme = theme;

          root.style.colorScheme = theme;

          if (button) {

            button.dataset.theme = theme;

            button.setAttribute("aria-pressed", String(theme === "dark"));

            button.title = theme === "dark" ? "Zum hellen Design wechseln" : "Zum dunklen Design wechseln";

          }

          if (label) {

            label.textContent = theme === "dark" ? "Dunkel" : "Hell";

          }

          if (persist) {

            try {

              localStorage.setItem(storageKey, theme);

            } catch {

              // ignore storage errors

            }

          }

        };



        applyTheme(root.dataset.theme === "dark" ? "dark" : "light");



        if (button) {

          button.addEventListener("click", () => {

            const nextTheme = root.dataset.theme === "dark" ? "light" : "dark";

            applyTheme(nextTheme, true);

          });

        }



        if (media) {

          const syncSystemTheme = (event) => {

            if (getStoredTheme()) return;

            applyTheme(event.matches ? "dark" : "light");

          };



          if (typeof media.addEventListener === "function") {

            media.addEventListener("change", syncSystemTheme);

          } else if (typeof media.addListener === "function") {

            media.addListener(syncSystemTheme);

          }

        }

      })();

    </script>

    <script is:inline>

      (() => {

        const parseFallbacks = (img) => {

          const raw = img.getAttribute("data-fallback-srcs");

          if (!raw) return [];

          try {

            const parsed = JSON.parse(raw);

            return Array.isArray(parsed) ? parsed.filter((item) => typeof item === "string" && item) : [];

          } catch {

            return [];

          }

        };



        const tryNextFallback = (img) => {

          const fallbacks = parseFallbacks(img);

          const currentIndex = Number(img.dataset.fallbackIndex || "-1");

          const nextIndex = currentIndex + 1;

          const nextSrc = fallbacks[nextIndex];

          if (!nextSrc) return;

          img.dataset.fallbackIndex = String(nextIndex);

          if (img.getAttribute("src") === nextSrc) {

            tryNextFallback(img);

            return;

          }

          img.src = nextSrc;

        };



        const bindImageFallback = (img) => {

          if (!(img instanceof HTMLImageElement)) return;

          if (img.dataset.fallbackBound === "true") return;

          if (!img.hasAttribute("data-fallback-srcs")) return;

          img.dataset.fallbackBound = "true";

          img.addEventListener("error", () => {

            tryNextFallback(img);

          });

          if (img.complete && img.naturalWidth === 0) {

            tryNextFallback(img);

          }

        };



        const bindAll = (root = document) => {

          root.querySelectorAll("img[data-fallback-srcs]").forEach(bindImageFallback);

        };



        bindAll();



        const observer = new MutationObserver((mutations) => {

          mutations.forEach((mutation) => {

            mutation.addedNodes.forEach((node) => {

              if (!(node instanceof Element)) return;

              if (node.matches("img[data-fallback-srcs]")) {

                bindImageFallback(node);

              }

              bindAll(node);

            });

          });

        });



        observer.observe(document.body, { childList: true, subtree: true });

      })();

    </script>

  </body>

</html>

