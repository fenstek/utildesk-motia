---

import {
  DEFAULT_ROBOTS_CONTENT,
  SITE_DESCRIPTION,
  SITE_NAME,
} from "../lib/siteMeta";
import {
  buildCollectionMetaTitle,
  buildToolMetaTitle,
  enrichMetaDescription,
  humanizeTagLabel,
  normalizeSeoText,
} from "../lib/seoText";
import {
  getAlternatePaths,
  getLocaleFromPath,
  hrefFor,
  LOCALE_META,
  type Locale,
  toAbsoluteLocalizedUrl,
  UI,
} from "../lib/i18n";
import "../styles/global.css";

interface Props {

  title?: string;

  description?: string;

  robots?: string;

  locale?: Locale;

  alternatePaths?: Partial<Record<Locale, string>>;

}



const {
  title = SITE_NAME,
  description = SITE_DESCRIPTION,
  robots = DEFAULT_ROBOTS_CONTENT,
  locale: propLocale,
  alternatePaths: propAlternatePaths,
} = Astro.props;

const pathname = Astro.url.pathname;
const locale = propLocale ?? getLocaleFromPath(pathname);
const ui = UI[locale];
const pathSegments = pathname.split("/").filter(Boolean);
const contentSegments = locale === "en" && pathSegments[0] === "en" ? pathSegments.slice(1) : pathSegments;
const homeHref = hrefFor("/", locale);
const toolsHref = hrefFor("/tools/", locale);
const ratgeberHref = hrefFor("/ratgeber/", locale);
const categoryHref = hrefFor("/category/", locale);
const privacyHref = locale === "en" ? "/en/privacy/" : "/datenschutz/";
const imprintHref = locale === "en" ? "/en/imprint/" : "/impressum/";
const llmsHref = locale === "en" ? "/en/llms.txt" : "/llms.txt";
const llmsFullHref = locale === "en" ? "/en/llms-full.txt" : "/llms-full.txt";
const feedXmlHref = locale === "en" ? "/en/feed.xml" : "/feed.xml";
const feedJsonHref = locale === "en" ? "/en/feed.json" : "/feed.json";
const toolsApiHref = locale === "en" ? "/en/api/tools.json" : "/api/tools.json";
const ratgeberApiHref = locale === "en" ? "/en/api/ratgeber.json" : "/api/ratgeber.json";
const normalizedTitle = normalizeSeoText(title);
const normalizedDescription = normalizeSeoText(description);
const siteSuffixPattern = /\s+(?:—|–|-|\|)\s+Utildesk$/;
const baseTitle = normalizeSeoText(normalizedTitle.replace(siteSuffixPattern, ""));

let resolvedTitle = normalizedTitle;
let resolvedDescription = normalizedDescription;

if (/^(?:\/en)?\/tools\/[^/]+\/$/.test(pathname) && !/^(?:\/en)?\/tools\/tag\//.test(pathname)) {
  const toolName = (locale === "en"
    ? baseTitle.replace(/:\s*Features,\s*Pricing\s+and\s+Use\s+Cases$/i, "")
    : baseTitle) || humanizeTagLabel(contentSegments[1] ?? "Tool");
  resolvedTitle = locale === "en"
    ? `${toolName}: Features, Pricing and Use Cases | Utildesk`
    : buildToolMetaTitle(toolName);
  resolvedDescription = enrichMetaDescription(resolvedDescription, [
    locale === "en"
      ? `Find ${toolName} on Utildesk with pricing, use cases and practical workflow context.`
      : `Auf Utildesk findest du ${toolName} mit Funktionen, Preis-Modell und typischen Einsatzbereichen im kompakten Überblick.`,
  ]);
} else if (pathname === "/tools/" || pathname === "/en/tools/") {
  resolvedTitle = locale === "en"
    ? "AI Tools, Productivity Apps and Automation Software | Utildesk"
    : buildCollectionMetaTitle("AI-Tools", "Apps und Produktivitätstools entdecken");
  resolvedDescription = enrichMetaDescription(resolvedDescription, [
    locale === "en"
      ? "Browse a curated directory of AI tools by use case, category, pricing model and workflow fit."
      : "Durchsuche das Utildesk-Verzeichnis nach Funktionen, Kategorien und Einsatzbereichen für produktive KI-Workflows.",
  ]);
} else if (/^(?:\/en)?\/tools\/tag\/[^/]+\/$/.test(pathname)) {
  const tagLabel = humanizeTagLabel(contentSegments[2] ?? baseTitle);
  resolvedTitle = locale === "en"
    ? `${tagLabel || "Tag"} AI tools | Utildesk`
    : buildCollectionMetaTitle(tagLabel || "Tag", "AI-Tools mit diesem Tag entdecken");
  resolvedDescription = enrichMetaDescription(
    resolvedDescription || `Tools mit dem Tag ${tagLabel} im Utildesk-Verzeichnis.`,
    [
      locale === "en"
        ? "Compare matching AI tools, categories and practical use cases in one curated directory."
        : "Vergleiche passende Tools, Kategorien und typische Einsatzbereiche auf einen Blick.",
    ],
  );
} else if (pathname === "/category/" || pathname === "/en/category/") {
  resolvedTitle = locale === "en"
    ? "AI Tool Categories | Utildesk"
    : buildCollectionMetaTitle("AI-Tools", "nach Kategorien entdecken");
  resolvedDescription = enrichMetaDescription(resolvedDescription, [
    locale === "en"
      ? "Explore AI tools by category, from productivity and writing to developer workflows and automation."
      : "Finde schneller passende Tools für Automatisierung, Produktivität, Schreiben, Design und Entwickler-Workflows.",
  ]);
} else if (/^(?:\/en)?\/category\/[^/]+\/$/.test(pathname)) {
  const categoryName = baseTitle || humanizeTagLabel(contentSegments[1] ?? "Kategorie");
  resolvedTitle = locale === "en"
    ? `${categoryName} AI tools | Utildesk`
    : buildCollectionMetaTitle(categoryName, "passende AI-Tools entdecken");
  resolvedDescription = enrichMetaDescription(resolvedDescription, [
    locale === "en"
      ? `Compare AI tools, workflows and practical use cases in the ${categoryName} category.`
      : `Vergleiche Tools, Einsatzbereiche und typische Workflows für die Kategorie ${categoryName}.`,
  ]);
} else if (pathname === "/ratgeber/" || pathname === "/en/ratgeber/") {
  resolvedTitle = locale === "en"
    ? "AI Guides, Comparisons and Workflow Briefings | Utildesk"
    : "KI-Ratgeber, Vergleiche und Workflow-Guides | Utildesk";
  resolvedDescription = enrichMetaDescription(resolvedDescription, [
    locale === "en"
      ? "Read practical AI guides, tool comparisons and workflow briefings for productive teams."
      : "Lies redaktionelle Einordnungen, Tool-Vergleiche und Praxis-Guides für Teams, die KI produktiv einsetzen wollen.",
  ]);
} else if (/^(?:\/en)?\/ratgeber\/[^/]+\/$/.test(pathname)) {
  resolvedDescription = enrichMetaDescription(resolvedDescription, [
    locale === "en"
      ? "Read the context, practical examples and related tools in the Utildesk guide."
      : "Lies die Einordnung, Praxisbeispiele und Tool-Bezüge im Utildesk-Ratgeber.",
  ]);
} else if (pathname === "/datenschutz" || pathname === "/datenschutz/" || pathname === "/en/privacy/" || pathname === "/en/privacy") {
  resolvedTitle = locale === "en"
    ? "Privacy Policy and Data Processing | Utildesk"
    : "Datenschutzerklärung und Datenverarbeitung | Utildesk";
  resolvedDescription = enrichMetaDescription(resolvedDescription, [
    locale === "en"
      ? "Privacy information for hosting, analytics, external resources and contact handling on Utildesk."
      : "Hier findest du die Hinweise zur Datenverarbeitung, Hosting-Infrastruktur und Kontaktaufnahme auf Utildesk.",
  ]);
} else if (pathname === "/impressum" || pathname === "/impressum/" || pathname === "/en/imprint/" || pathname === "/en/imprint") {
  resolvedTitle = locale === "en"
    ? "Imprint and Provider Information | Utildesk"
    : "Impressum und Anbieterkennzeichnung | Utildesk";
  resolvedDescription = enrichMetaDescription(resolvedDescription, [
    locale === "en"
      ? "Legal provider and contact information for Utildesk."
      : "Hier findest du die gesetzlichen Anbieterangaben und Kontaktinformationen für Utildesk.",
  ]);
} else if (pathname === "/" || pathname === "/en/") {
  resolvedTitle = locale === "en"
    ? "Utildesk: AI Tools, Automation and Practical Guides"
    : "Utildesk: AI-Tools, Automatisierung und KI-Ratgeber";
  resolvedDescription = enrichMetaDescription(resolvedDescription, [
    locale === "en"
      ? "Discover curated AI tools, workflow context and practical guides in one AI-readable directory."
      : "Entdecke kuratierte Tools, Workflows und redaktionelle Guides für produktive KI-Einsätze an einem Ort.",
  ]);
} else {
  resolvedDescription = enrichMetaDescription(resolvedDescription, [
    locale === "en"
      ? "Find more context, use cases and practical orientation on Utildesk."
      : "Mehr Kontext, Einsatzbereiche und weiterführende Orientierung findest du auf Utildesk.",
  ]);
}

const alternatePaths = propAlternatePaths ?? getAlternatePaths(pathname);
const languageSwitchTarget = alternatePaths
  ? alternatePaths[locale === "en" ? "de" : "en"]
  : hrefFor("/", locale === "en" ? "de" : "en");
const themeLabels = JSON.stringify({
  dark: ui.themeDark,
  light: ui.themeLight,
  toDark: ui.themeToDark,
  toLight: ui.themeToLight,
});

const UMAMI_SRC = import.meta.env.PUBLIC_UMAMI_SRC || "https://stats.utildesk.de/script.js";

const UMAMI_WEBSITE_ID = import.meta.env.PUBLIC_UMAMI_WEBSITE_ID;

const shouldLoadUmami = import.meta.env.PROD && UMAMI_WEBSITE_ID;

---



<!DOCTYPE html>

<html lang={LOCALE_META[locale].lang} data-accent="lime">

  <head>

    <meta charset="utf-8" />

    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <meta name="description" content={resolvedDescription} />
    <meta name="robots" content={robots} />
    <meta property="og:site_name" content={SITE_NAME} />
    <meta property="og:title" content={resolvedTitle} />
    <meta property="og:description" content={resolvedDescription} />
    <meta property="og:locale" content={locale === "en" ? "en_US" : "de_DE"} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={resolvedTitle} />
    <meta name="twitter:description" content={resolvedDescription} />
    <meta name="application-name" content={SITE_NAME} />
    <meta name="apple-mobile-web-app-title" content={SITE_NAME} />

    <meta name="generator" content={Astro.generator} />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <link rel="icon" href="/favicon.ico" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />

    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="alternate" type="application/rss+xml" title={locale === "en" ? "Utildesk Guides Feed" : "Utildesk Ratgeber Feed"} href={feedXmlHref} />
    <link rel="alternate" type="application/feed+json" title={locale === "en" ? "Utildesk Guides JSON Feed" : "Utildesk Ratgeber JSON Feed"} href={feedJsonHref} />
    <link rel="alternate" type="application/json" title="Utildesk Tools Catalog" href={toolsApiHref} />
    <link rel="alternate" type="application/json" title={locale === "en" ? "Utildesk Guides Catalog" : "Utildesk Ratgeber Catalog"} href={ratgeberApiHref} />
    <link rel="alternate" type="text/plain" title="Utildesk AI manifest" href={llmsHref} />
    <link rel="alternate" type="text/plain" title="Utildesk AI full manifest" href={llmsFullHref} />
    {alternatePaths && (
      <>
        <link rel="alternate" hreflang="de" href={toAbsoluteLocalizedUrl(alternatePaths.de ?? "/")} />
        <link rel="alternate" hreflang="en" href={toAbsoluteLocalizedUrl(alternatePaths.en ?? "/en/")} />
        <link rel="alternate" hreflang="x-default" href={toAbsoluteLocalizedUrl(alternatePaths.de ?? "/")} />
      </>
    )}

    <script is:inline>

      (() => {

        const storageKey = "utildesk-theme";

        try {

          const storedTheme = localStorage.getItem(storageKey);

          const theme = storedTheme === "dark" || storedTheme === "light" ? storedTheme : "dark";

          document.documentElement.dataset.theme = theme;

          document.documentElement.style.colorScheme = theme;

        } catch {

          document.documentElement.dataset.theme = "dark";

          document.documentElement.style.colorScheme = "dark";

        }

      })();

    </script>

    <title>{resolvedTitle}</title>

    <slot name="head" />

    {shouldLoadUmami && (

      <script defer src={UMAMI_SRC} data-website-id={UMAMI_WEBSITE_ID}></script>

    )}

  </head>

  <body>
    <a href="#main-content" class="skip-link">{ui.skipLink}</a>

    <header class="site-header">

      <div class="container">

        <div class="hdr-row hdr-top">

          <a href={homeHref} class="brand">

            <span class="brand-mark-text">[ utildesk ]</span>

            <span class="brand-sub">{ui.brandSub}</span>

          </a>

          <div class="hdr-meta" aria-label={ui.systemStatus}>

            <span>v4.2.0-catalog</span>

            <span class="dot">/</span>

            <span><span class="live-dot"></span>live</span>

            <span class="dot">/</span>

            <span>curated-no-ads</span>

          </div>

        </div>

        <nav class="nav hdr-row hdr-bottom" aria-label={ui.navLabel}>

          <div class="nav-links">

            <a href={homeHref}>{ui.navHome}</a>

            <a href={toolsHref}>{ui.navTools}</a>

            <a href={ratgeberHref}>{ui.navGuides}</a>

            <a href={categoryHref}>{ui.navCategories}</a>

          </div>

          <div class="nav-actions">

            <a class="btn-ghost" href={llmsHref}>{ui.llms}</a>

            <a class="btn-ghost" href={languageSwitchTarget} hreflang={locale === "en" ? "de" : "en"} aria-label={ui.languageLabel}>{ui.languageSwitch}</a>

            <button type="button" class="theme-toggle btn-ghost" id="theme-toggle" aria-label={ui.themeToggleLabel} aria-pressed="false" title={ui.themeToggleLabel} data-theme-labels={themeLabels}>

              <span data-theme-label>{ui.themeLight}</span>

            </button>

          </div>

        </nav>

        <div class="hdr-status">

          <span>{ui.dbStatus}</span>

          <span class="dot">/</span>

          <span>{ui.indexNowStatus}</span>

          <span class="dot">/</span>

          <span>{ui.aiReadableStatus}</span>

        </div>

      </div>

    </header>



    <main id="main-content" class="container">

      <slot />

    </main>



    <footer class="site-footer">

      <div class="container">

        <div class="footer-content">

          <a href={homeHref} class="footer-brand">

            <img src="/logo-grid.svg" alt="Utildesk" height="16" />

            Utildesk

          </a>

          <div class="footer-links">

            <a href={ratgeberHref}>{ui.footerGuides}</a>

            <a href={toolsHref}>{ui.footerTools}</a>

            <a href={categoryHref}>{ui.footerCategories}</a>

            <a href={privacyHref} rel="nofollow">{ui.footerPrivacy}</a>

            <a href={imprintHref} rel="nofollow">{ui.footerImprint}</a>

          </div>

        </div>

        <p class="footer-copy">&copy; {new Date().getFullYear()} Utildesk. {ui.footerCopy}</p>

      </div>

    </footer>



    <script is:inline>

      (() => {

        const storageKey = "utildesk-theme";

        const root = document.documentElement;

        const button = document.getElementById("theme-toggle");

        const label = button?.querySelector("[data-theme-label]");
        const themeLabels = (() => {
          try {
            return JSON.parse(button?.getAttribute("data-theme-labels") || "{}");
          } catch {
            return {};
          }
        })();

        const media = window.matchMedia ? window.matchMedia("(prefers-color-scheme: dark)") : null;



        const getStoredTheme = () => {

          try {

            const value = localStorage.getItem(storageKey);

            return value === "dark" || value === "light" ? value : null;

          } catch {

            return null;

          }

        };



        const applyTheme = (theme, persist = false) => {

          root.dataset.theme = theme;

          root.style.colorScheme = theme;

          if (button) {

            button.dataset.theme = theme;

            button.setAttribute("aria-pressed", String(theme === "dark"));

            button.title = theme === "dark" ? themeLabels.toLight : themeLabels.toDark;

          }

          if (label) {

            label.textContent = theme === "dark" ? themeLabels.dark : themeLabels.light;

          }

          if (persist) {

            try {

              localStorage.setItem(storageKey, theme);

            } catch {

              // ignore storage errors

            }

          }

        };



        applyTheme(root.dataset.theme === "dark" ? "dark" : "light");



        if (button) {

          button.addEventListener("click", () => {

            const nextTheme = root.dataset.theme === "dark" ? "light" : "dark";

            applyTheme(nextTheme, true);

          });

        }



        if (media) {

          const syncSystemTheme = (event) => {

            if (getStoredTheme()) return;

            applyTheme(event.matches ? "dark" : "light");

          };



          if (typeof media.addEventListener === "function") {

            media.addEventListener("change", syncSystemTheme);

          } else if (typeof media.addListener === "function") {

            media.addListener(syncSystemTheme);

          }

        }

      })();

    </script>

    <script is:inline>

      (() => {

        const parseFallbacks = (img) => {

          const raw = img.getAttribute("data-fallback-srcs");

          if (!raw) return [];

          try {

            const parsed = JSON.parse(raw);

            return Array.isArray(parsed) ? parsed.filter((item) => typeof item === "string" && item) : [];

          } catch {

            return [];

          }

        };



        const tryNextFallback = (img) => {

          const fallbacks = parseFallbacks(img);

          const currentIndex = Number(img.dataset.fallbackIndex || "-1");

          const nextIndex = currentIndex + 1;

          const nextSrc = fallbacks[nextIndex];

          if (!nextSrc) return;

          img.dataset.fallbackIndex = String(nextIndex);

          if (img.getAttribute("src") === nextSrc) {

            tryNextFallback(img);

            return;

          }

          img.src = nextSrc;

        };



        const bindImageFallback = (img) => {

          if (!(img instanceof HTMLImageElement)) return;

          if (img.dataset.fallbackBound === "true") return;

          if (!img.hasAttribute("data-fallback-srcs")) return;

          img.dataset.fallbackBound = "true";

          img.addEventListener("error", () => {

            tryNextFallback(img);

          });

          if (img.complete && img.naturalWidth === 0) {

            tryNextFallback(img);

          }

        };



        const bindAll = (root = document) => {

          root.querySelectorAll("img[data-fallback-srcs]").forEach(bindImageFallback);

        };



        bindAll();



        const observer = new MutationObserver((mutations) => {

          mutations.forEach((mutation) => {

            mutation.addedNodes.forEach((node) => {

              if (!(node instanceof Element)) return;

              if (node.matches("img[data-fallback-srcs]")) {

                bindImageFallback(node);

              }

              bindAll(node);

            });

          });

        });



        observer.observe(document.body, { childList: true, subtree: true });

      })();

    </script>

  </body>

</html>

