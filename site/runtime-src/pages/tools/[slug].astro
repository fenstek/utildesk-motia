---
export const prerender = false;
import RuntimeToolDetail from "../../components/RuntimeToolDetail.astro";
import RuntimeToolUnavailable from "../../components/RuntimeToolUnavailable.astro";
import { getRuntimeContentEntry, listRuntimeContentEntries } from "../../lib/runtimeContent";

const slug = Astro.params.slug ?? "";
const entry = await getRuntimeContentEntry("tool", "de", slug);
if (entry?.routeState === "redirect") return Astro.redirect(entry.canonicalPath, 301);
const renderable = Boolean(entry?.isActive && entry.routeState === "active");
const status = entry?.routeState === "tombstone" ? 410 : 404;
if (!renderable) Astro.response.status = status;
const [tools, guides] = renderable ? await Promise.all([
  listRuntimeContentEntries("tool", "de"),
  listRuntimeContentEntries("ratgeber", "de"),
]) : [[], []];
---
{renderable && entry ? <RuntimeToolDetail locale="de" entry={entry} tools={tools} guides={guides} /> : <RuntimeToolUnavailable locale="de" status={status} />}
