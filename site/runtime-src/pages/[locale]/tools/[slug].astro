---
export const prerender = false;
import RuntimeToolDetail from "../../../components/RuntimeToolDetail.astro";
import RuntimeToolUnavailable from "../../../components/RuntimeToolUnavailable.astro";
import { getRuntimeContentEntry, listRuntimeGuideBacklinkContext, listRuntimeToolContext } from "../../../lib/runtimeContent";
import { runtimeToolContextRequest } from "../../../lib/toolRuntime";

const locale = Astro.params.locale;
const slug = Astro.params.slug ?? "";
const validLocale = locale === "en";
const entry = validLocale ? await getRuntimeContentEntry("tool", "en", slug) : null;
if (entry?.routeState === "redirect" && entry.redirectTargetPath) return Astro.redirect(entry.redirectTargetPath, 301);
const renderable = Boolean(entry?.isActive && entry.routeState === "active");
const status = entry?.routeState === "tombstone" ? 410 : 404;
if (!renderable) {
  Astro.response.status = status;
  if (entry?.routeState) Astro.response.headers.set("X-Utildesk-Route-State", entry.routeState);
}
const context = entry ? runtimeToolContextRequest(entry.markdown, entry.slug) : { slugs: [], titles: [] };
const [tools, guides] = renderable ? await Promise.all([
  listRuntimeToolContext("en", context.slugs, context.titles),
  listRuntimeGuideBacklinkContext("en", slug),
]) : [[], []];
---
{renderable && entry ? <RuntimeToolDetail locale="en" entry={entry} tools={tools} guides={guides} /> : <RuntimeToolUnavailable locale="en" status={status} />}
