---
export const prerender = false;
import StaticEnglishCategoryDetail from "../../../../src/pages/[locale]/category/[slug].astro";
import { CATEGORIES } from "../../../../src/lib/categories";
import { getRuntimeToolShellData } from "../../../lib/toolShellRuntime";
const validLocale = Astro.params.locale === "en";
const category = validLocale ? CATEGORIES.find((item) => item.slug === Astro.params.slug) : null;
if (!category) Astro.response.status = 404;
const data = await getRuntimeToolShellData("en");
---
{category && <StaticEnglishCategoryDetail runtimeCategory={category} runtimeTools={data.displayTools} />}
