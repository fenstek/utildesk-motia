---
export const prerender = false;
import RuntimeToolDetail from "../../../../components/RuntimeToolDetail.astro";
import RuntimeToolUnavailable from "../../../../components/RuntimeToolUnavailable.astro";
import { getRuntimeContentEntry, listRuntimeContentEntries, type RuntimeLocale } from "../../../../lib/runtimeContent";

const locale = Astro.params.locale === "de" || Astro.params.locale === "en" ? Astro.params.locale as RuntimeLocale : null;
const slug = Astro.params.slug ?? "";
const entry = locale ? await getRuntimeContentEntry("tool", locale, slug) : null;
const renderable = Boolean(entry?.isActive && entry.routeState === "active");
const status = entry?.routeState === "tombstone" ? 410 : 404;
if (!renderable) Astro.response.status = status;
const [tools, guides] = renderable && locale ? await Promise.all([
  listRuntimeContentEntries("tool", locale),
  listRuntimeContentEntries("ratgeber", locale),
]) : [[], []];
---
{renderable && entry && locale ? <RuntimeToolDetail locale={locale} entry={entry} tools={tools} guides={guides} preview /> : <RuntimeToolUnavailable locale={locale || "de"} status={status} />}
